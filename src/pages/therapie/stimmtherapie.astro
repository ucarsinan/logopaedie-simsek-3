---
import ServicePage from '../../layouts/ServicePage.astro';
import { Image } from 'astro:assets';
import stimmImg from '../../assets/therapy/stimmtherapie-bildkarten-duisburg.webp';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Stimmtherapie: Stimmstörungen behandeln in Duisburg",
  "description": "Logopädische Stimmtherapie in Duisburg bei Dysphonie, Heiserkeit und organischen Stimmstörungen. Für Berufssprecher, Sänger und alle Altersgruppen.",
  "url": "https://logopaedie-simsek.de/therapie/stimmtherapie/",
  "about": { "@type": "MedicalCondition", "name": "Stimmstörung" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://logopaedie-simsek.de/" },
      { "@type": "ListItem", "position": 2, "name": "Therapieangebot", "item": "https://logopaedie-simsek.de/therapie/" },
      { "@type": "ListItem", "position": 3, "name": "Stimmtherapie", "item": "https://logopaedie-simsek.de/therapie/stimmtherapie/" }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Übernimmt die Krankenkasse die Kosten für Stimmtherapie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bei ärztlicher Verordnung übernehmen gesetzliche Krankenkassen Stimmtherapie als Heilmittel abzüglich der gesetzlichen Zuzahlung. Voraussetzung ist in der Regel eine laryngoskopische Untersuchung durch einen HNO-Arzt und ein entsprechendes Rezept. Bei Privatkassen und Beihilfe hängt die Erstattung vom jeweiligen Tarif beziehungsweise Beihilfeanspruch ab."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Stimmtherapie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Dauer einer Stimmtherapie hängt von der Art und Schwere der Stimmstörung ab. Typischerweise umfasst eine Therapie 10 bis 20 Einheiten à 45 Minuten. Bei funktionellen Stimmstörungen sind oft weniger Sitzungen nötig als bei organischen oder neurogenen Stimmstörungen."
      }
    },
    {
      "@type": "Question",
      "name": "Muss ich vor der Stimmtherapie zum HNO-Arzt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, vor Beginn einer Stimmtherapie ist eine Untersuchung beim HNO-Arzt (Laryngoskopie) dringend empfohlen und für die Verordnung notwendig. Heiserkeit, die länger als 2–3 Wochen anhält, sollte zunächst ärztlich abgeklärt werden, um ernsthafte Erkrankungen auszuschließen."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist die Lax-Vox-Methode in der Stimmtherapie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lax Vox® ist eine sanfte Methode der Stimmtherapie, bei der durch einen Schlauch in Wasser phoniert wird. Der entstehende Gegendruck kann eine ökonomischere Stimmgebung unterstützen und die Wahrnehmung für eine entspannte Phonation verbessern. Ob die Methode geeignet ist, hängt vom individuellen Befund ab."
      }
    }
  ]
};
---

<ServicePage
  title="Stimmtherapie & Stimmstörungen | Praxis für Logopädie Şimşek Duisburg"
  description="Logopädische Stimmtherapie in Duisburg – bei Dysphonie, Heiserkeit und funktionellen Stimmstörungen. Für Berufssprecher, Lehrerinnen, Sänger und alle Altersgruppen."
  serviceTitle="Stimmtherapie: Ihre Stimme – unsere Expertise"
  breadcrumbLabel="Stimmtherapie"
  tags={['Dysphonie', 'Heiserkeit', 'Stimmbildung', 'Berufssprecher']}
  additionalSchemas={[schema, faqSchema]}
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/therapie/stimmtherapie/' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/terapi/ses-terapisi/' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/therapie/stimmtherapie/' },
  ]}
  alternateUrl="/terapi/ses-terapisi"
  relatedServices={[
    { title: 'Sprachstörungen', href: '/therapie/sprachstoerungen/', description: 'Sprachentwicklungsverzögerung, Aphasie, Frühförderung' },
    { title: 'Sprechstörungen', href: '/therapie/sprechstoerungen/', description: 'Stottern, Lispeln, Dysarthrie und Sprechapraxie' },
    { title: 'Schluckstörungen', href: '/therapie/schluckstoerungen/', description: 'Dysphagie bei Erwachsenen und Kindern' },
  ]}
>
  <section class="bento-page" aria-label="Stimmtherapie in Duisburg">
    <div class="bento-grid">
      <article class="bento-card bento-card--image">
        <Image
          src={stimmImg}
          alt="Bildkarten und Therapiematerialien für die Stimmtherapie in der Praxis Şimşek Duisburg"
          class="bento-card__image"
          widths={[540, 900, 1200]}
          sizes="(max-width: 960px) 100vw, 55vw"
          loading="eager"
          decoding="async"
        />
        <div class="bento-card__overlay">
          <span class="bento-eyebrow">Stimmdiagnostik</span>
          <h2>Stimmstörungen erkennen, behandeln und vorbeugen</h2>
          <p>
            Heiserkeit, Stimmversagen oder Schmerzen beim Sprechen können Zeichen einer
            behandlungsbedürftigen Stimmstörung sein. Logopädische Stimmtherapie kann
            helfen, Stimmfunktion, Belastbarkeit und stimmhygienisches Verhalten gezielt
            zu verbessern.
          </p>
        </div>
      </article>

      <article class="bento-card bento-card--highlight">
        <span class="bento-eyebrow">Betroffene Berufsgruppen</span>
        <h2>Wer besonders von Stimmstörungen betroffen ist</h2>
        <ul>
          <li><strong>Lehrerinnen und Lehrer:</strong> hohe tägliche Stimmbelastung</li>
          <li><strong>Erzieherinnen und Erzieher:</strong> lautes Sprechen in Gruppen</li>
          <li><strong>Sängerinnen und Sänger:</strong> professioneller Stimmgebrauch</li>
          <li><strong>Call-Center-Mitarbeiterinnen:</strong> dauerhaftes Telefonsprechen</li>
          <li><strong>Führungskräfte:</strong> Präsentationen und Konferenzen</li>
          <li><strong>Nach Erkrankungen:</strong> Kehlkopfoperationen, COVID-19-Folgen</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Störungsbilder</span>
        <h2>Arten von Stimmstörungen im Überblick</h2>
        <ul>
          <li><strong>Funktionell:</strong> Fehlbelastung ohne strukturelle Schädigung</li>
          <li><strong>Organisch:</strong> Knötchen, Polypen, Ödeme oder Narben</li>
          <li><strong>Psychogen:</strong> psychisch bedingter Stimmverlust</li>
          <li><strong>Neurogen:</strong> nach Recurrensparese oder neurologischen Erkrankungen</li>
          <li><strong>Kinder:</strong> Stimmknötchen durch übermäßiges Schreien</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">ISTP-Methode</span>
        <h2>Integrative Stimmtherapie nach Evemarie Haupt</h2>
        <p>
          In unserer Praxis arbeiten wir nach der <strong>ISTP-Methode</strong> –
          Atmung, Haltung, Bewegung und Wahrnehmung vereint in einem ganzheitlichen
          Therapiekonzept.
        </p>
        <ul>
          <li>„Stimme ist Balance" – Gleichgewicht von Körper, Atem und Klang</li>
          <li>„Wohlgefühl bringt Wohlklang" – Entspannung als Basis gesunder Stimme</li>
          <li>„Wo Druck ist, kann keine Schwingung sein" – Überspannung lösen</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Lax Vox®</span>
        <h2>Schonende Stimmrehabilitation durch Wasserblase</h2>
        <p>
          Bei Lax Vox® wird durch ein Schlauchsystem in Wasser phoniert. Der entstehende
          Gegendruck kann eine ökonomischere Stimmgebung unterstützen und die Wahrnehmung
          für eine entspannte Phonation verbessern.
        </p>
        <p>
          Ob diese Methode geeignet ist, hängt vom individuellen Befund ab. Sie kann unter
          anderem bei funktionellen Stimmproblemen und im Rahmen der Stimmrehabilitation
          eingesetzt werden.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Therapiebausteine</span>
        <h2>Typische Elemente einer logopädischen Stimmtherapie</h2>
        <ul>
          <li><strong>Stimmhygiene:</strong> Verhaltensregeln zum Schutz der Stimme im Alltag</li>
          <li><strong>Atemschulung:</strong> Aufbau einer stützenden Atemtechnik als Basis der Stimmgebung</li>
          <li><strong>Resonanzübungen:</strong> Optimierung des Klangkörpers und Lockerung der Artikulationsorgane</li>
          <li><strong>Phonationsübungen:</strong> Abbau von Überspannung, weicher Stimmeinsatz</li>
          <li><strong>Körperarbeit:</strong> Haltung, Entspannung und Körperbewusstsein</li>
          <li><strong>Transfer:</strong> Übertragung erlernter Techniken auf reale Sprechsituationen</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Wichtiger Hinweis</span>
        <h2>Vor der Therapie: HNO-Untersuchung notwendig</h2>
        <p>
          Heiserkeit, die länger als 2–3 Wochen anhält, sollte zunächst ärztlich abgeklärt
          werden. Erst nach einer <strong>laryngoskopischen Untersuchung</strong> beginnen
          wir mit der Stimmtherapie – so ist die Behandlung sicher und zielgerichtet.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Diagnostik</span>
        <h2>Stimmanalyse als Grundlage jeder Behandlung</h2>
        <p>
          Wir erheben Ihre Stimmanamnese, analysieren Ihre Stimmqualität und sprechen
          die Befunde mit Ihrem behandelnden HNO-Arzt ab. Darauf aufbauend entwickeln
          wir einen individuellen Therapieplan.
        </p>
      </article>

      <article class="bento-card bento-card--accent">
        <span class="bento-eyebrow">DE / TR</span>
        <h2>Stimmtherapie auf Deutsch oder Türkisch – ganz nach Ihren Bedürfnissen.</h2>
        <p>
          Türkischsprachige Patientinnen und Patienten können die gesamte Therapie
          vollständig auf Türkisch in Anspruch nehmen.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Kassenleistung</span>
        <h2>Kostenübernahme durch gesetzliche und private Krankenkassen</h2>
        <ul>
          <li>Stimmtherapie ist ein anerkanntes Heilmittel bei ärztlicher Verordnung</li>
          <li>Verordnende Fachärzte: HNO-Ärzte, Phoniatriker, Neurologen</li>
          <li>Laryngoskopische Untersuchung als Voraussetzung für die Verordnung</li>
          <li>Bei Privatkassen und Beihilfe hängt die Erstattung vom jeweiligen Tarif beziehungsweise Anspruch ab</li>
        </ul>
      </article>

      <article class="bento-card bento-card--soft">
        <span class="bento-eyebrow">Prävention</span>
        <h2>Stimmbildung als Schutz vor zukünftigen Erkrankungen</h2>
        <p>
          Neben der Behandlung bestehender Stimmstörungen bieten wir präventive
          Stimmbildungskurse für stimmintensive Berufsgruppen an.
        </p>
        <p>
          Wer seine Stimme kennt und pflegt, schützt sich langfristig vor
          Erkrankungen und Ausfällen.
        </p>
      </article>
    </div>
  </section>
</ServicePage>

<style>
  .bento-page {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    grid-auto-flow: row dense;
  }

  .bento-card {
    grid-column: span 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(28, 25, 22, 0.06);
    min-height: 100%;
  }

  .bento-card--image {
    grid-column: span 6;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 22rem;
    border: 0;
  }

  .bento-card--highlight {
    grid-column: span 6;
    background: linear-gradient(180deg, rgba(112, 90, 74, 0.08), rgba(255, 255, 255, 0.96));
  }

  .bento-card--wide {
    grid-column: span 8;
  }

  .bento-card--accent {
    background: var(--color-primary);
    color: white;
  }

  .bento-card--soft {
    background: var(--color-primary-light);
  }

  .bento-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bento-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(24, 18, 14, 0.08) 10%,
      rgba(24, 18, 14, 0.76) 100%
    );
  }

  .bento-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .bento-card--image .bento-eyebrow,
  .bento-card--accent .bento-eyebrow {
    color: rgba(255, 255, 255, 0.84);
  }

  .bento-grid .bento-card :global(h2),
  .bento-grid .bento-card__overlay :global(h2) {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
    color: var(--color-text);
  }

  .bento-grid .bento-card__overlay :global(h2) {
    color: white;
    max-width: 20ch;
  }

  .bento-card__overlay :global(p),
  .bento-card__overlay :global(p strong),
  .bento-card__overlay :global(p a) {
    color: #ffffff !important;
  }

  .bento-grid .bento-card :global(p),
  .bento-grid .bento-card :global(ul),
  .bento-grid .bento-card__overlay :global(p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .bento-grid .bento-card__overlay :global(p) {
    max-width: 56ch;
  }

  .bento-grid .bento-card :global(ul) {
    display: grid;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .bento-grid .bento-card :global(li) {
    position: relative;
    padding-left: 1rem;
  }

  .bento-grid .bento-card :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .bento-grid .bento-card--accent :global(h2),
  .bento-grid .bento-card--accent :global(p),
  .bento-grid .bento-card--accent :global(a),
  .bento-grid .bento-card--accent .bento-eyebrow {
    color: white;
  }

  @media (max-width: 960px) {
    .bento-card,
    .bento-card--image,
    .bento-card--highlight,
    .bento-card--wide {
      grid-column: span 12;
    }

    .bento-card--image {
      min-height: 19rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      gap: 0.875rem;
    }

    .bento-card {
      padding: 1.2rem;
    }

    .bento-card--image {
      min-height: 0;
      padding: 1rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .bento-card__overlay {
      position: static;
      padding: 1rem 0 0;
      background: none;
    }

    .bento-card__image {
      height: 13.5rem;
      border-radius: 6px;
    }

    .bento-card--image .bento-eyebrow {
      color: var(--color-primary);
    }

    .bento-grid .bento-card__overlay :global(h2) {
      color: var(--color-text);
      max-width: none;
    }

    .bento-card__overlay :global(p),
    .bento-card__overlay :global(p strong),
    .bento-card__overlay :global(p a) {
      color: var(--color-text-muted) !important;
    }

    .bento-card__overlay :global(strong),
    .bento-card__overlay :global(a) {
      color: var(--color-text) !important;
    }
  }
</style>
