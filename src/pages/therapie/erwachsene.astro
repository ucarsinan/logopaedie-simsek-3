---
import ServicePage from '../../layouts/ServicePage.astro';
import { Image } from 'astro:assets';
import erwachseneImg from '../../assets/therapy/logopaedie-erwachsene-bildkarten-duisburg.webp';

const siteUrl = 'https://logopaedie-simsek.de';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Logopädie für Erwachsene Duisburg",
  "description": "Logopädische Therapie für Erwachsene in Duisburg. Aphasie, Dysarthrie, Stimmstörungen, Schluckstörungen nach Schlaganfall oder neurologischen Erkrankungen.",
  "url": `${siteUrl}/therapie/erwachsene`,
  "about": { "@type": "MedicalCondition", "name": "Aphasie" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Therapieangebot", "item": `${siteUrl}/therapie` },
      { "@type": "ListItem", "position": 3, "name": "Therapie für Erwachsene", "item": `${siteUrl}/therapie/erwachsene` }
    ]
  }
};
---

<ServicePage
  title="Logopädie für Erwachsene Duisburg – Aphasie, Stimme, Schlucken | Praxis Şimşek"
  description="Logopädische Therapie für Erwachsene in Duisburg – Aphasie nach Schlaganfall, Dysarthrie, Stimmstörungen, Dysphagie. Zweisprachig Deutsch & Türkisch."
  serviceTitle="Logopädie für Erwachsene"
  breadcrumbLabel="Therapie für Erwachsene"
  tags={['Aphasie', 'Dysarthrie', 'Stimmtherapie', 'Neurologie']}
  additionalSchemas={[schema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/therapie/erwachsene` },
    { lang: 'x-default', url: `${siteUrl}/therapie/erwachsene` },
  ]}
  relatedServices={[
    { title: 'Sprachstörungen', href: '/therapie/sprachstoerungen/', description: 'Aphasie, Wortfindung, Sprachverständnis' },
    { title: 'Schluckstörungen', href: '/therapie/schluckstoerungen/', description: 'Dysphagie-Therapie für Erwachsene und Senioren' },
    { title: 'Stimmtherapie', href: '/therapie/stimmtherapie/', description: 'Dysphonie, Heiserkeit, ISTP-Methode' },
  ]}
>
  <section class="bento-page" aria-label="Logopädie für Erwachsene in Duisburg">
    <div class="bento-grid">
      <article class="bento-card bento-card--image">
        <Image
          src={erwachseneImg}
          alt="Bildkarten für die logopädische Therapie mit Erwachsenen in der Praxis Şimşek Duisburg"
          class="bento-card__image"
          widths={[540, 900, 1200]}
          sizes="(max-width: 960px) 100vw, 55vw"
          loading="eager"
          decoding="async"
        />
        <div class="bento-card__overlay">
          <span class="bento-eyebrow">Erwachsenentherapie</span>
          <h2>Logopädie für Erwachsene – gezielt und kassenfinanziert</h2>
          <p>
            Sprach-, Sprech-, Stimm- und Schluckstörungen treffen Menschen in jedem
            Lebensalter – häufig als Folge neurologischer Erkrankungen, nach Operationen
            oder durch berufliche Überbelastung.
          </p>
        </div>
      </article>

      <article class="bento-card bento-card--highlight">
        <span class="bento-eyebrow">Überblick</span>
        <h2>Wann Logopädie für Erwachsene sinnvoll ist</h2>
        <ul>
          <li><strong>Nach Schlaganfall:</strong> Aphasie, Dysarthrie, Schluckstörungen</li>
          <li><strong>Neurologische Erkrankungen:</strong> Parkinson, Multiple Sklerose, ALS</li>
          <li><strong>Stimmprobleme:</strong> Dysphonie, Heiserkeit, Stimmerschöpfung</li>
          <li><strong>Stottern:</strong> auch im Erwachsenenalter effektiv behandelbar</li>
          <li><strong>Demenz:</strong> Erhalt der Alltagskommunikation und Angehörigenberatung</li>
          <li><strong>Nach Operationen:</strong> Hals, Kopf, Kehlkopf</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Aphasie</span>
        <h2>Sprachverlust nach Schlaganfall gezielt behandeln</h2>
        <p>
          Aphasie ist eine erworbene Sprachstörung – meist durch Schlaganfall, Hirnblutung,
          Tumor oder Schädel-Hirn-Trauma. Betroffen sind Sprechen, Verstehen, Lesen und Schreiben.
        </p>
        <p>
          Ziel der Therapie ist die Wiederherstellung sprachlicher Fähigkeiten oder die
          Entwicklung alltagstauglicher Kompensationsstrategien.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Dysarthrie & Apraxie</span>
        <h2>Neurologische Sprechstörungen verständlich machen</h2>
        <p>
          Dysarthrie entsteht durch Schädigung des Nervensystems und äußert sich in
          undeutlicher, verlangsamter oder monotoner Sprache. Ursachen sind Schlaganfall,
          Parkinson, MS und ALS.
        </p>
        <p>
          Bei der Sprechapraxie ist die motorische Planung gestört – trotz intakter
          Muskulatur sprechen Betroffene unflüssig oder machen inkonsistente Fehler.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Demenz</span>
        <h2>Kommunikation erhalten und Angehörige begleiten</h2>
        <p>
          Bei Demenzerkrankungen verschlechtert sich die Kommunikationsfähigkeit
          schrittweise. Logopädische Therapie zielt auf den Erhalt der Alltagskommunikation
          und unterstützt Angehörige mit konkreten Strategien.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Erster Termin</span>
        <h2>So läuft der erste logopädische Termin für Erwachsene ab</h2>
        <ul>
          <li>Ausführliche Anamnese zu Krankengeschichte, Beschwerden und Medikamenten</li>
          <li>Strukturierte Sprachdiagnostik mit standardisierten Tests je nach Störungsbild</li>
          <li>Befundbesprechung und gemeinsame Zieldefinition</li>
          <li>Erstellung eines individuellen Therapieplans</li>
          <li>Türkischsprachige Patienten erhalten die gesamte Diagnostik auf Türkisch</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Stottern</span>
        <h2>Stottern im Erwachsenenalter effektiv und ganzheitlich behandeln</h2>
        <p>
          Stottern ist nicht nur ein Kindheitsproblem. Moderne Therapiekonzepte verbinden
          Sprechtechnik, Kommunikationstraining und den Abbau von Vermeidungsverhalten.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Standort</span>
        <h2>Praxis in Duisburg-Mitte – barrierefrei erreichbar</h2>
        <p>
          Unsere Praxis liegt nur 2 Minuten vom Hauptbahnhof Duisburg entfernt. Aufzug
          vorhanden. Wir behandeln Patienten aus dem gesamten Stadtgebiet und dem Ruhrgebiet.
        </p>
      </article>

      <article class="bento-card bento-card--accent">
        <span class="bento-eyebrow">DE / TR</span>
        <h2>Vollständige Therapie auf Deutsch oder Türkisch – von der Anamnese bis zum Abschluss.</h2>
        <p>
          Türkischsprachige Erwachsene können unsere Therapie vollständig auf Türkisch
          in Anspruch nehmen.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Kostenübernahme</span>
        <h2>Logopädie für Erwachsene ist eine Kassenleistung</h2>
        <ul>
          <li>Gesetzliche Krankenkassen übernehmen die Kosten bei gültiger Heilmittelverordnung abzüglich der gesetzlichen Zuzahlung</li>
          <li>Bei privaten Versicherungen hängt die Erstattung vom jeweiligen Tarif ab</li>
          <li>Verordnende Fachärzte: Neurologen, HNO-Ärzte, Internisten, Allgemeinmediziner, Phoniatriker</li>
          <li>Erwachsene zahlen 10 % Zuzahlung plus 10 € Rezeptgebühr</li>
          <li>Details: <a href="/kostenuebernahme/">Kosten & Kostenübernahme</a></li>
        </ul>
      </article>

      <article class="bento-card bento-card--soft">
        <span class="bento-eyebrow">Stimme & Schlucken</span>
        <h2>Stimmtherapie und Dysphagietherapie auch mit Hausbesuchen</h2>
        <p>
          Berufssprecher und Personen nach Kehlkopfoperationen profitieren von gezielter
          Stimmtherapie. Schluckstörungen behandeln wir auch mit Hausbesuchen – für
          bettlägerige oder mobilitätseingeschränkte Patientinnen.
        </p>
      </article>
    </div>
  </section>
</ServicePage>

<style>
  .bento-page {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    grid-auto-flow: row dense;
  }

  .bento-card {
    grid-column: span 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(28, 25, 22, 0.06);
    min-height: 100%;
  }

  .bento-card--image {
    grid-column: span 6;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 22rem;
    border: 0;
  }

  .bento-card--highlight {
    grid-column: span 6;
    background: linear-gradient(180deg, rgba(112, 90, 74, 0.08), rgba(255, 255, 255, 0.96));
  }

  .bento-card--wide {
    grid-column: span 8;
  }

  .bento-card--accent {
    background: var(--color-primary);
    color: white;
  }

  .bento-card--soft {
    background: var(--color-primary-light);
  }

  .bento-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bento-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(24, 18, 14, 0.08) 10%,
      rgba(24, 18, 14, 0.76) 100%
    );
  }

  .bento-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .bento-card--image .bento-eyebrow,
  .bento-card--accent .bento-eyebrow {
    color: rgba(255, 255, 255, 0.84);
  }

  .bento-grid .bento-card :global(h2),
  .bento-grid .bento-card__overlay :global(h2) {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
    color: var(--color-text);
  }

  .bento-grid .bento-card__overlay :global(h2) {
    color: white;
    max-width: 20ch;
  }

  .bento-card__overlay :global(p),
  .bento-card__overlay :global(p strong),
  .bento-card__overlay :global(p a) {
    color: #ffffff !important;
  }

  .bento-grid .bento-card :global(p),
  .bento-grid .bento-card :global(ul),
  .bento-grid .bento-card__overlay :global(p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .bento-grid .bento-card__overlay :global(p) {
    max-width: 56ch;
  }

  .bento-grid .bento-card :global(ul) {
    display: grid;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .bento-grid .bento-card :global(li) {
    position: relative;
    padding-left: 1rem;
  }

  .bento-grid .bento-card :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .bento-grid .bento-card--accent :global(h2),
  .bento-grid .bento-card--accent :global(p),
  .bento-grid .bento-card--accent :global(a),
  .bento-grid .bento-card--accent .bento-eyebrow {
    color: white;
  }

  @media (max-width: 960px) {
    .bento-card,
    .bento-card--image,
    .bento-card--highlight,
    .bento-card--wide {
      grid-column: span 12;
    }

    .bento-card--image {
      min-height: 19rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      gap: 0.875rem;
    }

    .bento-card {
      padding: 1.2rem;
    }

    .bento-card--image {
      min-height: 0;
      padding: 1rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .bento-card__overlay {
      position: static;
      padding: 1rem 0 0;
      background: none;
    }

    .bento-card__image {
      height: 13.5rem;
      border-radius: 6px;
    }

    .bento-card--image .bento-eyebrow {
      color: var(--color-primary);
    }

    .bento-grid .bento-card__overlay :global(h2) {
      color: var(--color-text);
      max-width: none;
    }

    .bento-card__overlay :global(p),
    .bento-card__overlay :global(p strong),
    .bento-card__overlay :global(p a) {
      color: var(--color-text-muted) !important;
    }

    .bento-card__overlay :global(strong),
    .bento-card__overlay :global(a) {
      color: var(--color-text) !important;
    }
  }
</style>
