---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import therapyOverviewImg from '../../assets/therapy/therapy-overview-all-ages-logopaedie.png';

const services = [
  {
    title: 'Sprachstörungen',
    description: 'Sprachentwicklungsverzögerungen, Aphasie nach Schlaganfall, Frühförderung – für Kinder und Erwachsene.',
    tags: ['Sprachentwicklung', 'Aphasie', 'Frühförderung'],
    href: '/therapie/sprachstoerungen/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M7 8h10"/><path d="M7 12h6"/><path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'Sprechstörungen',
    description: 'Stottern, Poltern, Lispeln und motorisch bedingte Sprechstörungen wie Dysarthrie oder Sprechapraxie.',
    tags: ['Stottern', 'Lispeln', 'Dysarthrie'],
    href: '/therapie/sprechstoerungen/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 18v3"/><path d="M8 21h8"/><path d="M7 9a5 5 0 0 1 10 0v2a5 5 0 0 1-10 0z"/><path d="M4 10v1a8 8 0 0 0 16 0v-1"/><path d="M10 8h4"/></svg>`,
  },
  {
    title: 'Stimmtherapie',
    description: 'Funktionelle und organische Stimmstörungen – bei Heiserkeit, Dysphonie, nach Operationen oder bei Berufssprechern.',
    tags: ['Dysphonie', 'Heiserkeit', 'Stimmbildung'],
    href: '/therapie/stimmtherapie/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h2l2-5 4 10 3-8 2 3h5"/><path d="M4 18c3-2 6-2 9 0 2 1.3 4 1.3 7 0"/></svg>`,
  },
  {
    title: 'Schluckstörungen (Dysphagie)',
    description: 'Diagnostik und Therapie von Dysphagie bei Erwachsenen und Kindern – nach Schlaganfall, bei Parkinson oder anderen neurologischen Erkrankungen.',
    tags: ['Dysphagie', 'Schlucken', 'Neurologisch'],
    href: '/therapie/schluckstoerungen/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3c4 2 6 5 6 9a6 6 0 0 1-6 6"/><path d="M16 3c-2 2-3 5-3 8 0 5 3 8 7 10"/><path d="M6 21h5"/><path d="M7 14c1.5.8 3 .8 4 0"/></svg>`,
  },
  {
    title: 'Frühförderung Duisburg',
    description: 'Logopädische Früherkennung und Therapie für Kleinkinder und Vorschulkinder ab dem Säuglingsalter – spielbasiert und elternzentriert.',
    tags: ['Kleinkinder', '0–6 Jahre', 'Frühförderung'],
    href: '/fruehfoerderung-duisburg/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="3"/><path d="M4 21v-2a4 4 0 0 1 8 0v2"/><path d="M15 5h4v4"/><path d="M19 5 13 11"/><path d="M16 14h4v4h-4z"/></svg>`,
  },
  {
    title: 'Hausbesuche Duisburg',
    description: 'Logopädie bei Ihnen zu Hause – für mobilitätseingeschränkte Patienten, Senioren und Pflegebedürftige. Therapie im vertrauten Lebensumfeld.',
    tags: ['Hausbesuche', 'Senioren', 'Neurologisch'],
    href: '/hausbesuche-duisburg/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/><path d="M9 21v-6h6v6"/><path d="M16 4h3v4"/></svg>`,
  },
];
---

<Layout
  title="Therapie | Praxis für Logopädie Şimşek Duisburg"
  description="Das Therapieangebot der Praxis für Logopädie Şimşek in Duisburg: Sprachstörungen, Sprechstörungen, Stimmtherapie und Dysphagie – für Kinder und Erwachsene."
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/therapie/' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/terapi/' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/therapie/' },
  ]}
>
  <Header alternateUrl="/terapi/" />
  <Nav alternateUrl="/terapi/" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">
    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3 max-[640px]:py-2.5">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Therapie</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-12 max-[640px]:pt-9 pb-9 max-[640px]:pb-7 border-b border-border">
      <div class="container">
        <span class="text-xs font-semibold tracking-widest uppercase text-primary">Leistungsangebot</span>
        <h1 class="font-display text-[clamp(1.85rem,5vw,3rem)] max-[640px]:text-[clamp(1.55rem,8vw,2.1rem)] font-semibold leading-[1.1] text-text mt-3 mb-4">Unser Therapieangebot in Duisburg</h1>
        <p class="text-[1.0625rem] max-[640px]:text-[0.97rem] text-text-muted leading-[1.7] max-[640px]:leading-[1.65] max-w-2xl">
          In unserer Praxis in Duisburg behandeln wir ein breites Spektrum logopädischer Störungsbilder –
          für Kinder, Erwachsene und Senioren. Auf Deutsch und Türkisch.
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-12 max-[640px]:py-9 bg-bg">
      <div class="container">
        <div class="mb-7 max-[640px]:mb-5 w-full overflow-hidden rounded-md border border-border bg-surface shadow-sm h-72 max-[640px]:h-48">
          <Image
            src={therapyOverviewImg}
            alt="Logopädische Therapie für Kinder, Erwachsene und Senioren in der Praxis für Logopädie Şimşek Duisburg"
            class="h-full w-full object-cover object-center opacity-95"
            widths={[900, 1400, 1819]}
            sizes="(max-width: 640px) 100vw, 72rem"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="bento-page-grid">
          {services.map(service => (
            <a
              href={service.href}
              class="bento-tile bento-tile--half relative hover:border-primary hover:-translate-y-1 hover:shadow-md transition-[transform,box-shadow,border-color] duration-200 flex flex-col gap-4 max-[640px]:gap-3 no-underline group"
            >
              <div class="w-14 h-14 max-[640px]:w-11 max-[640px]:h-11 rounded-sm bg-primary-light flex items-center justify-center text-primary" aria-hidden="true" set:html={service.icon} />
              <div>
                <h2 class="font-display text-xl max-[640px]:text-[1.3rem] font-semibold text-text group-hover:text-primary transition-colors mb-2">{service.title}</h2>
                <p class="text-[.9375rem] max-[640px]:text-[0.9rem] text-text-muted leading-[1.65] max-[640px]:leading-[1.6]">{service.description}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                {service.tags.map(tag => (
                  <span class="bg-primary-light text-primary-dark text-xs font-semibold px-2.5 py-1 rounded-full max-[640px]:text-[0.7rem] max-[640px]:px-2 max-[640px]:py-0.5">{tag}</span>
                ))}
              </div>
              <span class="absolute top-6 right-6 max-[640px]:top-5 max-[640px]:right-5 inline-flex h-9 w-9 items-center justify-center rounded-full bg-primary-light text-primary transition-colors group-hover:bg-primary group-hover:text-white" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- USP Strip -->
    <section class="py-12 max-[640px]:py-10 bg-primary" aria-label="Unser Alleinstellungsmerkmal">
      <div class="container text-center flex flex-col items-center gap-5">
        <h2 class="font-display text-[clamp(1.4rem,3vw,2rem)] max-[640px]:text-[clamp(1.3rem,7vw,1.75rem)] font-semibold text-white">Zweisprachige Therapie auf Deutsch und Türkisch</h2>
        <p class="text-white/80 text-[1.0625rem] max-[640px]:text-[0.97rem] leading-[1.7] max-w-xl">
          Ein seltenes Angebot im Ruhrgebiet – besonders wertvoll für mehrsprachig aufwachsende Kinder
          und türkischsprachige Erwachsene. Wir schließen eine wichtige Versorgungslücke.
        </p>
        <a href="/kontakt/" class="btn btn-outline-white max-[640px]:max-w-[20rem]">Termin anfragen</a>
      </div>
    </section>

    <!-- Back link -->
    <div class="container py-9 max-[640px]:py-7">
      <div class="bento-page-grid">
        <div class="bento-tile bento-tile--full bento-tile--soft">
          <a href="/" class="inline-flex items-center gap-2 text-primary font-medium hover:underline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            Zurück zur Startseite
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
