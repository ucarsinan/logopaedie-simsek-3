---
import ServicePage from '../../layouts/ServicePage.astro';
import { Image } from 'astro:assets';
import schluckImg from '../../assets/therapy/schlucktherapie-dysphagie-duisburg.webp';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Dysphagie-Therapie: Schluckstörungen behandeln in Duisburg",
  "description": "Professionelle Diagnostik und Therapie von Schluckstörungen (Dysphagie) in Duisburg – für Erwachsene und Kinder nach Schlaganfall, bei Parkinson oder neurologischen Erkrankungen.",
  "url": "https://logopaedie-simsek.de/therapie/schluckstoerungen/",
  "about": { "@type": "MedicalCondition", "name": "Dysphagie" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://logopaedie-simsek.de/" },
      { "@type": "ListItem", "position": 2, "name": "Therapieangebot", "item": "https://logopaedie-simsek.de/therapie/" },
      { "@type": "ListItem", "position": 3, "name": "Schluckstörungen", "item": "https://logopaedie-simsek.de/therapie/schluckstoerungen/" }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wann sollte ich bei Schluckproblemen einen Logopäden aufsuchen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Eine logopädische Abklärung ist sinnvoll, wenn Sie häufig beim Essen oder Trinken husten, das Gefühl haben, dass Speisen im Hals stecken bleiben, eine nasse oder gurgelnde Stimme nach dem Essen bemerken, ungewollt abnehmen oder häufige Atemwegsinfekte auftreten. Schluckstörungen sollten zeitnah behandelt werden, da stille Aspiration ohne Therapie zu ernsthaften Folgeerkrankungen führen kann."
      }
    },
    {
      "@type": "Question",
      "name": "Übernimmt die Krankenkasse die Kosten für Schlucktherapie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dysphagietherapie ist ein anerkanntes Heilmittel und wird bei gültiger ärztlicher Verordnung von gesetzlichen Krankenkassen abzüglich der gesetzlichen Zuzahlung übernommen. Auch Haus- oder Pflegeheimbesuche können verordnet und abgerechnet werden, wenn sie medizinisch notwendig sind."
      }
    },
    {
      "@type": "Question",
      "name": "Kann Schlucktherapie auch bei Kindern durchgeführt werden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, Schlucktherapie ist auch für Kinder geeignet – von Frühgeborenen mit Saugstörungen bis zu Schulkindern. Häufige Indikationen bei Kindern sind orofaziale Fehlfunktionen, oromotorische Schwächen oder Schluckstörungen im Rahmen neurologischer Erkrankungen."
      }
    },
    {
      "@type": "Question",
      "name": "Bieten Sie Hausbesuche für Schlucktherapie an?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, wir bieten Hausbesuche für Patientinnen und Patienten an, die nicht oder nur eingeschränkt mobil sind – zum Beispiel nach einem Schlaganfall oder bei fortgeschrittener Demenz. Hausbesuche für Dysphagietherapie können ärztlich verordnet und bei medizinischer Notwendigkeit von gesetzlichen Krankenkassen übernommen werden."
      }
    }
  ]
};
---

<ServicePage
  title="Dysphagie Therapie | Schluckstörungen | Praxis für Logopädie Şimşek Duisburg"
  description="Professionelle Diagnostik und Therapie von Schluckstörungen (Dysphagie) in Duisburg – für Erwachsene und Kinder nach Schlaganfall, bei Parkinson oder neurologischen Erkrankungen."
  serviceTitle="Schluckstörungen (Dysphagie): Sicher schlucken lernen"
  breadcrumbLabel="Schluckstörungen"
  tags={['Dysphagie', 'Schlucken', 'Neurologie', 'Rehabilitation']}
  additionalSchemas={[schema, faqSchema]}
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/therapie/schluckstoerungen/' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/terapi/yutma-bozuklugu/' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/therapie/schluckstoerungen/' },
  ]}
  alternateUrl="/terapi/yutma-bozuklugu"
  relatedServices={[
    { title: 'Sprachstörungen', href: '/therapie/sprachstoerungen/', description: 'Sprachentwicklungsverzögerung, Aphasie, Frühförderung' },
    { title: 'Sprechstörungen', href: '/therapie/sprechstoerungen/', description: 'Stottern, Lispeln, Dysarthrie und Sprechapraxie' },
    { title: 'Stimmtherapie', href: '/therapie/stimmtherapie/', description: 'Heiserkeit, Dysphonie, funktionelle Stimmstörungen' },
  ]}
>
  <section class="bento-page" aria-label="Schluckstörungen Dysphagie in Duisburg">
    <div class="bento-grid">
      <article class="bento-card bento-card--image">
        <Image
          src={schluckImg}
          alt="Therapiematerialien für Schlucktherapie (Dysphagie) in der Praxis für Logopädie Şimşek Duisburg"
          class="bento-card__image"
          widths={[540, 900, 1200]}
          sizes="(max-width: 960px) 100vw, 55vw"
          loading="eager"
          decoding="async"
        />
        <div class="bento-card__overlay">
          <span class="bento-eyebrow">Dysphagie-Therapie</span>
          <h2>Sicher schlucken – sicher essen und trinken</h2>
          <p>
            Schluckstörungen können die Lebensqualität erheblich verringern. Im
            schlimmsten Fall droht stille Aspiration. Früherkennung, ärztliche Abklärung
            und logopädische Behandlung können helfen, Risiken zu senken und Essen,
            Trinken und Lebensqualität sicherer zu gestalten.
          </p>
        </div>
      </article>

      <article class="bento-card bento-card--highlight">
        <span class="bento-eyebrow">Warnsignale</span>
        <h2>Typische Anzeichen einer Schluckstörung</h2>
        <ul>
          <li><strong>Husten:</strong> häufig beim Essen und Trinken oder direkt danach</li>
          <li><strong>Fremdkörpergefühl:</strong> Speisen scheinen im Hals stecken zu bleiben</li>
          <li><strong>Gurgelnde Stimme:</strong> nass oder gurgelnd klingend nach dem Schlucken</li>
          <li><strong>Gewichtsverlust:</strong> ungewollt durch erschwerte oder vermiedene Nahrungsaufnahme</li>
          <li><strong>Atemwegsinfekte:</strong> wiederholt, möglicherweise im Zusammenhang mit Aspiration</li>
          <li><strong>Verlängerte Essenszeiten:</strong> oder Vermeidung bestimmter Konsistenzen</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Ursachen</span>
        <h2>Häufige Ursachen von Schluckstörungen</h2>
        <ul>
          <li><strong>Schlaganfall:</strong> eine der häufigsten Ursachen, oft kombiniert mit Aphasie</li>
          <li><strong>Parkinson:</strong> fortschreitende Verschlechterung der Schluckfunktion</li>
          <li><strong>MS / ALS:</strong> neurologisch bedingte Schluckschwäche</li>
          <li><strong>Demenz:</strong> im fortgeschrittenen Stadium</li>
          <li><strong>Kopf-Hals-Tumoren:</strong> und deren Behandlung (OP, Bestrahlung)</li>
          <li><strong>Frühgeborene:</strong> Saugstörungen und orale Hypersensitivität</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Diagnostik</span>
        <h2>Gründliche Schluckdiagnostik als Basis jeder Therapie</h2>
        <p>
          Wir erheben eine ausführliche Anamnese, führen eine klinische
          Schluckuntersuchung durch und beobachten unter anderem Stimmklang, Husten,
          Atemkoordination und Ess- beziehungsweise Trinkverhalten.
        </p>
        <p>
          Bei Bedarf empfehlen wir weiterführende instrumentelle Diagnostik
          (z. B. FEES/Videoendoskopie oder Videofluoroskopie) und stimmen uns mit
          behandelnden Ärztinnen und Ärzten ab.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Kinder</span>
        <h2>Schlucktherapie auch für Kinder und Frühgeborene</h2>
        <p>
          Schlucktherapie ist ab dem Säuglingsalter möglich. Häufige Indikationen
          bei Kindern sind orofaziale Fehlfunktionen, oromotorische Schwächen und
          Schluckstörungen im Rahmen neurologischer Erkrankungen.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Therapiemethoden</span>
        <h2>Unser Therapieansatz für sicheres und effizientes Schlucken</h2>
        <ul>
          <li><strong>Kräftigung:</strong> Gezieltes Training der am Schlucken beteiligten Muskulatur</li>
          <li><strong>Schlucktechniken:</strong> Kompensatorische Strategien (Chin-Tuck, Supraglottisches Schlucken)</li>
          <li><strong>Haltungsadaptation:</strong> Optimale Positionierung beim Essen und Trinken</li>
          <li><strong>Kostadaptation:</strong> Anpassung von Speisen- und Getränkekonsistenz</li>
          <li><strong>Atemschutz:</strong> Husten- und Räuspermanagement zur Sicherheit</li>
          <li><strong>Beratung:</strong> Einbindung von Angehörigen und Pflegepersonal</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Hausbesuche</span>
        <h2>Therapie zuhause für mobilitätseingeschränkte Patienten</h2>
        <p>
          Wir bieten Hausbesuche für Patientinnen und Patienten an, die nicht oder
          nur eingeschränkt mobil sind – zum Beispiel nach einem Schlaganfall oder
          bei fortgeschrittener Demenz.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Wichtig</span>
        <h2>Früh handeln bei Verdacht auf Schluckstörung</h2>
        <p>
          Schluckstörungen werden oft unterschätzt oder zu spät erkannt. Bei Verdacht
          auf Dysphagie empfehlen wir eine zeitnahe logopädische Diagnostik – stille
          Aspiration ohne Therapie kann zu ernsthaften Folgeerkrankungen führen.
        </p>
      </article>

      <article class="bento-card bento-card--accent">
        <span class="bento-eyebrow">Kassenleistung</span>
        <h2>Dysphagietherapie ist bei Verordnung eine Kassenleistung.</h2>
        <p>
          Dysphagietherapie ist ein anerkanntes Heilmittel bei ärztlicher Verordnung.
          Auch Hausbesuche können bei medizinischer Notwendigkeit verordnet und abgerechnet werden.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Netzwerk Duisburg</span>
        <h2>Wir arbeiten mit Pflegeeinrichtungen und Krankenhäusern zusammen</h2>
        <ul>
          <li>Enge Kooperation mit niedergelassenen Ärzten und Fachkliniken in Duisburg</li>
          <li>Abstimmung mit HNO-Facharzt und Gastroenterologen für weiterführende Diagnostik</li>
          <li>Regelmäßiger Austausch mit Pflegeeinrichtungen und Sozialstationen</li>
          <li>Koordination von Hausbesuchen für schwer mobile Patientinnen und Patienten</li>
        </ul>
      </article>

      <article class="bento-card bento-card--soft">
        <span class="bento-eyebrow">Therapieablauf</span>
        <h2>Individuelle Therapie mit regelmäßiger Verlaufskontrolle</h2>
        <p>
          Nach der Diagnostik folgt ein individuell abgestimmter Therapieplan mit
          regelmäßiger Überprüfung der Fortschritte. Bei Bedarf passen wir Ziele
          und Methoden kontinuierlich an.
        </p>
      </article>
    </div>
  </section>
</ServicePage>

<style>
  .bento-page {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    grid-auto-flow: row dense;
  }

  .bento-card {
    grid-column: span 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(28, 25, 22, 0.06);
    min-height: 100%;
  }

  .bento-card--image {
    grid-column: span 6;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 22rem;
    border: 0;
  }

  .bento-card--highlight {
    grid-column: span 6;
    background: linear-gradient(180deg, rgba(112, 90, 74, 0.08), rgba(255, 255, 255, 0.96));
  }

  .bento-card--wide {
    grid-column: span 8;
  }

  .bento-card--accent {
    background: var(--color-primary);
    color: white;
  }

  .bento-card--soft {
    background: var(--color-primary-light);
  }

  .bento-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bento-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(24, 18, 14, 0.08) 10%,
      rgba(24, 18, 14, 0.76) 100%
    );
  }

  .bento-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .bento-card--image .bento-eyebrow,
  .bento-card--accent .bento-eyebrow {
    color: rgba(255, 255, 255, 0.84);
  }

  .bento-grid .bento-card :global(h2),
  .bento-grid .bento-card__overlay :global(h2) {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
    color: var(--color-text);
  }

  .bento-grid .bento-card__overlay :global(h2) {
    color: white;
    max-width: 20ch;
  }

  .bento-card__overlay :global(p),
  .bento-card__overlay :global(p strong),
  .bento-card__overlay :global(p a) {
    color: #ffffff !important;
  }

  .bento-grid .bento-card :global(p),
  .bento-grid .bento-card :global(ul),
  .bento-grid .bento-card__overlay :global(p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .bento-grid .bento-card__overlay :global(p) {
    max-width: 56ch;
  }

  .bento-grid .bento-card :global(ul) {
    display: grid;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .bento-grid .bento-card :global(li) {
    position: relative;
    padding-left: 1rem;
  }

  .bento-grid .bento-card :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .bento-grid .bento-card--accent :global(h2),
  .bento-grid .bento-card--accent :global(p),
  .bento-grid .bento-card--accent :global(a),
  .bento-grid .bento-card--accent .bento-eyebrow {
    color: white;
  }

  @media (max-width: 960px) {
    .bento-card,
    .bento-card--image,
    .bento-card--highlight,
    .bento-card--wide {
      grid-column: span 12;
    }

    .bento-card--image {
      min-height: 19rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      gap: 0.875rem;
    }

    .bento-card {
      padding: 1.2rem;
    }

    .bento-card--image {
      min-height: 0;
      padding: 1rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .bento-card__overlay {
      position: static;
      padding: 1rem 0 0;
      background: none;
    }

    .bento-card__image {
      height: 13.5rem;
      border-radius: 6px;
    }

    .bento-card--image .bento-eyebrow {
      color: var(--color-primary);
    }

    .bento-grid .bento-card__overlay :global(h2) {
      color: var(--color-text);
      max-width: none;
    }

    .bento-card__overlay :global(p),
    .bento-card__overlay :global(p strong),
    .bento-card__overlay :global(p a) {
      color: var(--color-text-muted) !important;
    }

    .bento-card__overlay :global(strong),
    .bento-card__overlay :global(a) {
      color: var(--color-text) !important;
    }
  }
</style>
