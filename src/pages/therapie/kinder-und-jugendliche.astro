---
import ServicePage from '../../layouts/ServicePage.astro';
import { Image } from 'astro:assets';
import kinderImg from '../../assets/therapy/fruehfoerderung-logopaedie-kind-duisburg.webp';

const siteUrl = 'https://logopaedie-simsek.de';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Logopädie für Kinder und Jugendliche Duisburg",
  "description": "Logopädische Therapie für Kinder und Jugendliche in Duisburg. Sprachentwicklungsverzögerung, Stottern, LRS, Aussprache und mehr.",
  "url": `${siteUrl}/therapie/kinder-und-jugendliche`,
  "about": { "@type": "MedicalCondition", "name": "Sprachentwicklungsstörung" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Therapieangebot", "item": `${siteUrl}/therapie` },
      { "@type": "ListItem", "position": 3, "name": "Kinder und Jugendliche", "item": `${siteUrl}/therapie/kinder-und-jugendliche` }
    ]
  }
};
---

<ServicePage
  title="Logopädie für Kinder und Jugendliche Duisburg | Praxis für Logopädie Şimşek"
  description="Logopädische Therapie für Kinder und Jugendliche in Duisburg – Sprachentwicklungsverzögerung, Stottern, LRS, Aussprache, auditive Verarbeitung. Zweisprachig DE/TR."
  serviceTitle="Logopädie für Kinder und Jugendliche"
  breadcrumbLabel="Kinder und Jugendliche"
  tags={['Frühförderung', 'Sprachentwicklung', 'Stottern', 'LRS']}
  additionalSchemas={[schema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/therapie/kinder-und-jugendliche` },
    { lang: 'x-default', url: `${siteUrl}/therapie/kinder-und-jugendliche` },
  ]}
  relatedServices={[
    { title: 'Sprachstörungen', href: '/therapie/sprachstoerungen/', description: 'Sprachentwicklungsverzögerung, Aphasie, Grammatik' },
    { title: 'Sprechstörungen', href: '/therapie/sprechstoerungen/', description: 'Stottern, Lispeln, Ausspracheprobleme' },
    { title: 'Logopädie für Erwachsene', href: '/therapie/erwachsene/', description: 'Aphasie, Dysarthrie, Stimmstörungen' },
  ]}
>
  <section class="bento-page" aria-label="Logopädie für Kinder und Jugendliche in Duisburg">
    <div class="bento-grid">
      <article class="bento-card bento-card--image">
        <Image
          src={kinderImg}
          alt="Spielerische Logopädie für Kinder und Jugendliche in der Praxis für Logopädie Şimşek Duisburg"
          class="bento-card__image"
          widths={[540, 900, 1200]}
          sizes="(max-width: 960px) 100vw, 55vw"
          loading="eager"
          decoding="async"
        />
        <div class="bento-card__overlay">
          <span class="bento-eyebrow">Kindertherapie</span>
          <h2>Spielerisch, präzise und auf den Entwicklungsstand abgestimmt</h2>
          <p>
            Eine frühe Abklärung hilft, Förderbedarf rechtzeitig zu erkennen und passende
            Unterstützung einzuleiten. Logopädische Therapie ist je nach Indikation ab dem
            Säuglingsalter möglich.
          </p>
        </div>
      </article>

      <article class="bento-card bento-card--highlight">
        <span class="bento-eyebrow">Sprachliche Meilensteine</span>
        <h2>Orientierungsrahmen für eine altersgerechte Sprachentwicklung</h2>
        <ul>
          <li><strong>12 Monate:</strong> erste Wörter oder lautliche Annäherungen, versteht einfache Wörter</li>
          <li><strong>18 Monate:</strong> wachsender aktiver Wortschatz, erste Benennungen im Alltag</li>
          <li><strong>2 Jahre:</strong> deutlicher Wortschatzaufbau, erste Zwei-Wort-Verbindungen</li>
          <li><strong>3 Jahre:</strong> kurze Sätze, für Bezugspersonen meist verständlich</li>
          <li><strong>4 Jahre:</strong> längere Sätze, Fragen stellen, deutlich wachsender Wortschatz</li>
          <li><strong>5–6 Jahre:</strong> überwiegend verständliche Aussprache, Reimen, Silbentrennen</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Störungsbilder</span>
        <h2>Häufige Störungsbilder bei Kindern und Jugendlichen</h2>
        <ul>
          <li><strong>Sprachentwicklungsauffälligkeiten:</strong> Wortschatz, Grammatik, Sprachverständnis oder Sprachgebrauch</li>
          <li><strong>Aussprachestörungen:</strong> Sigmatismus/Lispeln und andere Lautbildungsprobleme</li>
          <li><strong>Stottern:</strong> Redeflussstörung mit Wiederholungen, Dehnungen oder Blockierungen</li>
          <li><strong>LRS-nahe Schwierigkeiten:</strong> phonologische Bewusstheit und Laut-Buchstaben-Wissen</li>
          <li><strong>AVWS:</strong> auditive Verarbeitungs- und Wahrnehmungsstörungen</li>
          <li><strong>Poltern:</strong> überhastetes Sprechen mit mangelnder Selbstwahrnehmung</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Warnsignale</span>
        <h2>Wann eine logopädische Abklärung sinnvoll ist</h2>
        <ul>
          <li>Das Kind spricht deutlich weniger als Gleichaltrige</li>
          <li>Die Aussprache ist auch mit 4–5 Jahren noch schwer verständlich</li>
          <li>Das Kind stottert oder klingt unflüssig</li>
          <li>Es hat Schwierigkeiten, Anweisungen zu verstehen</li>
          <li>Es weigert sich zu sprechen oder wirkt sozial gehemmt</li>
          <li>Probleme beim Lesen- und Schreibenlernen</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Mehrsprachigkeit</span>
        <h2>Deutsch und Türkisch präzise einschätzen</h2>
        <p>
          Bei mehrsprachigen Kindern führen wir die Diagnostik in <strong>beiden Sprachen</strong>
          durch. So unterscheiden wir mehrsprachigkeitstypische Erwerbsphänomene von
          Hinweisen auf eine tatsächliche Sprachentwicklungsstörung.
        </p>
        <p>
          Mehrsprachigkeit ist eine Ressource, keine Störung.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Unser Therapieansatz</span>
        <h2>Spielbasiert, alltagsnah und mit Eltern als aktiven Partnern</h2>
        <ul>
          <li><strong>Eltern als Partner:</strong> Regelmäßige Elterngespräche mit konkreten Übungsideen für zuhause</li>
          <li><strong>Spielbasiertes Lernen:</strong> Therapieintegriertes Spiel – das Kind erlebt es nicht als „Üben"</li>
          <li><strong>Schulkinder & Jugendliche:</strong> altersgerechte Methoden, die zum Entwicklungsstand passen</li>
          <li><strong>Transparenz:</strong> Eltern erhalten nach jeder Therapiephase einen Befundbericht</li>
          <li><strong>Frühförderung:</strong> vor dem Schuleintritt häufig sinnvoll, weil sprachliche Grundlagen früh aufgebaut werden</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Erster Termin</span>
        <h2>Anamnese, Diagnostik und individueller Therapieplan</h2>
        <p>
          Beim Erstgespräch fragen wir nach Sprachentwicklung, Familie und schulischem Umfeld.
          Darauf folgt eine altersgerechte Diagnostik mit standardisierten Tests und
          Sprachbeobachtung im Spiel.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">LRS & Stottern</span>
        <h2>Spezialgebiete mit besonderer Erfahrung in unserer Praxis</h2>
        <p>
          Stottern ist nicht selbstverschuldet – eine frühe Abklärung und passende Therapie
          können den Verlauf günstig beeinflussen und Belastung reduzieren. Bei LRS trainieren
          wir phonologische Bewusstheit und arbeiten eng mit Schule und Eltern zusammen.
        </p>
      </article>

      <article class="bento-card bento-card--accent">
        <span class="bento-eyebrow">Kostenfrei</span>
        <h2>Kinder und Jugendliche unter 18 sind von Zuzahlungen befreit.</h2>
        <p>
          Kinderärzte, HNO-Ärzte, Kinderpsychiater und andere Fachärzte können
          eine Heilmittelverordnung ausstellen.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Verordnung</span>
        <h2>Wer Logopädie für Kinder verordnen kann</h2>
        <ul>
          <li>Kinderärzte und Allgemeinmediziner</li>
          <li>HNO-Ärzte und Phoniatriker</li>
          <li>Kinderpsychiater und Neuropädiater</li>
          <li>Für den ersten Termin wird eine Heilmittelverordnung vom Arzt benötigt</li>
        </ul>
      </article>

      <article class="bento-card bento-card--soft">
        <span class="bento-eyebrow">DE / TR</span>
        <h2>Beratung und Therapie auch vollständig auf Türkisch</h2>
        <p>
          Türkischsprachige Familien erhalten Elterngespräche und Beratung vollständig auf
          Türkisch – von der Erstdiagnostik bis zum Therapieabschluss.
        </p>
      </article>
    </div>
  </section>
</ServicePage>

<style>
  .bento-page {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    grid-auto-flow: row dense;
  }

  .bento-card {
    grid-column: span 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(28, 25, 22, 0.06);
    min-height: 100%;
  }

  .bento-card--image {
    grid-column: span 6;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 22rem;
    border: 0;
  }

  .bento-card--highlight {
    grid-column: span 6;
    background: linear-gradient(180deg, rgba(112, 90, 74, 0.08), rgba(255, 255, 255, 0.96));
  }

  .bento-card--wide {
    grid-column: span 8;
  }

  .bento-card--accent {
    background: var(--color-primary);
    color: white;
  }

  .bento-card--soft {
    background: var(--color-primary-light);
  }

  .bento-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bento-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(24, 18, 14, 0.08) 10%,
      rgba(24, 18, 14, 0.76) 100%
    );
  }

  .bento-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .bento-card--image .bento-eyebrow,
  .bento-card--accent .bento-eyebrow {
    color: rgba(255, 255, 255, 0.84);
  }

  .bento-grid .bento-card :global(h2),
  .bento-grid .bento-card__overlay :global(h2) {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
    color: var(--color-text);
  }

  .bento-grid .bento-card__overlay :global(h2) {
    color: white;
    max-width: 20ch;
  }

  .bento-card__overlay :global(p),
  .bento-card__overlay :global(p strong),
  .bento-card__overlay :global(p a) {
    color: #ffffff !important;
  }

  .bento-grid .bento-card :global(p),
  .bento-grid .bento-card :global(ul),
  .bento-grid .bento-card__overlay :global(p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .bento-grid .bento-card__overlay :global(p) {
    max-width: 56ch;
  }

  .bento-grid .bento-card :global(ul) {
    display: grid;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .bento-grid .bento-card :global(li) {
    position: relative;
    padding-left: 1rem;
  }

  .bento-grid .bento-card :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .bento-grid .bento-card--accent :global(h2),
  .bento-grid .bento-card--accent :global(p),
  .bento-grid .bento-card--accent :global(a),
  .bento-grid .bento-card--accent .bento-eyebrow {
    color: white;
  }

  @media (max-width: 960px) {
    .bento-card,
    .bento-card--image,
    .bento-card--highlight,
    .bento-card--wide {
      grid-column: span 12;
    }

    .bento-card--image {
      min-height: 19rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      gap: 0.875rem;
    }

    .bento-card {
      padding: 1.2rem;
    }

    .bento-card--image {
      min-height: 0;
      padding: 1rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .bento-card__overlay {
      position: static;
      padding: 1rem 0 0;
      background: none;
    }

    .bento-card__image {
      height: 13.5rem;
      border-radius: 6px;
    }

    .bento-card--image .bento-eyebrow {
      color: var(--color-primary);
    }

    .bento-grid .bento-card__overlay :global(h2) {
      color: var(--color-text);
      max-width: none;
    }

    .bento-card__overlay :global(p),
    .bento-card__overlay :global(p strong),
    .bento-card__overlay :global(p a) {
      color: var(--color-text-muted) !important;
    }

    .bento-card__overlay :global(strong),
    .bento-card__overlay :global(a) {
      color: var(--color-text) !important;
    }
  }
</style>
