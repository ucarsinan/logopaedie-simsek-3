---
import ServicePage from '../../layouts/ServicePage.astro';
import { Image } from 'astro:assets';
import stimmImg from '../../assets/therapy/stimmtherapie-bildkarten-duisburg.webp';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was sind Sprechstörungen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sprechstörungen betreffen die motorische Ausführung des Sprechens – also wie Laute, Silben und Wörter produziert werden. Im Gegensatz zu Sprachstörungen ist die zugrunde liegende Sprachkompetenz (Wortschatz, Grammatik) dabei häufig intakt." }
    },
    {
      "@type": "Question",
      "name": "Ab wann ist Stottern beim Kind behandlungsbedürftig?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ein leichtes Stottern im Alter von 2–4 Jahren ist häufig normal. Wenn Ihr Kind jedoch mehr als 3 Monate lang stottert, sichtbaren Leidensdruck zeigt oder Vermeidungsverhalten entwickelt, empfehlen wir eine logopädische Abklärung. Bei frühem Therapiebeginn sind die Erfolgschancen besonders gut." }
    },
    {
      "@type": "Question",
      "name": "Was ist der Unterschied zwischen Stottern und Poltern?",
      "acceptedAnswer": { "@type": "Answer", "text": "Beim Stottern kommt es zu Wiederholungen, Dehnungen und Blockierungen beim Sprechen, oft begleitet von Leidensdruck. Poltern (Cluttering) ist überhastetes, unrhythmisches Sprechen mit undeutlicher Artikulation – Betroffene nehmen ihr eigenes Sprechen oft kaum als auffällig wahr." }
    },
    {
      "@type": "Question",
      "name": "Wie wird Dysarthrie nach einem Schlaganfall behandelt?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die Dysarthrietherapie verbessert die Verständlichkeit durch gezielte Übungen der Sprechmuskulatur, Atemsteuerung und Artikulationsdeutlichkeit. Ziele sind bessere Artikulation, optimierte Stimmgebung und Prosodie sowie Kompensationsstrategien. Bei schwerer Ausprägung werden auch Kommunikationshilfen eingesetzt." }
    },
    {
      "@type": "Question",
      "name": "Was ist Lispeln und kann es behandelt werden?",
      "acceptedAnswer": { "@type": "Answer", "text": "Lispeln (Sigmatismus) ist eine fehlerhafte Aussprache der S-Laute, zum Beispiel mit der Zunge zwischen den Zähnen (interdental) oder seitlich (lateral). Es ist sehr gut therapierbar: Mit spielerischen, altersgerechten Übungen und gezieltem Artikulationstraining lässt sich eine klare Aussprache entwickeln." }
    }
  ]
};

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Sprechstörungen behandeln: Stottern, Lispeln, Dysarthrie in Duisburg",
  "description": "Logopädische Therapie bei Stottern, Poltern, Lispeln und Dysarthrie in Duisburg. Professionelle Behandlung für Kinder und Erwachsene.",
  "url": "https://logopaedie-simsek.de/therapie/sprechstoerungen",
  "about": { "@type": "MedicalCondition", "name": "Sprechstörung" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://logopaedie-simsek.de" },
      { "@type": "ListItem", "position": 2, "name": "Therapieangebot", "item": "https://logopaedie-simsek.de/therapie" },
      { "@type": "ListItem", "position": 3, "name": "Sprechstörungen", "item": "https://logopaedie-simsek.de/therapie/sprechstoerungen" }
    ]
  }
};
---

<ServicePage
  title="Sprechstörungen: Stottern, Lispeln, Dysarthrie | Praxis für Logopädie Şimşek Duisburg"
  description="Therapie bei Stottern, Poltern, Lispeln und Dysarthrie in Duisburg. Professionelle Behandlung von Sprechstörungen für Kinder und Erwachsene. Zweisprachig DE/TR."
  serviceTitle="Sprechstörungen: Stottern, Lispeln & mehr"
  breadcrumbLabel="Sprechstörungen"
  tags={['Stottern', 'Lispeln', 'Dysarthrie', 'Sprechapraxie']}
  additionalSchemas={[schema, faqSchema]}
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/therapie/sprechstoerungen/' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/terapi/konusma-bozuklugu/' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/therapie/sprechstoerungen/' },
  ]}
  alternateUrl="/terapi/konusma-bozuklugu"
  relatedServices={[
    { title: 'Sprachstörungen', href: '/therapie/sprachstoerungen/', description: 'Sprachentwicklungsverzögerung, Aphasie, Frühförderung' },
    { title: 'Stimmtherapie', href: '/therapie/stimmtherapie/', description: 'Heiserkeit, Dysphonie, funktionelle Stimmstörungen' },
    { title: 'Schluckstörungen', href: '/therapie/schluckstoerungen/', description: 'Dysphagie bei Erwachsenen und Kindern' },
  ]}
>
  <section class="bento-page" aria-label="Sprechstörungen in Duisburg">
    <div class="bento-grid">
      <article class="bento-card bento-card--image">
        <Image
          src={stimmImg}
          alt="Therapie von Sprechstörungen in der Praxis für Logopädie Şimşek Duisburg"
          class="bento-card__image"
          widths={[540, 900, 1200]}
          sizes="(max-width: 960px) 100vw, 55vw"
          loading="eager"
          decoding="async"
        />
        <div class="bento-card__overlay">
          <span class="bento-eyebrow">Sprechmotorik</span>
          <h2>Sprechstörungen gezielt und alltagsnah behandeln</h2>
          <p>
            Sprechstörungen betreffen die motorische Ausführung des Sprechens. Sie können
            die Verständlichkeit deutlich einschränken und Kinder wie Erwachsene im Alltag,
            in der Schule und im Beruf stark belasten.
          </p>
        </div>
      </article>

      <article class="bento-card bento-card--highlight">
        <span class="bento-eyebrow">Überblick</span>
        <h2>Woran sich behandlungsbedürftige Sprechprobleme zeigen</h2>
        <ul>
          <li><strong>Redefluss:</strong> Wiederholungen, Dehnungen, Blockierungen oder stark überhastetes Sprechen</li>
          <li><strong>Aussprache:</strong> fehlerhafte Lautbildung, Lispeln oder undeutliche Artikulation</li>
          <li><strong>Neurologie:</strong> Sprechprobleme nach Schlaganfall, Parkinson oder Schädel-Hirn-Trauma</li>
          <li><strong>Belastung:</strong> Leidensdruck, Vermeideverhalten oder sozialer Rückzug</li>
          <li><strong>Verständlichkeit:</strong> Aussagen werden von Umfeld, Schule oder Familie oft nicht verstanden</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Störungsbilder</span>
        <h2>Häufige Sprechstörungen im Überblick</h2>
        <ul>
          <li><strong>Stottern:</strong> Wiederholungen, Dehnungen und Blockierungen</li>
          <li><strong>Poltern:</strong> überhastetes, unrhythmisches Sprechen mit verminderter Selbstwahrnehmung</li>
          <li><strong>Dyslalie / Sigmatismus:</strong> fehlerhafte Lautbildung, besonders der S-Laute</li>
          <li><strong>Dysarthrie:</strong> neurologisch bedingte Einschränkung von Artikulation, Atmung und Prosodie</li>
          <li><strong>Sprechapraxie:</strong> Planungsstörung der Sprechbewegungen</li>
          <li><strong>Rhinophonie:</strong> veränderte Nasalität beim Sprechen</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Stottern</span>
        <h2>Stottertherapie verbindet Technik und Entlastung</h2>
        <p>
          Stottern beginnt meist im Alter von 2 bis 6 Jahren. Unsere Therapie kombiniert
          <strong> Sprechflüssigkeitstechniken</strong> wie weichen Stimmeinsatz oder Verlangsamung
          mit psychosozialer Begleitung.
        </p>
        <p>
          Damit arbeiten wir nicht nur an der Sprechweise, sondern auch an Vermeideverhalten,
          Anspannung und sozialer Sicherheit.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Kinder</span>
        <h2>Aussprachestörungen bei Kindern früh korrigieren</h2>
        <p>
          Lispeln, Sigmatismus und andere Aussprachefehler können die schulische Entwicklung
          und das Selbstvertrauen beeinflussen. Mit spielerischen Übungen fördern wir eine
          <strong> klare und verständliche Aussprache</strong>.
        </p>
        <p>
          Behandelt werden Ersetzungen, Auslassungen, Zusätze und inkonsistente Aussprachefehler.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Elternhinweis</span>
        <h2>Bei anhaltendem Stottern ist frühe Abklärung sinnvoll</h2>
        <p>
          Ein leichtes Stottern zwischen dem 2. und 4. Lebensjahr kann vorübergehend sein.
          Wenn Ihr Kind jedoch länger als drei Monate stottert, sichtbaren Leidensdruck zeigt
          oder beginnt, Sprechen zu vermeiden, empfehlen wir eine logopädische Abklärung.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Poltern</span>
        <h2>Poltern wird oft übersehen, ist aber gut behandelbar</h2>
        <p>
          Betroffene sprechen häufig überhetzt und undeutlich, ohne sich dessen ausreichend
          bewusst zu sein. Ein zentraler Teil der Therapie ist deshalb die Verbesserung
          von Selbstwahrnehmung, Sprechtempo und Struktur im Ausdruck.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Erwachsene</span>
        <h2>Dysarthrie und Sprechapraxie nach neurologischen Erkrankungen</h2>
        <p>
          Bei <strong>Parkinson, Multipler Sklerose, Schlaganfall</strong> oder nach
          Schädel-Hirn-Trauma können Sprechmuskulatur und Sprechplanung beeinträchtigt sein.
        </p>
        <p>
          Ziel ist eine bessere Verständlichkeit im Alltag und der sichere Umgang mit verbliebenen Ressourcen.
        </p>
      </article>

      <article class="bento-card bento-card--accent">
        <span class="bento-eyebrow">Therapieziele</span>
        <h2>Verständlichkeit, Sicherheit und Teilhabe stehen im Mittelpunkt.</h2>
        <p>
          Wir arbeiten an deutlicher Artikulation, besserer Atemführung, flüssigerem Sprechen
          und praktikablen Strategien für Schule, Familie und Beruf.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Neurologische Therapie</span>
        <h2>Schwerpunkte bei Dysarthrie und Sprechapraxie</h2>
        <ul>
          <li>Verbesserung der Artikulationsdeutlichkeit</li>
          <li>Optimierung von Atmung, Stimmgebung und Prosodie</li>
          <li>Reorganisation der Sprechplanung durch strukturierte Übungssequenzen</li>
          <li>Erlernen von Kompensationsstrategien für den Alltag</li>
          <li>Einsatz von Kommunikationshilfen bei schwerer Ausprägung</li>
        </ul>
      </article>

      <article class="bento-card bento-card--soft">
        <span class="bento-eyebrow">Ablauf</span>
        <h2>Diagnostik, Therapieplanung und regelmäßige Verlaufskontrolle</h2>
        <p>
          Jede Behandlung startet mit einer differenzierten Einschätzung der Sprechstörung.
          Darauf aufbauend definieren wir Therapieziele und trainieren gezielt die Fähigkeiten,
          die für Alltag und Teilhabe am wichtigsten sind.
        </p>
      </article>
    </div>
  </section>
</ServicePage>

<style>
  .bento-page {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    grid-auto-flow: row dense;
  }

  .bento-card {
    grid-column: span 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(28, 25, 22, 0.06);
    min-height: 100%;
  }

  .bento-card--image {
    grid-column: span 6;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 22rem;
    border: 0;
  }

  .bento-card--highlight {
    grid-column: span 6;
    background: linear-gradient(180deg, rgba(112, 90, 74, 0.08), rgba(255, 255, 255, 0.96));
  }

  .bento-card--wide {
    grid-column: span 8;
  }

  .bento-card--accent {
    background: var(--color-primary);
    color: white;
  }

  .bento-card--soft {
    background: var(--color-primary-light);
  }

  .bento-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bento-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(24, 18, 14, 0.08) 10%,
      rgba(24, 18, 14, 0.76) 100%
    );
  }

  .bento-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .bento-card--image .bento-eyebrow,
  .bento-card--accent .bento-eyebrow {
    color: rgba(255, 255, 255, 0.84);
  }

  .bento-grid .bento-card :global(h2),
  .bento-grid .bento-card__overlay :global(h2) {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
    color: var(--color-text);
  }

  .bento-grid .bento-card__overlay :global(h2) {
    color: white;
    max-width: 20ch;
  }

  .bento-card__overlay :global(p),
  .bento-card__overlay :global(p strong),
  .bento-card__overlay :global(p a) {
    color: #ffffff !important;
  }

  .bento-grid .bento-card :global(p),
  .bento-grid .bento-card :global(ul),
  .bento-grid .bento-card__overlay :global(p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .bento-grid .bento-card__overlay :global(p) {
    max-width: 56ch;
  }

  .bento-grid .bento-card :global(ul) {
    display: grid;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .bento-grid .bento-card :global(li) {
    position: relative;
    padding-left: 1rem;
  }

  .bento-grid .bento-card :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .bento-grid .bento-card--accent :global(h2),
  .bento-grid .bento-card--accent :global(p),
  .bento-grid .bento-card--accent :global(a),
  .bento-grid .bento-card--accent .bento-eyebrow {
    color: white;
  }

  @media (max-width: 960px) {
    .bento-card,
    .bento-card--image,
    .bento-card--highlight,
    .bento-card--wide {
      grid-column: span 12;
    }

    .bento-card--image {
      min-height: 19rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      gap: 0.875rem;
    }

    .bento-card {
      padding: 1.2rem;
    }

    .bento-card--image {
      min-height: 0;
      padding: 1rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .bento-card__overlay {
      position: static;
      padding: 1rem 0 0;
      background: none;
    }

    .bento-card__image {
      height: 13.5rem;
      border-radius: 6px;
    }

    .bento-card--image .bento-eyebrow {
      color: var(--color-primary);
    }

    .bento-grid .bento-card__overlay :global(h2) {
      color: var(--color-text);
      max-width: none;
    }

    .bento-card__overlay :global(p),
    .bento-card__overlay :global(p strong),
    .bento-card__overlay :global(p a) {
      color: var(--color-text-muted) !important;
    }

    .bento-card__overlay :global(strong),
    .bento-card__overlay :global(a) {
      color: var(--color-text) !important;
    }
  }
</style>
