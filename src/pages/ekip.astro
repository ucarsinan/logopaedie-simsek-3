---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import emelImg from '../assets/therapy/team-emel-simsek-ucar.jpg';
import maraImg from '../assets/therapy/team-mara-niessalla.png';

const siteUrl = 'https://logopaedie-simsek.de';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Emel Şimşek-Uçar",
  "jobTitle": "Devlet Onaylı Logoped",
  "worksFor": {
    "@type": "MedicalOrganization",
    "name": "Praxis für Logopädie Şimşek",
    "url": siteUrl
  },
  "knowsLanguage": ["de", "tr"],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tonhallenstraße 21",
    "addressLocality": "Duisburg",
    "postalCode": "47051",
    "addressCountry": "DE"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${siteUrl}/anasayfa` },
    { "@type": "ListItem", "position": 2, "name": "Ekip", "item": `${siteUrl}/ekip` }
  ]
};

const teamMembers = [
  {
    name: 'Emel Şimşek-Uçar',
    role: 'Muayenehane Sahibi · Devlet Onaylı Logoped',
    photo: emelImg,
    alt: 'Emel Şimşek-Uçar, Praxis für Logopädie Şimşek muayenehanesinin sahibi',
    tags: ['Deutsch & Türkçe', '10+ Yıl Deneyim', 'Çocuklar & Yetişkinler'],
  },
  {
    name: 'Mara Nießalla',
    role: 'Devlet Onaylı Logoped',
    photo: maraImg,
    alt: 'Mara Nießalla, Praxis für Logopädie Şimşek Duisburg logopedi ekibinden',
    tags: ['Çocuklar & Gençler', 'Dil Gelişimi', 'Tanı & Terapi'],
  },
];
---

<Layout
  title="Ekibimiz – Praxis für Logopädie Şimşek Duisburg"
  description="Emel Şimşek-Uçar ve Mara Nießalla ile tanışın – Praxis für Logopädie Şimşek Duisburg ekibi."
  lang="tr"
  additionalSchemas={[personSchema, breadcrumbSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/team/` },
    { lang: 'tr', url: `${siteUrl}/ekip/` },
    { lang: 'x-default', url: `${siteUrl}/team/` },
  ]}
>
  <Header lang="tr" alternateUrl="/team" />
  <Nav lang="tr" alternateUrl="/team" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="İçerik Yolu">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/anasayfa/" class="hover:text-primary transition-colors">Ana Sayfa</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Ekip</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-14 pb-10 border-b border-border">
      <div class="container">
        <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold leading-[1.1] text-text mb-4">
          Ekibimiz
        </h1>
        <p class="text-text-muted text-lg">
          Logoterapi güven işidir. Muayehanemizdeki insanlarla tanışın.
        </p>
      </div>
    </section>

    <!-- Team Profile -->
    <div class="container py-14">
      <div class="bento-page-grid">

        <section class="bento-tile bento-tile--full">
          <span class="bento-kicker">Ekip</span>
          <div class="grid grid-cols-2 gap-6 max-[860px]:grid-cols-1">
          {teamMembers.map((member) => (
            <article class="bento-tile overflow-hidden !p-0">
              <div class="grid grid-cols-[140px_1fr] min-h-40 max-[540px]:grid-cols-[112px_1fr]">
                <div class="relative bg-surface-2 overflow-hidden">
                  <Image
                    src={member.photo}
                    alt={member.alt}
                    class="w-full h-full object-cover object-top"
                    widths={[240, 360, 520]}
                    sizes="(max-width: 540px) 112px, 140px"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="p-6 max-[540px]:p-4 flex flex-col justify-center">
                  <h2 class="font-display text-2xl max-[540px]:text-xl font-semibold text-text mb-1">{member.name}</h2>
                  <p class="text-primary font-medium text-sm mb-4">{member.role}</p>
                  <div class="flex flex-wrap gap-2">
                    {member.tags.map((tag) => (
                      <span class="bg-primary-light text-primary-dark text-xs font-semibold px-3 py-1 rounded-full">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
        </section>

        <article class="prose-section bento-tile bento-tile--wide bento-tile--highlight">
        <h2>Emel Şimşek-Uçar Hakkında</h2>
        <p>
          Emel Şimşek-Uçar, <strong>devlet onaylı logoped</strong> ve Duisburg-Mitte'deki
          Praxis für Logopädie Şimşek Muayenehanesi'nin kurucusudur. On yılı aşkın klinik deneyimiyle
          çocukları, gençleri ve yetişkinleri daha iyi iletişim kurabilmeleri yolunda desteklemektedir.
        </p>

        <h2>Uzmanlık Alanları</h2>
        <ul>
          <li><strong>Çocuk Dil Terapisi:</strong> Dil gelişim gecikmeleri, ses oluşturma bozuklukları, kekemelik, okuma-yazma güçlüğü önlemi</li>
          <li><strong>Çok Dillilik:</strong> İki dilli büyüyen çocuklarda (Almanca/Türkçe) tanı ve terapi</li>
          <li><strong>Yetişkin Terapisi:</strong> Afazi, dizartri, ses bozuklukları, yutma bozuklukları</li>
          <li><strong>Erken Müdahale:</strong> Bebeklik döneminden itibaren logopedik tedavi</li>
        </ul>

        <h2>Mara Nießalla Hakkında</h2>
        <p>
          Mara Nießalla ekibimizi <strong>devlet onaylı logoped</strong> olarak tamamlıyor.
          Özellikle çocuklar ve gençlerde dil gelişimi, artikülasyon ve günlük yaşama uygun
          egzersiz stratejileri alanlarında çalışmaktadır.
        </p>

        <h2>Diller</h2>
        <p>
          Muayenehane; tam tanı, danışmanlık ve terapi hizmetini <strong>Almanca ve Türkçe</strong>
          olarak sunmaktadır. Bu durum özellikle iki dilli büyüyen çocuklar ve ana dillerinde
          bakım almak isteyen Türkçe konuşan hastalar için büyük bir değer taşımaktadır.
        </p>
        </article>

        <aside class="bento-tile bento-tile--soft">
          <span class="bento-kicker">Kariyer</span>
          <h2>Büyüyoruz</h2>
          <p>
            Ekibimizi güçlendirmek ister misiniz? Deneyimli logoped arıyoruz.
          </p>
          <div class="mt-6 flex gap-4 flex-wrap">
            <a href="/kariyer/" class="btn btn-primary">İş ilanına git</a>
            <a href="/iletisim/" class="btn btn-ghost">Randevu Talebi</a>
          </div>
        </aside>

      </div>
    </div>

  </main>
  <Footer lang="tr" />
</Layout>

<style>
  .prose-section :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-section :global(p) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-section :global(ul) {
    list-style: none;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose-section :global(ul li) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    padding-left: 1.5rem;
    position: relative;
  }
  .prose-section :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .prose-section :global(strong) { font-weight: 600; color: var(--color-text); }
  .prose-section :global(a) { color: var(--color-primary); }
  .info-box {
    background: var(--color-primary-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 6px 6px 0;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }
</style>
