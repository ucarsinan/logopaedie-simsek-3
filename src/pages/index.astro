---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Services from '../components/sections/Services.astro';
import BentoGallery from '../components/sections/BentoGallery.astro';
import Bilingual from '../components/sections/Bilingual.astro';
import Team from '../components/sections/Team.astro';
import Praxis from '../components/sections/Praxis.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Karriere from '../components/sections/Karriere.astro';
import Faq from '../components/sections/Faq.astro';
import Kontakt from '../components/sections/Kontakt.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n/index';

const t = useTranslations('de');
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://logopaedie-simsek.de/#business",
  "review": t.testimonials.items.map(item => ({
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": item.stars, "bestRating": 5 },
    "author": { "@type": "Person", "name": item.author },
    "reviewBody": item.quote,
    "publisher": { "@type": "Organization", "name": "Praxis für Logopädie Şimşek" }
  }))
};
---

<Layout
  title="Logopädie Duisburg | Praxis Şimşek – Sprachtherapie Deutsch & Türkisch"
  description="Logopädische Praxis in Duisburg – spezialisiert auf Sprach-, Sprech- und Stimmtherapie für Kinder und Erwachsene. Zweisprachig DE/TR."
  additionalSchemas={[faqSchema, reviewSchema]}
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/anasayfa/' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/' },
  ]}
>
  <Header alternateUrl="/anasayfa/" />
  <Nav alternateUrl="/anasayfa/" />
  <main>
    <Hero />
    <About />
    <BentoGallery />
    <Services />
    <Bilingual />
    <Team />
    <Praxis />
    <Testimonials />
    <Karriere />
    <Faq />
    <Kontakt />
  </main>
  <Footer />
</Layout>
