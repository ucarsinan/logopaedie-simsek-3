---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://logopaedie-simsek.de';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "MedicalBusiness"],
      "@id": `${siteUrl}/#business`,
      "name": "Praxis für Logopädie Şimşek",
      "description": "Logopädische Praxis in Duisburg – Sprach-, Sprech-, Stimm- und Schlucktherapie für Kinder und Erwachsene. Zweisprachig Deutsch & Türkisch.",
      "url": siteUrl,
      "telephone": "+4920334868690",
      "email": "info@logopaedie-simsek.de",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Tonhallenstraße 21",
        "addressLocality": "Duisburg",
        "postalCode": "47051",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.4292,
        "longitude": 6.7681
      },
      "hasMap": "https://goo.gl/maps/cGPVX58woxP2",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:00",
          "closes": "18:00"
        }
      ],
      "availableLanguage": [
        { "@type": "Language", "name": "German" },
        { "@type": "Language", "name": "Turkish" }
      ],
      "areaServed": { "@type": "City", "name": "Duisburg" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Logopädie Duisburg", "item": `${siteUrl}/logopaedie-duisburg` }
      ]
    }
  ]
};
---

<Layout
  title="Logopädie Duisburg – Praxis Şimşek | Sprach- & Sprechtherapie"
  description="Logopädische Praxis in Duisburg-Mitte – nur 2 Minuten vom Hauptbahnhof. Sprach-, Sprech-, Stimm- und Schlucktherapie für Kinder und Erwachsene. Zweisprachig Deutsch & Türkisch."
  additionalSchemas={[schema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/logopaedie-duisburg/` },
    { lang: 'x-default', url: `${siteUrl}/logopaedie-duisburg/` },
  ]}
>
  <Header />
  <Nav />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Logopädie Duisburg</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-14 pb-12 border-b border-border">
      <div class="container">
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="bg-primary-light text-primary-dark text-xs font-semibold px-3 py-1 rounded-full">Duisburg-Mitte</span>
          <span class="bg-primary-light text-primary-dark text-xs font-semibold px-3 py-1 rounded-full">Deutsch & Türkisch</span>
          <span class="bg-primary-light text-primary-dark text-xs font-semibold px-3 py-1 rounded-full">Kassenrezept & Privat</span>
        </div>
        <h1 class="font-display text-[clamp(2rem,5vw,3.25rem)] font-semibold leading-[1.1] text-text mb-5">
          Logopädie Duisburg –<br />Praxis Şimşek
        </h1>
        <p class="text-text-muted text-lg max-w-2xl mb-7">
          Ihre logopädische Fachpraxis im Herzen von Duisburg. Sprach-, Sprech-, Stimm- und
          Schlucktherapie für Kinder, Jugendliche und Erwachsene – auf Deutsch und Türkisch.
          Nur 2 Minuten zu Fuß vom Hauptbahnhof.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/kontakt/" class="btn btn-accent">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/></svg>
            Termin anfragen
          </a>
          <a href="tel:+4920334868690" class="btn btn-ghost">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            0203 – 34 86 86 90
          </a>
        </div>
      </div>
    </section>

    <!-- Content -->
    <div class="container py-14">
      <div class="bento-page-grid">

        <!-- Main content -->
        <article class="bento-tile bento-tile--wide bento-tile--highlight prose-section">

          <h2>Logopädie in Duisburg – was wir behandeln</h2>
          <p>
            Die Praxis für Logopädie Şimşek bietet ein breites Spektrum logopädischer Diagnostik
            und Therapie in Duisburg-Mitte. Unsere Patientinnen und Patienten kommen aus Duisburg,
            Duisburg-Zentrum, Duisburg-Mitte und der gesamten Umgebung – darunter Rheinhausen,
            Hamborn, Marxloh, Meiderich und dem Ruhrgebiet.
          </p>

          <h2>Unser Therapieangebot in Duisburg</h2>
          <ul>
            <li><strong><a href="/therapie/sprachstoerungen/">Sprachtherapie:</a></strong> Sprachentwicklungsverzögerung, Aphasie nach Schlaganfall, Wortfindungsstörungen, Grammatikstörungen</li>
            <li><strong><a href="/therapie/sprechstoerungen/">Sprechtherapie:</a></strong> Stottern, Poltern, Lispeln, Dysarthrie, Sprechapraxie</li>
            <li><strong><a href="/therapie/stimmtherapie/">Stimmtherapie:</a></strong> Dysphonie, Heiserkeit, funktionelle und organische Stimmstörungen, ISTP-Methode</li>
            <li><strong><a href="/therapie/schluckstoerungen/">Schlucktherapie:</a></strong> Dysphagie bei Kindern und Erwachsenen, nach neurologischen Erkrankungen</li>
            <li><strong><a href="/therapie/kinder-und-jugendliche/">Therapie für Kinder:</a></strong> Frühförderung, Lese-Rechtschreib-Schwäche, auditive Verarbeitung</li>
            <li><strong><a href="/therapie/erwachsene/">Therapie für Erwachsene:</a></strong> Neurologische Erkrankungen, Stimmbelastung, Schluckprobleme</li>
          </ul>

          <h2>Zweisprachige Logopädie: Deutsch und Türkisch</h2>
          <p>
            Ein besonderes Merkmal unserer Praxis ist die <strong>zweisprachige Betreuung
            auf Deutsch und Türkisch</strong>. Für mehrsprachig aufwachsende Kinder kann eine
            Diagnostik in den relevanten Sprachen helfen, mehrsprachigkeitstypische Entwicklung
            von einer tatsächlichen Sprachentwicklungsstörung zu unterscheiden.
            Erfahren Sie mehr unter <a href="/tuerkische-logopaedie-duisburg/">Türkische Logopädie Duisburg</a>.
          </p>

          <h2>Logopädie – was ist das?</h2>
          <p>
            Logopädie (auch: Sprachtherapie) befasst sich mit der Diagnostik, Behandlung und
            Prävention von Störungen in den Bereichen Sprache, Sprechen, Stimme, Schlucken und
            Hören. Logopädinnen arbeiten mit Säuglingen, Kleinkindern, Schulkindern,
            Jugendlichen und Erwachsenen – von der Frühförderung bis zur geriatrischen Behandlung.
          </p>

          <div class="info-box">
            <p>
              <strong>Wer verordnet Logopädie?</strong> Hausärztinnen, HNO-Ärzte, Kinderärzte,
              Neurologen, Internisten, Zahnärzte und andere Fachärzte können eine
              Heilmittelverordnung (Rezept) für logopädische Therapie ausstellen.
              Gesetzliche Krankenkassen übernehmen die Kosten bei gültiger Verordnung abzüglich
              der gesetzlichen Zuzahlung; bei privaten Versicherungen hängt die Erstattung vom Tarif ab.
              Mehr dazu: <a href="/kostenuebernahme/">Kosten & Kostenübernahme</a>
            </p>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="bento-tile bento-tile--soft flex flex-col gap-5">
          <!-- Kontakt-Box -->
          <div class="bg-surface border border-border rounded-lg p-6 shadow-sm">
            <h3 class="font-display text-base font-semibold text-text mb-4">Praxis Duisburg</h3>
            <address class="not-italic text-sm text-text-muted flex flex-col gap-2">
              <div class="flex gap-2.5 items-start">
                <svg class="mt-0.5 shrink-0 text-primary" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Tonhallenstraße 21<br />47051 Duisburg<br /><span class="text-xs">(3. OG, Aufzug vorhanden)</span></span>
              </div>
              <div class="flex gap-2.5 items-center">
                <svg class="shrink-0 text-primary" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:+4920334868690" class="hover:text-primary transition-colors">0203 34 86 86 90</a>
              </div>
              <div class="flex gap-2.5 items-center">
                <svg class="shrink-0 text-primary" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <a href="mailto:info@logopaedie-simsek.de" class="hover:text-primary transition-colors">info@logopaedie-simsek.de</a>
              </div>
            </address>
            <div class="mt-4 pt-4 border-t border-border">
              <p class="text-xs text-text-muted font-medium mb-1">Öffnungszeiten</p>
              <p class="text-sm text-text-muted">Mo–Fr: 08:00–18:00 Uhr<br /><span class="text-xs">(nach Vereinbarung)</span></p>
            </div>
          </div>

          <!-- Anfahrt-Tipp -->
          <div class="bg-primary-light border border-primary/20 rounded-lg p-5 text-sm">
            <p class="font-semibold text-primary-dark mb-1">Nur 2 Min. vom HBF</p>
            <p class="text-text-muted">Duisburg Hauptbahnhof → Tonhallenstraße. Gut erreichbar mit Bus, Straßenbahn und U-Bahn.</p>
            <a href="/kontakt/" class="mt-3 inline-block text-primary-dark font-semibold text-xs hover:underline">Anfahrt & Kontakt →</a>
          </div>

          <!-- Sprachen -->
          <div class="bg-surface border border-border rounded-lg p-5 text-sm">
            <p class="font-semibold text-text mb-2">Deutsch & Türkisch</p>
            <p class="text-text-muted">Wir bieten Diagnostik, Beratung und Therapie auf Deutsch und Türkisch an.</p>
            <a href="/tuerkische-logopaedie-duisburg/" class="mt-3 inline-block text-primary-dark font-semibold text-xs hover:underline">Türkische Logopädie →</a>
          </div>
        </aside>
      </div>
    </div>

    <!-- CTA -->
    <section class="bg-primary py-14" aria-label="Termin anfragen">
      <div class="container text-center flex flex-col items-center gap-5">
        <h2 class="font-display text-[clamp(1.5rem,3vw,2.25rem)] font-semibold text-white leading-[1.2]">
          Termin in unserer Duisburger Praxis vereinbaren
        </h2>
        <p class="text-white/80 text-lg max-w-xl">
          Rufen Sie uns an oder nutzen Sie die Kontaktseite für Adresse, Anfahrt und allgemeine Informationen.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/kontakt/" class="btn btn-outline-white">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg>
            Termin anfragen
          </a>
          <a href="tel:+4920334868690" class="btn btn-outline-white">
            0203 – 34 86 86 90
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .prose-section :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .prose-section :global(h3) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-section :global(p) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-section :global(ul) {
    list-style: none;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose-section :global(ul li) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    padding-left: 1.5rem;
    position: relative;
  }
  .prose-section :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .prose-section :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }
  .prose-section :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }
  .prose-section :global(a:hover) {
    text-decoration-color: currentColor;
  }
  .info-box {
    background: var(--color-primary-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 6px 6px 0;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }
  .info-box :global(p) {
    margin: 0;
  }
</style>
