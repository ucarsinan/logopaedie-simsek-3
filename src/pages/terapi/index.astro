---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const services = [
  {
    title: 'Dil Bozuklukları',
    description: 'Dil gelişim gecikmeleri, inme sonrası afazi, erken müdahale – çocuklar ve yetişkinler için.',
    tags: ['Dil Gelişimi', 'Afazi', 'Erken Müdahale'],
    href: '/terapi/dil-bozuklugu',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'Konuşma Bozuklukları',
    description: 'Kekemelik, hızlı konuşma, pelteklik ve dizartri veya konuşma apraksisi gibi motor kaynaklı konuşma bozuklukları.',
    tags: ['Kekemelik', 'Pelteklik', 'Dizartri'],
    href: '/terapi/konusma-bozuklugu',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
  {
    title: 'Ses Terapisi',
    description: 'Fonksiyonel ve organik ses bozuklukları – kısıklık, disfoni, ameliyat sonrası veya meslek sesi kullananlar için.',
    tags: ['Disfoni', 'Kısıklık', 'Ses Eğitimi'],
    href: '/terapi/ses-terapisi',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  },
  {
    title: 'Yutma Bozuklukları (Disfaji)',
    description: 'Yetişkinlerde ve çocuklarda disfajinin tanı ve tedavisi – inme, Parkinson veya diğer nörolojik hastalıklarda.',
    tags: ['Disfaji', 'Yutma', 'Nöroloji'],
    href: '/terapi/yutma-bozuklugu',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];
---

<Layout
  title="Hizmetler | Praxis für Logopädie Şimşek Duisburg"
  description="Duisburg'daki Şimşek Logopedi Muayenehanesi'nin tüm logoterapi hizmetleri: dil bozuklukları, konuşma bozuklukları, ses terapisi ve disfaji – çocuklar ve yetişkinler için."
  lang="tr"
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/leistungen' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/terapi' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/leistungen' },
  ]}
>
  <Header lang="tr" alternateUrl="/leistungen" />
  <Nav lang="tr" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">
    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="İçerik Yolu">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted" role="list">
          <li><a href="/anasayfa/" class="hover:text-primary transition-colors">Ana Sayfa</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Hizmetler</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-14 pb-10 border-b border-border">
      <div class="container">
        <span class="text-xs font-semibold tracking-widest uppercase text-primary">Hizmet Teklifimiz</span>
        <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold leading-[1.1] text-text mt-3 mb-4">Logoterapinin Tüm Alanları</h1>
        <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-2xl">
          Duisburg'daki muayenehanemizde çocuklar, yetişkinler ve yaşlılar için logopedik bozuklukların
          tam spektrumunu tedavi ediyoruz. Almanca ve Türkçe olarak.
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-16 bg-bg">
      <div class="container">
        <div class="grid grid-cols-2 gap-6 max-[640px]:grid-cols-1">
          {services.map(service => (
            <a
              href={service.href}
              class="bg-surface border border-border rounded-md p-8 shadow-sm hover:border-primary hover:-translate-y-1 hover:shadow-md transition-[transform,box-shadow,border-color] duration-200 flex flex-col gap-4 no-underline group"
            >
              <div class="w-14 h-14 rounded-sm bg-primary-light flex items-center justify-center text-primary" aria-hidden="true" set:html={service.icon} />
              <div>
                <h2 class="font-display text-xl font-semibold text-text group-hover:text-primary transition-colors mb-2">{service.title}</h2>
                <p class="text-[.9375rem] text-text-muted leading-[1.65]">{service.description}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                {service.tags.map(tag => (
                  <span class="bg-primary-light text-primary text-xs font-semibold px-2.5 py-1 rounded-full">{tag}</span>
                ))}
              </div>
              <span class="text-sm font-semibold text-primary inline-flex items-center gap-1 mt-auto">
                Daha fazla bilgi
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- USP Strip -->
    <section class="py-14 bg-primary" aria-label="Fark Yaratan Özelliğimiz">
      <div class="container text-center flex flex-col items-center gap-5">
        <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] font-semibold text-white">Almanca ve Türkçe İki Dilli Terapi</h2>
        <p class="text-white/80 text-[1.0625rem] leading-[1.7] max-w-xl">
          Ruhr Bölgesi'nde nadir bulunan bir hizmet – özellikle iki dilli büyüyen çocuklar
          ve Türkçe konuşan yetişkinler için büyük değer taşıyor.
        </p>
        <a href="/iletisim/" class="btn btn-outline-white">Randevu Talebi</a>
      </div>
    </section>

    <!-- Back link -->
    <div class="container py-10">
      <a href="/anasayfa/" class="inline-flex items-center gap-2 text-primary font-medium hover:underline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Ana Sayfaya Dön
      </a>
    </div>
  </main>
  <Footer lang="tr" />
</Layout>
