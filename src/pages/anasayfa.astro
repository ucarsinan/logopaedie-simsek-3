---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Services from '../components/sections/Services.astro';
import BentoGallery from '../components/sections/BentoGallery.astro';
import Team from '../components/sections/Team.astro';
import Praxis from '../components/sections/Praxis.astro';
import Faq from '../components/sections/Faq.astro';
import Kontakt from '../components/sections/Kontakt.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n/index';

const t = useTranslations('tr');
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<Layout
  title="Praxis für Logopädie Şimşek – Konuşun. Anlayın. Bağlanın."
  description="Duisburg'da logoterapi muayenehanesi – çocuklar ve yetişkinler için dil, konuşma ve ses bozukluklarında uzman. Almanca ve Türkçe iki dilli hizmet."
  lang="tr"
  additionalSchemas={[faqSchema]}
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/anasayfa' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/' },
  ]}
>
  <Header lang="tr" alternateUrl="/" />
  <Nav lang="tr" alternateUrl="/" />
  <main>
    <Hero lang="tr" />
    <About lang="tr" />
    <BentoGallery lang="tr" />
    <Services lang="tr" />
    <Team lang="tr" />
    <Praxis lang="tr" />
    <Faq lang="tr" />
    <Kontakt lang="tr" />
  </main>
  <Footer lang="tr" />
</Layout>
