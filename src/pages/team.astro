---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import emelImg from '../assets/therapy/team-emel-simsek-ucar.jpg';
import maraImg from '../assets/therapy/team-mara-niessalla.png';

const siteUrl = 'https://logopaedie-simsek.de';

const teamSchemas = [
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Emel Şimşek-Uçar",
  "jobTitle": "Staatlich anerkannte Logopädin",
  "url": `${siteUrl}/team`,
  "description": "Staatlich anerkannte Logopädin und Gründerin der Praxis für Logopädie Şimşek in Duisburg. Spezialisiert auf zweisprachige Diagnostik und Therapie auf Deutsch und Türkisch. Mehr als 10 Jahre klinische Erfahrung in der Sprachtherapie für Kinder und Erwachsene.",
  "worksFor": {
    "@type": "MedicalOrganization",
    "name": "Praxis für Logopädie Şimşek",
    "url": siteUrl
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "German" },
    { "@type": "Language", "name": "Turkish" }
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Logopädin",
    "occupationalCategory": "Therapeutin",
    "skills": "Sprachtherapie, Stimmtherapie, Dysphagietherapie, Frühförderung, Aphasietherapie, Zweisprachige Diagnostik"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tonhallenstraße 21",
    "addressLocality": "Duisburg",
    "postalCode": "47051",
    "addressCountry": "DE"
  }
},
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Mara Nießalla",
  "jobTitle": "Staatlich geprüfte Logopädin",
  "url": `${siteUrl}/team`,
  "description": "Staatlich geprüfte Logopädin in der Praxis für Logopädie Şimşek in Duisburg. Schwerpunkt Sprachentwicklung bei Kindern und Jugendlichen.",
  "worksFor": {
    "@type": "MedicalOrganization",
    "name": "Praxis für Logopädie Şimşek",
    "url": siteUrl
  },
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Logopädin",
    "occupationalCategory": "Therapeutin",
    "skills": "Kindersprachtherapie, Sprachentwicklung, Diagnostik, Therapieplanung"
  }
}
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Team", "item": `${siteUrl}/team` }
  ]
};
---

<Layout
  title="Unser Team – Praxis für Logopädie Şimşek Duisburg"
  description="Lernen Sie Emel Şimşek-Uçar und Mara Nießalla kennen – das Team der Praxis für Logopädie Şimşek in Duisburg."
  additionalSchemas={[...teamSchemas, breadcrumbSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/team` },
    { lang: 'tr', url: `${siteUrl}/ekip` },
    { lang: 'x-default', url: `${siteUrl}/team` },
  ]}
>
  <Header alternateUrl="/ekip" />
  <Nav alternateUrl="/ekip" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </li>
          <li class="text-text font-medium" aria-current="page">Team</li>
        </ol>
      </div>
    </nav>

    <!-- Bento Grid -->
    <section class="container py-10 pb-16" aria-labelledby="team-heading">
      <div class="bento">

        <!-- ── Emel: Large portrait (spans 2 rows) ── -->
        <article class="bento-emel relative overflow-hidden rounded-(--radius-lg) group" aria-label="Emel Şimşek-Uçar">
          <a href="/team/emel-simsek-ucar/" class="absolute inset-0 z-10" aria-label="Zum Profil von Emel Şimşek-Uçar"></a>
          <Image
            src={emelImg}
            alt="Emel Şimşek-Uçar – Praxisinhaberin und Logopädin in Duisburg"
            class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.04]"
            widths={[480, 720, 960]}
            sizes="(max-width: 540px) 100vw, (max-width: 860px) 50vw, 40vw"
            loading="eager"
            decoding="async"
          />
          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#1c1916]/70 via-[#1c1916]/15 to-transparent"></div>
          <!-- Badge -->
          <div class="absolute top-5 right-5">
            <span class="bg-accent text-white text-[.7rem] font-bold tracking-[.06em] uppercase px-3 py-1.5 rounded-full shadow-md">
              Praxisinhaberin
            </span>
          </div>
          <!-- Content overlay -->
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h2 id="team-heading" class="font-display text-[1.625rem] font-semibold text-white leading-tight mb-1">
              Emel Şimşek-Uçar
            </h2>
            <p class="text-white/70 text-sm mb-3 font-medium">Staatlich anerkannte Logopädin</p>
            <div class="flex flex-wrap gap-2">
              <span class="bg-white/15 backdrop-blur-sm text-white text-xs font-medium px-3 py-1.5 rounded-full border border-white/20">
                Deutsch &amp; Türkçe
              </span>
              <span class="bg-white/15 backdrop-blur-sm text-white text-xs font-medium px-3 py-1.5 rounded-full border border-white/20">
                10+ Jahre Erfahrung
              </span>
              <span class="bg-white/15 backdrop-blur-sm text-white text-xs font-medium px-3 py-1.5 rounded-full border border-white/20">
                Kinder &amp; Erwachsene
              </span>
            </div>
            <span class="mt-3 inline-flex items-center gap-1 text-white/70 text-xs font-semibold group-hover:text-white transition-colors relative z-20 pointer-events-none">
              Profil ansehen
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </div>
        </article>

        <!-- ── Title card ── -->
        <div class="bento-title rounded-(--radius-lg) p-8 flex flex-col justify-between" style="background: var(--color-primary-light);">
          <span class="text-xs font-semibold tracking-[.12em] uppercase text-primary">Unser Team</span>
          <div>
            <p class="font-display text-[clamp(1.875rem,3vw,2.625rem)] font-semibold text-text leading-[1.1] mb-3">
              Logopädie ist<br><em class="text-primary">Vertrauenssache.</em>
            </p>
            <p class="text-text-muted text-[0.9375rem] leading-relaxed max-w-xs">
              Lernen Sie die Menschen kennen, die jeden Tag für bessere Kommunikation arbeiten.
            </p>
          </div>
          <a href="/kontakt/" class="self-start btn btn-primary text-sm py-3 px-5 mt-2">
            Termin anfragen
          </a>
        </div>

        <!-- ── Stats card ── -->
        <div class="bento-stats rounded-(--radius-lg) p-6 flex flex-col justify-between" style="background: var(--color-primary);">
          <div class="space-y-1 mb-6">
            <div class="font-display text-[3.25rem] font-semibold text-white leading-none">10+</div>
            <div class="text-white/55 text-xs font-medium leading-snug">Jahre klinische<br>Erfahrung</div>
          </div>
          <div class="w-8 h-px mb-6" style="background: rgba(255,255,255,0.2);"></div>
          <div class="space-y-1">
            <div class="font-display text-[3.25rem] font-semibold text-white leading-none">2</div>
            <div class="text-white/55 text-xs font-medium leading-snug">Sprachen auf<br>Muttersprachniveau</div>
          </div>
        </div>

        <!-- ── Languages card ── -->
        <div class="bento-lang rounded-(--radius-lg) p-6 flex flex-col justify-center gap-4" style="background: var(--color-bg-alt);">
          <div class="flex gap-2.5 flex-wrap">
            <span class="bg-surface border border-border text-text font-semibold text-sm px-4 py-2.5 rounded-xl shadow-sm">
              🇩🇪&nbsp; Deutsch
            </span>
            <span class="bg-surface border border-border text-text font-semibold text-sm px-4 py-2.5 rounded-xl shadow-sm">
              🇹🇷&nbsp; Türkçe
            </span>
          </div>
          <p class="text-text-muted text-xs leading-relaxed">
            Vollständige Diagnostik, Beratung und Therapie in beiden Sprachen — Mehrsprachigkeit als Ressource, nicht als Hürde.
          </p>
        </div>

        <!-- ── Mara: Portrait card ── -->
        <article class="bento-mara rounded-(--radius-lg) overflow-hidden group relative" style="background: var(--color-surface); border: 1px solid var(--color-border);" aria-label="Mara Nießalla">
          <a href="/team/mara-niessalla/" class="absolute inset-0 z-10" aria-label="Zum Profil von Mara Nießalla"></a>
          <div class="h-54 overflow-hidden relative">
            <Image
              src={maraImg}
              alt="Mara Nießalla – Logopädin in der Praxis Şimşek Duisburg"
              class="w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.04]"
              widths={[320, 480, 640]}
              sizes="(max-width: 540px) 100vw, (max-width: 860px) 50vw, 40vw"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-5">
            <h2 class="font-display text-[1.3125rem] font-semibold text-text mb-1">Mara Nießalla</h2>
            <p class="text-primary font-semibold text-sm mb-2.5">Staatlich geprüfte Logopädin</p>
            <div class="flex flex-wrap gap-1.5 mb-3">
              <span class="bg-primary-light text-primary text-xs font-semibold px-2.5 py-1 rounded-full">Kinder &amp; Jugendliche</span>
              <span class="bg-primary-light text-primary text-xs font-semibold px-2.5 py-1 rounded-full">Sprachentwicklung</span>
              <span class="bg-primary-light text-primary text-xs font-semibold px-2.5 py-1 rounded-full">Diagnostik</span>
            </div>
            <p class="text-text-muted text-xs leading-relaxed">
              Schwerpunkt Kinder und Jugendliche: Sprachentwicklung, Artikulation und alltagsnahe Übungsstrategien.
            </p>
          </div>
        </article>

        <!-- ── Philosophy quote ── -->
        <div class="bento-phil rounded-(--radius-lg) p-7 flex flex-col justify-center" style="background: var(--color-accent-light);">
          <svg class="mb-4 shrink-0 opacity-35" width="36" height="36" viewBox="0 0 24 24" fill="var(--color-accent)" aria-hidden="true">
            <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/>
          </svg>
          <blockquote class="font-display text-[1.1875rem] italic text-text leading-relaxed mb-4">
            „Mehrsprachigkeit ist keine Hürde – sie ist eine Ressource."
          </blockquote>
          <cite class="text-xs font-semibold tracking-widest uppercase not-italic" style="color: var(--color-accent);">
            Emel Şimşek-Uçar
          </cite>
        </div>

        <!-- ── Career CTA ── -->
        <a href="/karriere/" class="bento-cta rounded-(--radius-lg) p-6 flex flex-col justify-between text-white group transition-opacity hover:opacity-90" style="background: var(--color-accent);">
          <div>
            <span class="text-xs font-semibold tracking-[.12em] uppercase text-white/60">Karriere</span>
            <h3 class="font-display text-[1.5rem] font-semibold text-white mt-2 leading-tight">
              Wir suchen<br>Verstärkung
            </h3>
            <p class="text-white/65 text-xs mt-2.5 leading-relaxed">
              Engagierte Logopäd:innen für unser Team in Duisburg gesucht.
            </p>
          </div>
          <div
            class="mt-5 inline-flex items-center justify-center gap-2 text-sm font-semibold rounded-xl px-4 py-3 transition-colors border border-white/30 group-hover:border-white/60"
            style="background: rgba(255,255,255,0.12);"
          >
            Stellenanzeige
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </div>
        </a>

      </div>
    </section>

    <!-- CTA Strip -->
    <div class="border-t border-border bg-bg-alt py-8">
      <div class="container flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
        <p class="text-text-muted text-sm">Fragen zu unserem Therapieangebot oder Terminanfragen?</p>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a href="/kontakt/" class="btn btn-primary justify-center">Termin anfragen</a>
          <a href="/therapieangebot/" class="btn btn-ghost justify-center">Therapieangebot</a>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Bento grid layout ── */
  .bento {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: minmax(240px, auto) minmax(200px, auto) minmax(210px, auto);
    gap: 12px;
    grid-template-areas:
      "emel emel title title title"
      "emel emel stats lang  lang"
      "mara mara phil  phil  cta";
  }

  .bento-emel  { grid-area: emel;  }
  .bento-title { grid-area: title; }
  .bento-stats { grid-area: stats; }
  .bento-lang  { grid-area: lang;  }
  .bento-mara  { grid-area: mara;  }
  .bento-phil  { grid-area: phil;  }
  .bento-cta   { grid-area: cta;   }

  @media (max-width: 860px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      gap: 10px;
      grid-template-areas:
        "title title"
        "emel  mara"
        "stats lang"
        "phil  cta";
    }
    .bento-emel { min-height: 340px; }
    .bento-mara { min-height: 340px; }
  }

  @media (max-width: 540px) {
    .bento {
      grid-template-columns: 1fr;
      gap: 10px;
      grid-template-areas:
        "title"
        "emel"
        "stats"
        "lang"
        "mara"
        "phil"
        "cta";
    }
    .bento-emel { min-height: 380px; }
    .bento-mara { min-height: 300px; }
  }

</style>
