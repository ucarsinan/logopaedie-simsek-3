---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import emelImg from '../assets/therapy/team-emel-simsek-ucar.jpg';
import maraImg from '../assets/therapy/team-mara-niessalla.png';

const siteUrl = 'https://logopaedie-simsek.de';

const teamSchemas = [
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Emel Şimşek-Uçar",
  "jobTitle": "Staatlich anerkannte Logopädin",
  "url": `${siteUrl}/team`,
  "description": "Staatlich anerkannte Logopädin und Gründerin der Praxis für Logopädie Şimşek in Duisburg. Spezialisiert auf zweisprachige Diagnostik und Therapie auf Deutsch und Türkisch. Mehr als 10 Jahre klinische Erfahrung in der Sprachtherapie für Kinder und Erwachsene.",
  "worksFor": {
    "@type": "MedicalOrganization",
    "name": "Praxis für Logopädie Şimşek",
    "url": siteUrl
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "German" },
    { "@type": "Language", "name": "Turkish" }
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Logopädin",
    "occupationalCategory": "Therapeutin",
    "skills": "Sprachtherapie, Stimmtherapie, Dysphagietherapie, Frühförderung, Aphasietherapie, Zweisprachige Diagnostik"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tonhallenstraße 21",
    "addressLocality": "Duisburg",
    "postalCode": "47051",
    "addressCountry": "DE"
  }
},
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Mara Nießalla",
  "jobTitle": "Staatlich geprüfte Logopädin",
  "url": `${siteUrl}/team`,
  "description": "Staatlich geprüfte Logopädin in der Praxis für Logopädie Şimşek in Duisburg. Schwerpunkt Sprachentwicklung bei Kindern und Jugendlichen.",
  "worksFor": {
    "@type": "MedicalOrganization",
    "name": "Praxis für Logopädie Şimşek",
    "url": siteUrl
  },
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Logopädin",
    "occupationalCategory": "Therapeutin",
    "skills": "Kindersprachtherapie, Sprachentwicklung, Diagnostik, Therapieplanung"
  }
}
];

const teamMembers = [
  {
    name: 'Emel Şimşek-Uçar',
    role: 'Praxisinhaberin · Staatlich anerkannte Logopädin',
    photo: emelImg,
    alt: 'Emel Şimşek-Uçar – Praxisinhaberin und Logopädin in Duisburg',
    tags: ['Deutsch & Türkçe', '10+ Jahre Erfahrung', 'Kinder & Erwachsene'],
  },
  {
    name: 'Mara Nießalla',
    role: 'Staatlich geprüfte Logopädin',
    photo: maraImg,
    alt: 'Mara Nießalla – Logopädin in der Praxis Şimşek Duisburg',
    tags: ['Kinder & Jugendliche', 'Sprachentwicklung', 'Diagnostik & Therapie'],
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Team", "item": `${siteUrl}/team` }
  ]
};
---

<Layout
  title="Unser Team – Praxis für Logopädie Şimşek Duisburg"
  description="Lernen Sie Emel Şimşek-Uçar und Mara Nießalla kennen – das Team der Praxis für Logopädie Şimşek in Duisburg."
  additionalSchemas={[...teamSchemas, breadcrumbSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/team` },
    { lang: 'tr', url: `${siteUrl}/ekip` },
    { lang: 'x-default', url: `${siteUrl}/team` },
  ]}
>
  <Header alternateUrl="/ekip" />
  <Nav alternateUrl="/ekip" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Team</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-14 pb-10 border-b border-border">
      <div class="container">
        <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold leading-[1.1] text-text mb-4">
          Unser Team
        </h1>
        <p class="text-text-muted text-lg">
          Logopädie ist Vertrauenssache. Lernen Sie die Menschen hinter der Praxis kennen.
        </p>
      </div>
    </section>

    <!-- Team Profile -->
    <div class="container py-14">
      <div class="prose-section">

        <div class="grid grid-cols-2 gap-6 mb-10 max-[860px]:grid-cols-1">
          {teamMembers.map((member) => (
            <article class="bg-surface border border-border rounded-md overflow-hidden shadow-sm">
              <div class="grid grid-cols-[160px_1fr] min-h-45 max-[540px]:grid-cols-1">
                <div class="relative bg-surface-2 overflow-hidden max-[540px]:h-64">
                  <Image
                    src={member.photo}
                    alt={member.alt}
                    class="w-full h-full object-cover object-top"
                    widths={[240, 360, 520]}
                    sizes="(max-width: 540px) 100vw, 160px"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="p-7 flex flex-col justify-center">
                  <h2 class="font-display text-2xl font-semibold text-text mb-1">{member.name}</h2>
                  <p class="text-primary font-medium text-sm mb-4">{member.role}</p>
                  <div class="flex flex-wrap gap-2">
                    {member.tags.map((tag) => (
                      <span class="bg-primary-light text-primary text-xs font-semibold px-3 py-1 rounded-full">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>

        <h2>Über Emel Şimşek-Uçar</h2>
        <p>
          Emel Şimşek-Uçar ist <strong>staatlich anerkannte Logopädin</strong> und Gründerin der
          Praxis für Logopädie Şimşek in Duisburg-Mitte. Mit mehr als zehn Jahren klinischer
          Erfahrung begleitet sie Kinder, Jugendliche und Erwachsene auf dem Weg zu mehr
          Kommunikationsfähigkeit.
        </p>
        <p>
          Als zweisprachig aufgewachsene Therapeutin mit Deutsch und Türkisch auf
          muttersprachlichem Niveau kennt sie die Herausforderungen mehrsprachiger Familien
          aus eigener Perspektive. Diese Erfahrung fließt direkt in die Diagnostik und Therapie ein:
          Mehrsprachigkeit wird als Ressource behandelt – nicht als Problem.
        </p>

        <h2>Schwerpunkte</h2>
        <ul>
          <li><strong>Kindersprachtherapie:</strong> Sprachentwicklungsverzögerungen, Lautbildungsstörungen, Stottern, LRS-Prävention</li>
          <li><strong>Mehrsprachige Diagnostik DE/TR:</strong> Standardisierte Sprachstandserhebung in beiden Sprachen – um Sprachstörung von sprachlicher Unsicherheit zuverlässig zu unterscheiden</li>
          <li><strong>Erwachsenentherapie:</strong> Aphasie, Dysarthrie, Stimmstörungen, Schluckstörungen nach neurologischen Erkrankungen</li>
          <li><strong>Frühförderung:</strong> Logopädische Intervention ab dem Säuglingsalter – je früher, desto wirksamer</li>
          <li><strong>Stimmtherapie:</strong> Funktionelle und organische Stimmstörungen, ISTP-Methode, Lax Vox</li>
        </ul>

        <h2>Therapiephilosophie</h2>
        <p>
          Logopädische Therapie ist dann am wirksamsten, wenn sie im Alltag der Patientin
          oder des Patienten verankert ist. Emel Şimşek-Uçar legt daher großen Wert auf
          <strong>Elternarbeit und Angehörigenberatung</strong>: Übungen und Strategien, die zu
          Hause, in der Kita oder im Alltag fortgeführt werden können, machen den Unterschied
          zwischen langsamen Fortschritten und echtem Therapieerfolg.
        </p>
        <p>
          Befundberichte, Therapiepläne und Elterngespräche können vollständig auf
          Türkisch oder Deutsch geführt werden – damit Familien die Therapie wirklich
          verstehen und aktiv unterstützen können.
        </p>

        <h2>Über Mara Nießalla</h2>
        <p>
          Mara Nießalla ergänzt das Team als <strong>staatlich geprüfte Logopädin</strong>.
          Ihr Schwerpunkt liegt in der Therapie von Kindern und Jugendlichen, insbesondere
          bei Fragen rund um Sprachentwicklung, Artikulation und alltagsnahe Übungsstrategien.
        </p>
        <p>
          Sie begleitet Familien vom Erstgespräch bis zum Therapieabschluss mit klarer
          Diagnostik, nachvollziehbarer Beratung und Übungen, die sich gut in den Alltag
          übertragen lassen.
        </p>

        <h2>Sprachen</h2>
        <p>
          Die Praxis bietet vollständige Diagnostik, Beratung und Therapie auf <strong>Deutsch und Türkisch</strong>.
          Dies ist besonders wertvoll für zweisprachig aufwachsende Kinder und türkischsprachige
          Patientinnen und Patienten, die in ihrer Muttersprache betreut werden möchten.
        </p>

        <div class="info-box">
          <p>
            <strong>Wir wachsen:</strong> Haben Sie Interesse, unser Team zu verstärken?
            Wir suchen engagierte Logopädinnen und Logopäden.
            <a href="/karriere/">Zur Stellenanzeige →</a>
          </p>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="/kontakt/" class="btn btn-primary w-full sm:flex-1 justify-center">Termin anfragen</a>
          <a href="/therapieangebot/" class="btn btn-ghost w-full sm:flex-1 justify-center">Unser Therapieangebot</a>
        </div>

      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .prose-section :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-section :global(p) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-section :global(ul) {
    list-style: none;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose-section :global(ul li) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    padding-left: 1.5rem;
    position: relative;
  }
  .prose-section :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .prose-section :global(strong) { font-weight: 600; color: var(--color-text); }
  .prose-section :global(a) { color: var(--color-primary); }
  .info-box {
    background: var(--color-primary-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 6px 6px 0;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }
</style>
