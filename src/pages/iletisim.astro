---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://logopaedie-simsek.de';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${siteUrl}/anasayfa` },
    { "@type": "ListItem", "position": 2, "name": "İletişim", "item": `${siteUrl}/iletisim` }
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Praxis für Logopädie Şimşek",
  "url": siteUrl,
  "telephone": "+4920334868690",
  "email": "info@logopaedie-simsek.de",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tonhallenstraße 21",
    "addressLocality": "Duisburg",
    "postalCode": "47051",
    "addressCountry": "DE"
  },
  "openingHours": "Mo-Fr 08:00-18:00",
  "hasMap": "https://www.google.com/maps/dir/?api=1&destination=Tonhallenstra%C3%9Fe+21%2C+47051+Duisburg"
};
---

<Layout
  title="İletişim & Konum – Praxis für Logopädie Şimşek Duisburg"
  description="Duisburg'daki Şimşek Logopedi Muayenehanesi ile iletişime geçin. Randevu talebi, adres, telefon, e-posta, çalışma saatleri ve konum bilgisi. Ana tren garına yürüme mesafesinde."
  lang="tr"
  additionalSchemas={[breadcrumbSchema, localBusinessSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/kontakt` },
    { lang: 'tr', url: `${siteUrl}/iletisim` },
    { lang: 'x-default', url: `${siteUrl}/kontakt` },
  ]}
>
  <Header lang="tr" alternateUrl="/kontakt" />
  <Nav lang="tr" alternateUrl="/kontakt" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="İçerik Yolu">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/anasayfa/" class="hover:text-primary transition-colors">Ana Sayfa</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">İletişim</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-14 pb-10 border-b border-border">
      <div class="container">
        <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold leading-[1.1] text-text mb-4">
          İletişim & Konum
        </h1>
        <p class="text-text-muted text-lg">
          Tonhallenstraße 21, 47051 Duisburg · 3. kat · Asansör mevcut
        </p>
      </div>
    </section>

    <!-- Content -->
    <div class="container py-14">
      <div class="grid md:grid-cols-2 gap-12 items-start">

        <!-- Phone-only appointment CTA -->
        <div class="bg-surface border border-border rounded-md p-9 shadow-sm flex flex-col gap-7">
          <!-- Notice -->
          <div class="bg-primary-light border border-[rgba(42,127,111,.25)] rounded-sm px-5 py-4 flex gap-3 items-start">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-sm text-primary leading-[1.65]">Randevular yalnızca <strong>telefonla</strong> alınmaktadır. E-posta veya form üzerinden randevu talep edilememektedir.</p>
          </div>

          <!-- Large phone CTA -->
          <div class="flex flex-col items-center text-center gap-5 py-4">
            <div class="w-18 h-18 bg-primary rounded-full flex items-center justify-center text-white shadow-[0_8px_24px_rgba(42,127,111,.35)]" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h2 class="font-display text-[1.5rem] font-semibold text-text mb-1.5">Hemen Arayın</h2>
              <p class="text-text-muted text-[.9375rem] leading-[1.65] max-w-xs">Bizi doğrudan arayın – size yardımcı olmaktan memnuniyet duyarız.</p>
            </div>
            <a href="tel:+4920334868690" class="btn btn-primary w-full justify-center text-[1.0625rem] py-4">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              0203 – 34 86 86 90
            </a>
            <p class="text-sm text-text-muted">Ulaşılabilirlik: <strong class="text-text">Pzt–Cum 08:00–18:00</strong></p>
          </div>

          <!-- Bilingual note -->
          <div class="border-t border-border pt-5 text-[.875rem] text-text-muted text-center leading-[1.65]">
            Danışmanlık <strong>Türkçe</strong> olarak da mümkündür.
          </div>
        </div>

        <!-- Contact info + directions -->
        <div class="flex flex-col gap-5">
          <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start">
            <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Telefon</div>
              <div class="text-[.9375rem] font-semibold text-text"><a class="text-primary hover:underline" href="tel:+4920334868690">0203 – 34 86 86 90</a></div>
              <div class="text-[.8125rem] text-text-muted mt-0.5">Pzt–Cum 08:00–18:00</div>
            </div>
          </div>
          <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start">
            <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">E-Posta</div>
              <div class="text-[.9375rem] font-semibold text-text"><a class="text-primary hover:underline" href="mailto:info@logopaedie-simsek.de">info@logopaedie-simsek.de</a></div>
              <div class="text-[.8125rem] text-text-muted mt-0.5">Genel sorular için · Randevu alınmaz</div>
            </div>
          </div>
          <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start">
            <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Adres</div>
              <address class="not-italic">
                <div class="text-[.9375rem] font-semibold text-text">Tonhallenstraße 21, 47051 Duisburg</div>
                <div class="text-[.8125rem] text-text-muted mt-0.5">3. kat · Asansör mevcut</div>
              </address>
            </div>
          </div>

          <div class="bg-surface border border-border rounded-md p-6 shadow-sm">
            <h3 class="font-display text-base font-semibold text-text mb-3">Ulaşım</h3>
            <p class="text-sm text-text-muted mb-3">
              Duisburg Ana Tren Garı'na yalnızca <strong class="text-text">2 dakika yürüme mesafesi</strong>.<br>
              U79 · König-Heinrich-Platz · S-Bahn / RE / RB Duisburg Hbf
            </p>
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=Tonhallenstra%C3%9Fe+21%2C+47051+Duisburg"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary w-full justify-center"
            >
              Google Maps'te Aç
            </a>
          </div>

          <div class="bg-surface border border-border rounded-md p-5 text-sm">
            <p class="font-semibold text-text mb-1">İki Dilli Muayenehane</p>
            <p class="text-text-muted">Randevu ve danışmanlık Türkçe olarak da mümkündür.</p>
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer lang="tr" />
</Layout>
