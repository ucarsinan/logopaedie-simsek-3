---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import maraImg from '../../assets/therapy/team-mara-niessalla.png';

const siteUrl = 'https://logopaedie-simsek.de';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Mara Nießalla",
  "jobTitle": "Staatlich geprüfte Logopädin",
  "url": `${siteUrl}/team/mara-niessalla`,
  "description": "Staatlich geprüfte Logopädin in der Praxis für Logopädie Şimşek in Duisburg. Schwerpunkt Sprachentwicklung bei Kindern und Jugendlichen.",
  "worksFor": {
    "@type": "MedicalOrganization",
    "name": "Praxis für Logopädie Şimşek",
    "url": siteUrl
  },
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Logopädin",
    "occupationalCategory": "Therapeutin",
    "skills": "Kindersprachtherapie, Sprachentwicklung, Diagnostik, Therapieplanung"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Team", "item": `${siteUrl}/team` },
    { "@type": "ListItem", "position": 3, "name": "Mara Nießalla", "item": `${siteUrl}/team/mara-niessalla` }
  ]
};

const schwerpunkte = [
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Kindersprachtherapie',
    text: 'Gezielte Förderung von Sprache, Sprechen und Kommunikation bei Kindern und Jugendlichen',
  },
  {
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
    title: 'Sprachentwicklung',
    text: 'Begleitung und Unterstützung bei verzögerter oder auffälliger Sprachentwicklung',
  },
  {
    icon: `<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>`,
    title: 'Diagnostik',
    text: 'Strukturierte Eingangsdiagnostik zur genauen Einschätzung des Sprachentwicklungsstands',
  },
  {
    icon: `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    title: 'Alltagsnahe Übungsstrategien',
    text: 'Übungen, die sich einfach in Kita und Alltag integrieren lassen — für nachhaltigen Therapieerfolg',
  },
];
---

<Layout
  title="Mara Nießalla – Staatlich geprüfte Logopädin | Praxis Şimşek Duisburg"
  description="Mara Nießalla, staatlich geprüfte Logopädin bei der Praxis für Logopädie Şimşek in Duisburg. Schwerpunkt Sprachentwicklung, Diagnostik und Therapie bei Kindern und Jugendlichen."
  additionalSchemas={[personSchema, breadcrumbSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/team/mara-niessalla` },
    { lang: 'x-default', url: `${siteUrl}/team/mara-niessalla` },
  ]}
>
  <Header />
  <Nav />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </li>
          <li><a href="/team/" class="hover:text-primary transition-colors">Team</a></li>
          <li aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </li>
          <li class="text-text font-medium" aria-current="page">Mara Nießalla</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt border-b border-border py-12 pb-10">
      <div class="container">
        <span class="text-xs font-semibold tracking-[.12em] uppercase text-text-muted mb-3 block">
          Therapeutin · Logopädie Şimşek Duisburg
        </span>
        <h1 class="font-display text-[clamp(2.25rem,5vw,3.25rem)] font-semibold text-text leading-tight mb-3">
          Mara Nießalla
        </h1>
        <p class="text-primary font-semibold text-[1.0625rem] mb-4">
          Staatlich geprüfte Logopädin
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-primary-light text-primary text-xs font-semibold px-3 py-1.5 rounded-full">Kinder &amp; Jugendliche</span>
          <span class="bg-surface border border-border text-text-muted text-xs font-semibold px-3 py-1.5 rounded-full">Sprachentwicklung</span>
          <span class="bg-surface border border-border text-text-muted text-xs font-semibold px-3 py-1.5 rounded-full">Diagnostik &amp; Therapie</span>
        </div>
      </div>
    </section>

    <!-- Profile Content -->
    <div class="container py-12">
      <div class="profile-grid">

        <!-- Sidebar: Photo + Quick Facts -->
        <aside class="profile-sidebar">
          <div class="rounded-[var(--radius-lg)] overflow-hidden bg-surface-2 mb-5 shadow-sm">
            <Image
              src={maraImg}
              alt="Mara Nießalla – Logopädin in der Praxis Şimşek Duisburg"
              class="w-full object-cover object-top"
              widths={[380, 520, 640]}
              sizes="(max-width: 860px) 100vw, 380px"
              loading="eager"
              decoding="async"
            />
          </div>

          <!-- Quick facts -->
          <div class="bg-surface border border-border rounded-[var(--radius-md)] p-5 mb-4">
            <h2 class="font-semibold text-sm text-text mb-4 tracking-[.04em] uppercase text-text-muted">Kurzprofil</h2>
            <ul class="space-y-3.5">
              <li class="flex items-start gap-3">
                <span class="w-8 h-8 rounded-lg bg-primary-light flex items-center justify-center shrink-0 mt-0.5">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </span>
                <div>
                  <div class="text-[.7rem] text-text-muted font-medium uppercase tracking-wide">Qualifikation</div>
                  <div class="text-sm font-semibold text-text">Staatlich geprüfte Logopädin</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-8 h-8 rounded-lg bg-primary-light flex items-center justify-center shrink-0 mt-0.5">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </span>
                <div>
                  <div class="text-[.7rem] text-text-muted font-medium uppercase tracking-wide">Schwerpunkt</div>
                  <div class="text-sm font-semibold text-text">Kinder &amp; Jugendliche</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-8 h-8 rounded-lg bg-primary-light flex items-center justify-center shrink-0 mt-0.5">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                <div>
                  <div class="text-[.7rem] text-text-muted font-medium uppercase tracking-wide">Standort</div>
                  <div class="text-sm font-semibold text-text">Duisburg-Mitte</div>
                </div>
              </li>
            </ul>
          </div>

          <a href="/kontakt/" class="btn btn-primary w-full justify-center">Termin anfragen</a>
        </aside>

        <!-- Bio content -->
        <div class="prose-section">

          <h2>Über Mara Nießalla</h2>
          <p>
            Mara Nießalla ergänzt das Team als <strong>staatlich geprüfte Logopädin</strong>.
            Ihr Schwerpunkt liegt in der Therapie von Kindern und Jugendlichen, insbesondere
            bei Fragen rund um Sprachentwicklung, Artikulation und alltagsnahe Übungsstrategien.
          </p>
          <p>
            Sie begleitet Familien vom Erstgespräch bis zum Therapieabschluss mit klarer
            Diagnostik, nachvollziehbarer Beratung und Übungen, die sich gut in den Alltag
            übertragen lassen.
          </p>

          <h2>Schwerpunkte</h2>
          <div class="focus-grid">
            {schwerpunkte.map((item) => (
              <div class="focus-card">
                <div class="focus-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                </div>
                <div>
                  <div class="focus-title">{item.title}</div>
                  <div class="focus-text">{item.text}</div>
                </div>
              </div>
            ))}
          </div>

          <h2>Therapieansatz</h2>
          <p>
            Im Mittelpunkt jeder Therapiestunde steht das Kind mit seinen individuellen
            Stärken und Bedürfnissen. Mara Nießalla legt besonderen Wert auf
            <strong>alltagsnahe Übungsstrategien</strong>, die Eltern und Bezugspersonen
            einfach in den Alltag einbauen können — weil Therapie auch zu Hause stattfindet.
          </p>
          <p>
            Klare Befundkommunikation und transparente Therapieplanung ermöglichen es
            Familien, aktiv am Therapieprozess teilzunehmen und den Fortschritt
            zu begleiten.
          </p>

          <div class="mt-8">
            <a href="/therapieangebot/" class="btn btn-ghost justify-center">Unser Therapieangebot</a>
          </div>

        </div>
      </div>
    </div>

    <!-- Back to team -->
    <div class="border-t border-border bg-bg-alt py-6">
      <div class="container">
        <a href="/team/" class="inline-flex items-center gap-2 text-sm font-semibold text-text-muted hover:text-primary transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
          Zurück zum Team
        </a>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .profile-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .profile-sidebar {
    position: sticky;
    top: calc(var(--header-h) + var(--nav-h) + 1.5rem);
  }
  @media (max-width: 860px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }
    .profile-sidebar {
      position: static;
    }
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin: 1rem 0 1.75rem;
  }
  @media (max-width: 600px) {
    .focus-grid { grid-template-columns: 1fr; }
  }
  .focus-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .focus-icon {
    width: 2rem;
    height: 2rem;
    background: var(--color-primary-light);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .focus-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .focus-text {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .prose-section :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-section :global(h2:first-child) { margin-top: 0; }
  .prose-section :global(p) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-section :global(strong) { font-weight: 600; color: var(--color-text); }
</style>
