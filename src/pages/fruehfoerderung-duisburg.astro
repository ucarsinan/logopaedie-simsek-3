---
import ServicePage from '../layouts/ServicePage.astro';
import { Image } from 'astro:assets';
import fruehImg from '../assets/therapy/fruehfoerderung-logopaedie-kind-duisburg.webp';

const siteUrl = 'https://logopaedie-simsek.de';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Logopädische Frühförderung Duisburg – Sprachtherapie für Kleinkinder",
  "description": "Logopädische Frühförderung in Duisburg für Kinder ab dem Säuglingsalter. Früherkennung und Behandlung von Sprachentwicklungsverzögerungen. Zweisprachig DE/TR.",
  "url": `${siteUrl}/fruehfoerderung-duisburg`,
  "about": { "@type": "MedicalCondition", "name": "Sprachentwicklungsverzögerung" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Frühförderung Duisburg", "item": `${siteUrl}/fruehfoerderung-duisburg` }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Ab welchem Alter ist logopädische Frühförderung sinnvoll?",
      "acceptedAnswer": { "@type": "Answer", "text": "Logopädische Frühförderung ist ab dem Säuglingsalter möglich – auch bei Saugstörungen von Neugeborenen. Bei Sprachentwicklungsverzögerungen empfehlen wir eine Abklärung, sobald ein Kind mit 18–24 Monaten noch keine ersten Wörter spricht oder mit 3 Jahren noch keine Zwei-Wort-Sätze bildet." }
    },
    {
      "@type": "Question",
      "name": "Übernimmt die Krankenkasse die Kosten für Frühförderung?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja. Logopädische Frühförderung ist ein Heilmittel und wird bei vorliegender ärztlicher Heilmittelverordnung von gesetzlichen und privaten Krankenkassen übernommen. Kinder unter 18 Jahren sind vollständig von Zuzahlungen befreit." }
    },
    {
      "@type": "Question",
      "name": "Welcher Arzt kann Frühförderung verordnen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Kinderärzte, Allgemeinmediziner, Kinderpsychiater, Neurologen und Phoniatriker können eine Heilmittelverordnung für logopädische Frühförderung ausstellen." }
    },
    {
      "@type": "Question",
      "name": "Wächst sich eine Sprachentwicklungsverzögerung von selbst aus?",
      "acceptedAnswer": { "@type": "Answer", "text": "Manche sogenannten 'Late Talker' holen den Rückstand ohne Therapie auf. Ein Teil der Kinder entwickelt jedoch ohne Förderung anhaltende Sprachprobleme, die sich auf die schulische Entwicklung auswirken. Eine frühzeitige logopädische Abklärung gibt Sicherheit und verschafft wertvolle Zeit." }
    }
  ]
};
---

<ServicePage
  title="Logopädische Frühförderung Duisburg – Sprachtherapie für Kleinkinder"
  description="Logopädische Frühförderung in Duisburg ab dem Säuglingsalter. Früherkennung und Therapie von Sprachentwicklungsverzögerungen für Kinder bis 6 Jahre. Zweisprachig DE/TR."
  serviceTitle="Frühförderung Duisburg – Logopädie für Kleinkinder"
  breadcrumbLabel="Frühförderung Duisburg"
  tags={['Kleinkinder', 'Frühförderung', 'Sprachentwicklung', 'DE/TR']}
  additionalSchemas={[schema, faqSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/fruehfoerderung-duisburg/` },
    { lang: 'x-default', url: `${siteUrl}/fruehfoerderung-duisburg/` },
  ]}
  relatedServices={[
    { title: 'Sprachstörungen', href: '/therapie/sprachstoerungen/', description: 'Sprachentwicklungsverzögerung, Aphasie, Frühförderung' },
    { title: 'Therapie für Kinder', href: '/therapie/kinder-und-jugendliche/', description: 'Das vollständige Therapieangebot für Kinder und Jugendliche' },
    { title: 'Türkische Logopädie', href: '/tuerkische-logopaedie-duisburg/', description: 'Zweisprachige Therapie auf Deutsch und Türkisch' },
  ]}
>
  <section class="bento-page" aria-label="Logopädische Frühförderung in Duisburg">
    <div class="bento-grid">
      <article class="bento-card bento-card--image">
        <Image
          src={fruehImg}
          alt="Spielerische Frühförderung für Kleinkinder in der logopädischen Praxis Şimşek Duisburg"
          class="bento-card__image"
          widths={[540, 900, 1200]}
          sizes="(max-width: 960px) 100vw, 55vw"
          loading="eager"
          decoding="async"
        />
        <div class="bento-card__overlay">
          <span class="bento-eyebrow">0-6 Jahre</span>
          <h2>Früh handeln, Sprache spielerisch stärken</h2>
          <p>
            Logopädische Frühförderung erkennt und behandelt sprachliche Auffälligkeiten,
            bevor sie den Alltag, den Schuleintritt oder die soziale Teilhabe erschweren.
          </p>
        </div>
      </article>

      <article class="bento-card bento-card--highlight">
        <span class="bento-eyebrow">Überblick</span>
        <h2>Wann Frühförderung sinnvoll ist</h2>
        <ul>
          <li><strong>Säuglinge:</strong> Saug-, Trink- oder Fütterstörungen</li>
          <li><strong>Mit 12 Monaten:</strong> kein Zeigen, Winken oder erstes "Mama" / "Papa"</li>
          <li><strong>Mit 18 Monaten:</strong> weniger als 10 Wörter im aktiven Wortschatz</li>
          <li><strong>Mit 24 Monaten:</strong> noch keine Zwei-Wort-Verbindungen</li>
          <li><strong>Mit 3 Jahren:</strong> das Kind wird von Fremden kaum verstanden</li>
          <li><strong>Mit 4-5 Jahren:</strong> Grammatik-, Wortschatz- oder Ausspracheprobleme</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Was bedeutet das?</span>
        <h2>Sprachliche Grundlagen entstehen in den ersten Lebensjahren</h2>
        <p>
          Frühförderung bezeichnet die frühe Diagnostik und Therapie bei Säuglingen,
          Kleinkindern und Vorschulkindern. Das Gehirn ist in dieser Phase besonders
          lernfähig, deshalb können passende Impulse viel bewirken.
        </p>
      </article>

      <article class="bento-card bento-card--accent">
        <span class="bento-eyebrow">Wichtig</span>
        <h2>Unsicherheit ist kein Grund zu warten.</h2>
        <p>
          Wenn Sie das Gefühl haben, dass die Sprachentwicklung Ihres Kindes nicht stimmt,
          empfehlen wir eine logopädische Abklärung. Sie dauert ca. 45-60 Minuten und gibt
          Ihnen Klarheit.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Mehrsprachigkeit</span>
        <h2>Deutsch und Türkisch zuverlässig einschätzen</h2>
        <p>
          Bei mehrsprachig aufwachsenden Kindern ist entscheidend, ob Rückstände in einer
          Sprache oder in allen Sprachen bestehen. Unsere Diagnostik auf Deutsch und Türkisch
          hilft, eine Sprachentwicklungsstörung von normalem bilingualem Erwerb zu unterscheiden.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Erster Termin</span>
        <h2>So läuft die Frühförderung in unserer Praxis ab</h2>
        <ul>
          <li>Ausführliches Elterngespräch zur bisherigen Entwicklung und Alltagssituation</li>
          <li>Spielerische, altersgerechte Diagnostik statt Prüfungssituation</li>
          <li>Standardisierte Tests je nach Alter und Fragestellung</li>
          <li>Besprechung der Ergebnisse mit klaren nächsten Schritten</li>
          <li>Konkrete Hinweise, wie Eltern die Entwicklung zu Hause unterstützen können</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Therapie</span>
        <h2>Spielerisch, alltagsnah und mit Elternberatung</h2>
        <p>
          Kinder lernen Sprache über Beziehung, Spiel und Wiederholung. Deshalb verbinden
          wir gezielte Therapieziele mit Materialien, die Kinder motivieren, und beziehen
          Eltern eng in die Förderung ein.
        </p>
      </article>

      <article class="bento-card bento-card--soft">
        <span class="bento-eyebrow">Kosten</span>
        <h2>Kinder unter 18 Jahren sind zuzahlungsbefreit</h2>
        <p>
          Logopädische Frühförderung ist ein Heilmittel. Bei ärztlicher Verordnung übernehmen
          gesetzliche und private Krankenkassen die Kosten.
        </p>
        <a class="bento-link" href="/kostenuebernahme/">Kosten & Kostenübernahme</a>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Verordnung</span>
        <h2>Diese Ärzte können Logopädie verordnen</h2>
        <ul>
          <li>Kinderärzte und Allgemeinmediziner</li>
          <li>HNO-Ärzte und Phoniatriker</li>
          <li>Kinderpsychiater und Neurologen</li>
          <li>Bei Fütter- oder Schluckthemen auch spezialisierte Fachärzte</li>
        </ul>
      </article>

      <article class="bento-card bento-card--wide bento-card--highlight">
        <span class="bento-eyebrow">Kontakt</span>
        <h2>Abklärung für Ihr Kind in Duisburg vereinbaren</h2>
        <p>
          Sprechen Sie uns an, wenn Sie Fragen zur Sprachentwicklung, Mehrsprachigkeit oder
          zur Verordnung haben. Beratung ist auf Deutsch und Türkisch möglich.
        </p>
        <a class="bento-link" href="/kontakt/">Termin anfragen</a>
      </article>
    </div>
  </section>
</ServicePage>

<style>
  .bento-page {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    grid-auto-flow: row dense;
  }

  .bento-card {
    grid-column: span 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(28, 25, 22, 0.06);
    min-height: 100%;
  }

  .bento-card--image {
    grid-column: span 6;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 22rem;
    border: 0;
  }

  .bento-card--highlight {
    grid-column: span 6;
    background: linear-gradient(180deg, rgba(112, 90, 74, 0.08), rgba(255, 255, 255, 0.96));
  }

  .bento-card--wide {
    grid-column: span 8;
  }

  .bento-card--accent {
    background: var(--color-primary);
    color: white;
  }

  .bento-card--soft {
    background: var(--color-primary-light);
  }

  .bento-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bento-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(24, 18, 14, 0.08) 10%,
      rgba(24, 18, 14, 0.76) 100%
    );
  }

  .bento-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .bento-card--image .bento-eyebrow,
  .bento-card--accent .bento-eyebrow {
    color: rgba(255, 255, 255, 0.84);
  }

  .bento-grid .bento-card :global(h2),
  .bento-grid .bento-card__overlay :global(h2) {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
    color: var(--color-text);
  }

  .bento-grid .bento-card__overlay :global(h2) {
    color: white;
    max-width: 20ch;
  }

  .bento-card__overlay :global(p),
  .bento-card__overlay :global(p strong),
  .bento-card__overlay :global(p a) {
    color: #ffffff !important;
  }

  .bento-grid .bento-card :global(p),
  .bento-grid .bento-card :global(ul),
  .bento-grid .bento-card__overlay :global(p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .bento-grid .bento-card__overlay :global(p) {
    max-width: 56ch;
  }

  .bento-grid .bento-card :global(ul) {
    display: grid;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .bento-grid .bento-card :global(li) {
    position: relative;
    padding-left: 1rem;
  }

  .bento-grid .bento-card :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .bento-grid .bento-card--accent :global(h2),
  .bento-grid .bento-card--accent :global(p),
  .bento-grid .bento-card--accent :global(a),
  .bento-grid .bento-card--accent .bento-eyebrow {
    color: white;
  }

  .bento-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1.1rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .bento-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 960px) {
    .bento-card,
    .bento-card--image,
    .bento-card--highlight,
    .bento-card--wide {
      grid-column: span 12;
    }

    .bento-card--image {
      min-height: 19rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      gap: 0.875rem;
    }

    .bento-card {
      padding: 1.2rem;
    }

    .bento-card--image {
      min-height: 0;
      padding: 1rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .bento-card__overlay {
      position: static;
      padding: 1rem 0 0;
      background: none;
    }

    .bento-card__image {
      height: 13.5rem;
      border-radius: 6px;
    }

    .bento-card--image .bento-eyebrow {
      color: var(--color-primary);
    }

    .bento-grid .bento-card__overlay :global(h2) {
      color: var(--color-text);
      max-width: none;
    }

    .bento-card__overlay :global(p),
    .bento-card__overlay :global(p strong),
    .bento-card__overlay :global(p a) {
      color: var(--color-text-muted) !important;
    }

    .bento-card__overlay :global(strong),
    .bento-card__overlay :global(a) {
      color: var(--color-text) !important;
    }
  }
</style>
