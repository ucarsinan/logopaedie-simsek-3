---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const services = [
  {
    title: 'Sprachstörungen',
    description: 'Sprachentwicklungsverzögerungen, Aphasie nach Schlaganfall, Frühförderung – für Kinder und Erwachsene.',
    tags: ['Sprachentwicklung', 'Aphasie', 'Frühförderung'],
    href: '/therapieangebot/sprachstoerungen',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'Sprechstörungen',
    description: 'Stottern, Poltern, Lispeln und motorisch bedingte Sprechstörungen wie Dysarthrie oder Sprechapraxie.',
    tags: ['Stottern', 'Lispeln', 'Dysarthrie'],
    href: '/therapieangebot/sprechstoerungen',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
  {
    title: 'Stimmtherapie',
    description: 'Funktionelle und organische Stimmstörungen – bei Heiserkeit, Dysphonie, nach Operationen oder bei Berufssprechern.',
    tags: ['Dysphonie', 'Heiserkeit', 'Stimmbildung'],
    href: '/therapieangebot/stimmtherapie',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  },
  {
    title: 'Schluckstörungen (Dysphagie)',
    description: 'Diagnostik und Therapie von Dysphagie bei Erwachsenen und Kindern – nach Schlaganfall, bei Parkinson oder anderen neurologischen Erkrankungen.',
    tags: ['Dysphagie', 'Schlucken', 'Neurologisch'],
    href: '/therapieangebot/schluckstoerungen',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
  {
    title: 'Frühförderung Duisburg',
    description: 'Logopädische Früherkennung und Therapie für Kleinkinder und Vorschulkinder ab dem Säuglingsalter – spielbasiert und elternzentriert.',
    tags: ['Kleinkinder', '0–6 Jahre', 'Frühförderung'],
    href: '/fruehfoerderung-duisburg/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 1 0 0 10A5 5 0 0 0 12 2z"/><path d="M6 20v-1a6 6 0 0 1 12 0v1"/><path d="M3 11h2M19 11h2"/></svg>`,
  },
  {
    title: 'Hausbesuche Duisburg',
    description: 'Logopädie bei Ihnen zu Hause – für mobilitätseingeschränkte Patienten, Senioren und Pflegebedürftige. Therapie im vertrauten Lebensumfeld.',
    tags: ['Hausbesuche', 'Senioren', 'Neurologisch'],
    href: '/hausbesuche-duisburg/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
];
---

<Layout
  title="Therapieangebot | Praxis für Logopädie Şimşek Duisburg"
  description="Das Therapieangebot der Praxis Şimşek in Duisburg: Sprachstörungen, Sprechstörungen, Stimmtherapie und Dysphagie – für Kinder und Erwachsene."
  hreflangAlternates={[
    { lang: 'de', url: 'https://logopaedie-simsek.de/therapieangebot' },
    { lang: 'tr', url: 'https://logopaedie-simsek.de/terapi/' },
    { lang: 'x-default', url: 'https://logopaedie-simsek.de/therapieangebot' },
  ]}
>
  <Header alternateUrl="/terapi/" />
  <Nav alternateUrl="/terapi/" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">
    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Therapieangebot</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-14 pb-10 border-b border-border">
      <div class="container">
        <span class="text-xs font-semibold tracking-widest uppercase text-primary">Leistungsangebot</span>
        <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold leading-[1.1] text-text mt-3 mb-4">Alle Bereiche der Logopädie</h1>
        <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-2xl">
          In unserer Praxis in Duisburg behandeln wir das vollständige Spektrum logopädischer Störungsbilder –
          für Kinder, Erwachsene und Senioren. Auf Deutsch und Türkisch.
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-14 bg-bg">
      <div class="container">
        <div class="grid grid-cols-2 gap-6 max-[640px]:grid-cols-1">
          {services.map(service => (
            <a
              href={service.href}
              class="bg-surface border border-border rounded-md p-8 shadow-sm hover:border-primary hover:-translate-y-1 hover:shadow-md transition-[transform,box-shadow,border-color] duration-200 flex flex-col gap-4 no-underline group"
            >
              <div class="w-14 h-14 rounded-sm bg-primary-light flex items-center justify-center text-primary" aria-hidden="true" set:html={service.icon} />
              <div>
                <h2 class="font-display text-xl font-semibold text-text group-hover:text-primary transition-colors mb-2">{service.title}</h2>
                <p class="text-[.9375rem] text-text-muted leading-[1.65]">{service.description}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                {service.tags.map(tag => (
                  <span class="bg-primary-light text-primary text-xs font-semibold px-2.5 py-1 rounded-full">{tag}</span>
                ))}
              </div>
              <span class="text-sm font-semibold text-primary inline-flex items-center gap-1 mt-auto">
                Mehr erfahren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- USP Strip -->
    <section class="py-14 bg-primary" aria-label="Unser Alleinstellungsmerkmal">
      <div class="container text-center flex flex-col items-center gap-5">
        <h2 class="font-display text-[clamp(1.5rem,3vw,2rem)] font-semibold text-white">Zweisprachige Therapie auf Deutsch und Türkisch</h2>
        <p class="text-white/80 text-[1.0625rem] leading-[1.7] max-w-xl">
          Ein seltenes Angebot im Ruhrgebiet – besonders wertvoll für mehrsprachig aufwachsende Kinder
          und türkischsprachige Erwachsene. Wir schließen eine wichtige Versorgungslücke.
        </p>
        <a href="/#kontakt" class="btn btn-outline-white">Termin anfragen</a>
      </div>
    </section>

    <!-- Back link -->
    <div class="container py-10">
      <a href="/" class="inline-flex items-center gap-2 text-primary font-medium hover:underline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Zurück zur Startseite
      </a>
    </div>
  </main>
  <Footer />
</Layout>
