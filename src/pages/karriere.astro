---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://logopaedie-simsek.de';

const jobSchema = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": "Logopädin / Logopäde (m/w/d)",
  "description": "Wir suchen eine engagierte Logopädin / einen engagierten Logopäden für unsere Praxis in Duisburg. Voll- oder Teilzeit, überdurchschnittliches Gehalt, zweisprachiges Team.",
  "hiringOrganization": {
    "@type": "Organization",
    "name": "Praxis für Logopädie Şimşek",
    "sameAs": siteUrl
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Tonhallenstraße 21",
      "addressLocality": "Duisburg",
      "postalCode": "47051",
      "addressCountry": "DE"
    }
  },
  "employmentType": ["FULL_TIME", "PART_TIME"],
  "workHours": "Vollzeit oder Teilzeit möglich",
  "industry": "Logopädie / Sprachtherapie",
  "occupationalCategory": "Logopädin / Logopäde"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Karriere", "item": `${siteUrl}/karriere` }
  ]
};

const benefits = [
  { icon: "💰", title: "Überdurchschnittliches Gehalt", desc: "Faire und transparente Vergütung" },
  { icon: "🤝", title: "Strukturierte Einarbeitung", desc: "Wir begleiten Sie von Beginn an" },
  { icon: "💬", title: "Kollegiales Team", desc: "Offene Kommunikation, gegenseitige Unterstützung" },
  { icon: "🏢", title: "Moderne Praxisräume", desc: "Gut ausgestattete Therapieräume in zentraler Lage" },
  { icon: "📚", title: "Fortbildungsunterstützung", desc: "Wir fördern Ihre fachliche Weiterentwicklung" },
  { icon: "⏰", title: "Flexible Arbeitszeiten", desc: "Voll- oder Teilzeit nach Absprache" },
  { icon: "🚇", title: "Zentrale Lage", desc: "Direkt am Duisburger Hauptbahnhof, gut per ÖPNV erreichbar" },
];
---

<Layout
  title="Karriere – Praxis für Logopädie Şimşek Duisburg | Stellenangebote"
  description="Praxis für Logopädie Şimşek Duisburg sucht engagierte Logopädinnen und Logopäden. Überdurchschnittliches Gehalt, tolles Team, zweisprachige Praxis. Jetzt bewerben!"
  additionalSchemas={[jobSchema, breadcrumbSchema]}
>
  <Header />
  <Nav />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Karriere</li>
        </ol>
      </div>
    </nav>

    <!-- Bento Grid -->
    <section class="container py-10 pb-16">
      <div class="bento-grid">

        <!-- HERO CARD -->
        <div class="bento-card bento-hero">
          <div class="bento-hero__tags">
            <span class="tag tag--green">Duisburg</span>
            <span class="tag tag--green">Voll- / Teilzeit</span>
            <span class="tag tag--accent">Sofort verfügbar</span>
          </div>
          <h1 class="bento-hero__title">Karriere bei #TeamŞimşek</h1>
          <p class="bento-hero__subtitle">
            Wir suchen eine engagierte Logopädin oder einen engagierten Logopäden
            für unser zweisprachiges Team in Duisburg-Mitte.
          </p>
          <a href="mailto:info@logopaedie-simsek.de?subject=Bewerbung%20als%20Logop%C3%A4din%20%2F%20Logop%C3%A4de&body=Sehr%20geehrte%20Frau%20%C5%9Eim%C5%9Fek-U%C3%A7ar%2C%0A%0Ahiermit%20bewerbe%20ich%20mich%20auf%20die%20ausgeschriebene%20Stelle%20als%20Logop%C3%A4din%20%2F%20Logop%C3%A4de%20in%20Ihrer%20Praxis.%0A%0AMit%20freundlichen%20Gr%C3%BC%C3%9Fen%0A" class="bento-cta-btn">
            Jetzt bewerben
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 14 0M12 5l7 7-7 7"/></svg>
          </a>
          <div class="bento-hero__deco" aria-hidden="true"></div>
        </div>

        <!-- STATS CARD -->
        <div class="bento-card bento-stats">
          <p class="bento-stats__label">Erfahrung</p>
          <p class="bento-stats__number">10+</p>
          <p class="bento-stats__desc">Jahre Praxiserfahrung in Duisburg</p>
          <div class="bento-stats__divider"></div>
          <p class="bento-stats__label">Sprachen</p>
          <p class="bento-stats__langs">
            <span>🇩🇪 Deutsch</span>
            <span>🇹🇷 Türkisch</span>
          </p>
          <div class="bento-stats__divider"></div>
          <p class="bento-stats__label">Therapiebereiche</p>
          <p class="bento-stats__desc">Frühförderung bis Geriatrie</p>
        </div>

        <!-- ANFORDERUNGEN CARD -->
        <div class="bento-card bento-requirements">
          <div class="bento-section-tag">Was wir uns wünschen</div>
          <h2 class="bento-card__title">Ihr Profil</h2>
          <ul class="req-list">
            <li>
              <span class="req-check">✓</span>
              <span>Abgeschlossene staatliche Ausbildung als Logopädin / Logopäde</span>
            </li>
            <li>
              <span class="req-check">✓</span>
              <span>Selbstständige und flexible Arbeitsweise</span>
            </li>
            <li>
              <span class="req-check">✓</span>
              <span>Einfühlungsvermögen im Umgang mit Patientinnen und Patienten</span>
            </li>
            <li>
              <span class="req-check">✓</span>
              <span>Interesse an Kindersprachtherapie und/oder Aphasietherapie</span>
            </li>
            <li>
              <span class="req-check req-check--accent">+</span>
              <span>Türkischkenntnisse sind ein Plus, aber keine Voraussetzung</span>
            </li>
          </ul>
          <p class="req-welcome">Berufseinsteiger herzlich willkommen!</p>
        </div>

        <!-- ÜBER UNS CARD -->
        <div class="bento-card bento-about">
          <div class="bento-section-tag bento-section-tag--accent">Über uns</div>
          <h2 class="bento-card__title">Praxis Şimşek</h2>
          <p class="bento-about__text">
            Etablierte Logopädiepraxis in Duisburg-Mitte mit über zehn Jahren Erfahrung.
            Eine der wenigen Praxen in der Region mit vollständig zweisprachigem Angebot.
          </p>
          <div class="bento-about__tag-row">
            <span class="mini-tag">Frühförderung</span>
            <span class="mini-tag">Aphasie</span>
            <span class="mini-tag">Geriatrie</span>
            <span class="mini-tag">Kindertherapie</span>
          </div>
        </div>

        <!-- BENEFITS CARD (unified) -->
        <div class="bento-card bento-benefits-all">
          <div class="bento-benefits-all__header">
            <div class="bento-section-tag">Was wir bieten</div>
            <h2 class="bento-card__title bento-card__title--large">Ihre Vorteile</h2>
          </div>
          <div class="benefits-inner-grid">
            {benefits.map((b, i) => (
              <div class={`benefit-item benefit-item--${i}`}>
                <span class="benefit-icon">{b.icon}</span>
                <h3 class="benefit-title">{b.title}</h3>
                <p class="benefit-desc">{b.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- BEWERBUNG CTA CARD -->
        <div class="bento-card bento-apply">
          <div class="bento-apply__deco" aria-hidden="true"></div>
          <div class="bento-apply__layout">

            <!-- Left: Headline + CTAs -->
            <div class="bento-apply__left">
              <div class="bento-section-tag bento-section-tag--light">Bewerbung</div>
              <h2 class="bento-apply__title">Jetzt<br>durchstarten</h2>
              <p class="bento-apply__sub">
                Kein Formular, kein Portal. Einfach E-Mail mit Lebenslauf — der Rest kann nachgereicht werden.
              </p>
              <div class="bento-apply__actions">
                <a href="mailto:info@logopaedie-simsek.de?subject=Bewerbung%20als%20Logop%C3%A4din%20%2F%20Logop%C3%A4de&body=Sehr%20geehrte%20Frau%20%C5%9Eim%C5%9Fek-U%C3%A7ar%2C%0A%0Ahiermit%20bewerbe%20ich%20mich%20auf%20die%20ausgeschriebene%20Stelle%20als%20Logop%C3%A4din%20%2F%20Logop%C3%A4de%20in%20Ihrer%20Praxis.%0A%0AMit%20freundlichen%20Gr%C3%BC%C3%9Fen%0A" class="apply-btn apply-btn--primary">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  Bewerbung senden
                </a>
                <a href="tel:+4920334868690" class="apply-btn apply-btn--outline">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 12 19.79 19.79 0 0 1 1.15 3.4 2 2 0 0 1 3.12 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
                  0203 – 34 86 86 90
                </a>
              </div>
            </div>

            <!-- Right: Contact card -->
            <div class="bento-apply__right">
              <div class="bento-apply__contact-card">
                <div class="bento-apply__contact-header">
                  <div class="bento-apply__avatar" aria-hidden="true">EŞ</div>
                  <div>
                    <div class="bento-apply__name">Emel Şimşek-Uçar</div>
                    <div class="bento-apply__role">Praxisinhaberin · Ansprechpartnerin</div>
                  </div>
                </div>
                <div class="bento-apply__contact-rows">
                  <div class="contact-row">
                    <svg class="contact-row__ico" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>Tonhallenstraße 21, 47051 Duisburg</span>
                  </div>
                  <div class="contact-row">
                    <svg class="contact-row__ico" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <span>info@logopaedie-simsek.de</span>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- PRAKTIKUM — volle Zeile -->
        <div class="bento-card bento-note">
          <div class="bento-note__inner">
            <svg class="bento-note__ico" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            <div>
              <h3 class="bento-note__title">Praktikumsplätze</h3>
              <p class="bento-note__text">
                Derzeit können wir keine Praktikumsplätze für Studierende aus dem Ausland anbieten.
                Für inländische Anfragen kontaktieren Sie uns gerne direkt.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Bento Grid Layout ─── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto;
    gap: 12px;
  }

  /* ─── Base Card ─── */
  .bento-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .bento-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  /* ─── Hero Card ─── */
  .bento-hero {
    grid-column: span 2;
    background: var(--color-primary);
    border-color: var(--color-primary-dark);
    padding: 2.25rem;
  }
  .bento-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1.25rem;
  }
  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .tag--green {
    background: rgba(255,255,255,0.18);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.25);
  }
  .tag--accent {
    background: var(--color-accent);
    color: #fff;
  }
  .bento-hero__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .bento-hero__subtitle {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.65;
    margin-bottom: 1.75rem;
    max-width: 42ch;
  }
  .bento-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.625rem 1.375rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.18s, transform 0.18s;
  }
  .bento-cta-btn:hover {
    background: var(--color-bg-alt);
    transform: translateX(2px);
  }
  .bento-hero__deco {
    position: absolute;
    bottom: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    pointer-events: none;
  }

  /* ─── Stats Card ─── */
  .bento-stats {
    background: var(--color-bg-alt);
    border-color: var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .bento-stats__label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }
  .bento-stats__number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 4px;
  }
  .bento-stats__desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-bottom: 0;
  }
  .bento-stats__divider {
    width: 100%;
    height: 1px;
    background: var(--color-border);
    margin: 1rem 0;
  }
  .bento-stats__langs {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 0;
  }

  /* ─── Anforderungen Card ─── */
  .bento-requirements {
    grid-column: span 2;
  }
  .bento-section-tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-light);
    padding: 4px 10px;
    border-radius: 6px;
    margin-bottom: 0.875rem;
  }
  .bento-section-tag--accent {
    color: var(--color-accent);
    background: var(--color-accent-light);
  }
  .bento-section-tag--light {
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.15);
  }
  .bento-card__title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }
  .bento-card__title--large {
    font-size: 2rem;
    margin-bottom: 0;
  }
  .req-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }
  .req-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
  .req-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-primary-light);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .req-check--accent {
    background: var(--color-accent-light);
    color: var(--color-accent);
  }
  .req-welcome {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    background: var(--color-primary-light);
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius-sm);
    display: inline-block;
    margin-top: 0.25rem;
  }

  /* ─── Über uns Card ─── */
  .bento-about {
    background: var(--color-surface-2);
  }
  .bento-about__text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }
  .bento-about__tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .mini-tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 3px 10px;
    border-radius: 6px;
  }

  /* ─── Benefits Unified Card ─── */
  .bento-benefits-all {
    grid-column: span 3;
    background: var(--color-surface);
  }
  .bento-benefits-all__header {
    margin-bottom: 1.25rem;
  }
  .benefits-inner-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .benefit-item {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.125rem 1rem;
    transition: box-shadow 0.18s;
  }
  .benefit-item:hover {
    box-shadow: var(--shadow-sm);
  }
  .benefit-icon {
    font-size: 1.25rem;
    display: block;
    margin-bottom: 0.5rem;
    line-height: 1;
    opacity: 0.85;
  }
  .benefit-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }
  .benefit-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ─── Note Card — volle Zeile ─── */
  .bento-note {
    grid-column: span 3;
    background: var(--color-primary-light);
    border-color: var(--color-border);
    padding: 1.125rem 1.5rem;
  }
  .bento-note:hover {
    transform: none;
    box-shadow: none;
  }
  .bento-note__inner {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }
  .bento-note__ico {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 1px;
  }
  .bento-note__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }
  .bento-note__text {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ─── Apply CTA Card ─── */
  .bento-apply {
    grid-column: span 3;
    background: var(--color-text);
    border-color: var(--color-text);
    padding: 2.5rem;
  }
  .bento-apply__deco {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    pointer-events: none;
  }
  .bento-apply__layout {
    display: flex;
    align-items: center;
    gap: 3rem;
  }
  .bento-apply__left {
    flex: 1;
    min-width: 0;
  }
  .bento-apply .bento-section-tag {
    margin-bottom: 0.75rem;
  }
  .bento-apply__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
