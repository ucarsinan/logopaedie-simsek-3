---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://logopaedie-simsek.de';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Übernimmt die Krankenkasse die Kosten für Logopädie?",
      "acceptedAnswer": { "@type": "Answer", "text": "Gesetzliche Krankenkassen übernehmen logopädische Therapie bei medizinischer Indikation und gültiger Heilmittelverordnung abzüglich der gesetzlichen Zuzahlung. Erwachsene zahlen in der Regel 10 % Zuzahlung plus 10 € Rezeptgebühr. Kinder und Jugendliche unter 18 Jahren sind von dieser Zuzahlung befreit. Bei privaten Krankenkassen hängt die Erstattung vom jeweiligen Tarif ab." }
    },
    {
      "@type": "Question",
      "name": "Welcher Arzt kann Logopädie verordnen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Folgende Fachärzte können eine Heilmittelverordnung für Logopädie ausstellen: Allgemeinmediziner, HNO-Ärzte, Internisten, Kinderärzte, Kinderpsychiater, Neurologen, Orthopäden, Phoniatriker und Zahnärzte." }
    },
    {
      "@type": "Question",
      "name": "Was kostet Logopädie als Selbstzahler?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ohne Rezept können Sie bestimmte logopädische Leistungen als Selbstzahler in Anspruch nehmen, zum Beispiel Beratung oder präventive Stimmbildung. Die Kosten richten sich nach Behandlungsumfang und Honorarvereinbarung. Bitte kontaktieren Sie uns für aktuelle Informationen zu Selbstzahlertarifen." }
    },
    {
      "@type": "Question",
      "name": "Wie viel zahle ich als Erwachsener selbst?",
      "acceptedAnswer": { "@type": "Answer", "text": "Als gesetzlich versicherter Erwachsener zahlen Sie in der Regel 10 % der Therapiekosten selbst, zuzüglich einer Rezeptgebühr von 10 € pro Heilmittelverordnung. Die Krankenkasse übernimmt den verbleibenden Anteil, sofern eine gültige Verordnung vorliegt." }
    },
    {
      "@type": "Question",
      "name": "Müssen Kinder zuzahlen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Nein. Kinder und Jugendliche unter 18 Jahren sind von der gesetzlichen Zuzahlung befreit, wenn eine gültige Heilmittelverordnung vorliegt." }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Kosten & Kostenübernahme", "item": `${siteUrl}/kostenuebernahme` }
  ]
};
---

<Layout
  title="Kosten & Kostenübernahme – Logopädie Duisburg | Praxis Şimşek"
  description="Wer übernimmt die Kosten für Logopädie? Alles über Krankenkasse, Heilmittelverordnung, Zuzahlung und Selbstzahler. Praxis für Logopädie Şimşek Duisburg."
  additionalSchemas={[faqSchema, breadcrumbSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/kostenuebernahme/` },
    { lang: 'tr', url: `${siteUrl}/tr/kostenuebernahme` },
    { lang: 'x-default', url: `${siteUrl}/kostenuebernahme/` },
  ]}
>
  <Header alternateUrl="/tr/kostenuebernahme" />
  <Nav alternateUrl="/tr/kostenuebernahme" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3 max-[640px]:py-2.5">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Kosten & Kostenübernahme</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-12 max-[640px]:pt-9 pb-9 max-[640px]:pb-7 border-b border-border">
      <div class="container">
        <h1 class="font-display text-[clamp(1.85rem,5vw,3rem)] max-[640px]:text-[clamp(1.55rem,8vw,2.1rem)] font-semibold leading-[1.1] text-text mb-4">
          Kosten & Kostenübernahme
        </h1>
        <p class="text-text-muted text-lg max-[640px]:text-[0.97rem]">
          Logopädische Therapie ist ein Heilmittel. Bei medizinischer Indikation und gültiger
          Heilmittelverordnung übernehmen gesetzliche Krankenkassen den Großteil der Kosten;
          bei Privatversicherten richtet sich die Erstattung nach dem jeweiligen Tarif.
        </p>
      </div>
    </section>

    <!-- Content -->
    <div class="container py-12 max-[640px]:py-9">
      <div class="bento-page-grid bento-page-grid--costs">
        <article class="bento-tile bento-tile--wide bento-tile--highlight prose-section">
          <span class="bento-kicker">Krankenkasse</span>
          <h2>Kostenübernahme durch die Krankenkasse</h2>
          <p>
            Eine ärztlich verordnete logopädische Behandlung ist als <strong>Heilmittel</strong>
            Teil der medizinischen Versorgung. Gesetzliche Krankenkassen tragen die Kosten
            abzüglich der gesetzlichen Zuzahlung, wenn eine medizinische Indikation und eine
            gültige Heilmittelverordnung (Rezept) vorliegen. Bei privaten Krankenkassen hängt
            die Erstattung vom individuellen Tarif ab.
          </p>
        </article>

        <aside class="bento-tile bento-tile--soft">
          <span class="bento-kicker">Kosten</span>
          <h2>Kurzüberblick</h2>
          <p>Mit gültiger ärztlicher Heilmittelverordnung übernehmen gesetzliche Krankenkassen den Großteil der Behandlungskosten. Kinder unter 18 Jahren sind von der gesetzlichen Zuzahlung befreit.</p>
          <p><a href="tel:+4920334868690">0203 34 86 86 90</a></p>
        </aside>

        <section class="bento-tile bento-tile--half prose-section">
          <span class="bento-kicker">Rezept</span>
          <h2>Wer kann Logopädie verordnen?</h2>
          <p>Folgende Fachärzte können eine Heilmittelverordnung für Logopädie ausstellen:</p>
          <ul>
            <li>Allgemeinmedizinerinnen und Allgemeinmediziner</li>
            <li>HNO-Ärztinnen und HNO-Ärzte</li>
            <li>Internistinnen und Internisten</li>
            <li>Kieferorthopädinnen und Kieferorthopäden</li>
            <li>Kinderärztinnen und Kinderärzte (Pädiater)</li>
            <li>Kinderpsychiaterinnen und Kinderpsychiater</li>
            <li>Neurologinnen und Neurologen</li>
            <li>Orthopädinnen und Orthopäden</li>
            <li>Phoniatrinnen und Phoniater</li>
            <li>Zahnärztinnen und Zahnärzte</li>
          </ul>
        </section>

        <section class="bento-tile bento-tile--half bento-tile--warm prose-section">
          <span class="bento-kicker">Zuzahlung</span>
          <h2>Was zahle ich selbst?</h2>
          <h3>Kinder und Jugendliche</h3>
          <p>
            <strong>Keine gesetzliche Zuzahlung.</strong> Kinder und Jugendliche bis zur
            Vollendung des 18. Lebensjahres sind von der gesetzlichen Zuzahlung befreit.
          </p>
          <h3>Erwachsene</h3>
          <ul>
            <li><strong>10 % der Therapiekosten</strong> als Eigenanteil</li>
            <li><strong>10 € Rezeptgebühr</strong> einmalig pro Verordnung</li>
          </ul>
          <p>
            Mit <strong>Befreiungskarte</strong> der Krankenkasse entfällt der Eigenanteil.
          </p>
        </section>

        <section class="bento-tile bento-tile--half prose-section">
          <span class="bento-kicker">PKV</span>
          <h2>Privat Versicherte</h2>
          <p>
            Privatversicherte werden nach Heilmittelverordnung behandelt. Die Abrechnung
            erfolgt auf Grundlage einer privaten Honorarvereinbarung. Bitte klären Sie die
            Kostenübernahme vorab mit Ihrer privaten Krankenversicherung.
          </p>
        </section>

        <section class="bento-tile bento-tile--half bento-tile--soft prose-section">
          <span class="bento-kicker">Selbstzahler</span>
          <h2>Therapie ohne Rezept</h2>
          <p>
            Sie können bestimmte logopädische Leistungen auch ohne Rezept als Selbstzahler
            in Anspruch nehmen – zum Beispiel Beratung oder präventive Stimmbildung.
          </p>
          <p>
            Für aktuelle Selbstzahlertarife beraten wir Sie persönlich.
          </p>
        </section>

        <section class="bento-tile bento-tile--wide prose-section">
          <span class="bento-kicker">FAQ</span>
          <h2>Häufige Fragen</h2>
          <h3>Muss ich das Rezept vor Therapiebeginn einreichen?</h3>
          <p>
            Ja, die Heilmittelverordnung muss vor oder zu Beginn der ersten Therapieeinheit
            vorliegen. Bitte bringen Sie Ihr Rezept zum Ersttermin mit.
          </p>

          <h3>Was passiert, wenn das Rezept aufgebraucht ist?</h3>
          <p>
            Bei Bedarf stellen wir Ihnen einen Folgerezept-Antrag an Ihren behandelnden Arzt.
            Wir beraten Sie, wie das Verfahren läuft und was dokumentiert werden muss.
          </p>

          <h3>Kann ich ohne Überweisung kommen?</h3>
          <p>
            Als Selbstzahler ja. Für kassenfinanzierte Therapie benötigen Sie eine
            Heilmittelverordnung von einem der oben genannten Fachärzte – keine Überweisung
            zum Logopäden, sondern ein Heilmittelrezept.
          </p>
        </section>

        <aside class="bento-tile bento-tile--accent">
          <span class="bento-kicker">Gut zu wissen</span>
          <h2>Wir helfen bei der Klärung</h2>
          <p>
            Wir arbeiten mit gesetzlichen Krankenkassen, Privatversicherten und Selbstzahlern.
            Wenn Sie unsicher sind, welche Verordnung oder Abrechnung für Sie passt, rufen Sie uns an.
          </p>
          <p><a href="tel:+4920334868690">0203 34 86 86 90</a></p>
        </aside>
      </div>
    </div>

    <!-- CTA -->
    <section class="bg-primary py-12 max-[640px]:py-10" aria-label="Termin anfragen">
      <div class="container text-center flex flex-col items-center gap-4">
        <h2 class="font-display text-[clamp(1.375rem,2.5vw,2rem)] max-[640px]:text-[clamp(1.25rem,7vw,1.7rem)] font-semibold text-white">Termin vereinbaren</h2>
        <p class="text-white/80 max-[640px]:text-[0.95rem]">Wir beantworten Ihre Fragen zur Kostenübernahme auch telefonisch.</p>
        <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-3 w-full max-[640px]:max-w-[20rem]">
          <a href="/kontakt/" class="btn btn-outline-white">Kontakt & Anfahrt</a>
          <a href="tel:+4920334868690" class="btn btn-outline-white">0203 – 34 86 86 90</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .prose-section :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .prose-section :global(h3) {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-section :global(p) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-section :global(ul) {
    list-style: none;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose-section :global(ul li) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    padding-left: 1.5rem;
    position: relative;
  }
  .prose-section :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .prose-section :global(strong) { font-weight: 600; color: var(--color-text); }
  .prose-section :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }
  .prose-section :global(a:hover) { text-decoration-color: currentColor; }
  .bento-page-grid--costs .prose-section :global(.bento-kicker + h2),
  .bento-page-grid--costs .prose-section :global(.bento-kicker + h3) {
    margin-top: 0;
  }
  .info-box {
    background: var(--color-primary-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 6px 6px 0;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }
  @media (max-width: 640px) {
    .prose-section :global(h2) { font-size: 1.3rem; margin-top: 2rem; }
    .prose-section :global(h3) { font-size: 1.05rem; }
    .prose-section :global(p),
    .prose-section :global(ul li) { font-size: 0.9rem; line-height: 1.65; }
    .info-box { padding: 1rem 1.1rem; }
  }
</style>
