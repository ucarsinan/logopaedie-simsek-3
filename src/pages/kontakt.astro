---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://logopaedie-simsek.de';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Kontakt", "item": `${siteUrl}/kontakt` }
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Praxis für Logopädie Şimşek",
  "url": siteUrl,
  "telephone": "+4920334868690",
  "faxNumber": "+4920334868691",
  "email": "info@logopaedie-simsek.de",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tonhallenstraße 21",
    "addressLocality": "Duisburg",
    "postalCode": "47051",
    "addressCountry": "DE"
  },
  "openingHours": "Mo-Fr 08:00-18:00",
  "hasMap": "https://www.google.com/maps/dir/?api=1&destination=Tonhallenstra%C3%9Fe+21%2C+47051+Duisburg"
};
---

<Layout
  title="Kontakt & Anfahrt – Praxis für Logopädie Şimşek Duisburg"
  description="Kontakt zur Praxis für Logopädie Şimşek in Duisburg. Termin anfragen, Adresse, Telefon, E-Mail, Öffnungszeiten und Anfahrt. Nur 2 Minuten vom Hauptbahnhof."
  additionalSchemas={[breadcrumbSchema, localBusinessSchema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/kontakt/` },
    { lang: 'tr', url: `${siteUrl}/iletisim/` },
    { lang: 'x-default', url: `${siteUrl}/kontakt/` },
  ]}
>
  <Header alternateUrl="/iletisim" />
  <Nav alternateUrl="/iletisim" />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">

    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label="Breadcrumb">
      <div class="container py-3 max-[640px]:py-2.5">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">Kontakt</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-12 max-[640px]:pt-9 pb-9 max-[640px]:pb-7 border-b border-border">
      <div class="container">
        <h1 class="font-display text-[clamp(1.85rem,5vw,3rem)] max-[640px]:text-[clamp(1.55rem,8vw,2.1rem)] font-semibold leading-[1.1] text-text mb-4">
          Kontakt & Anfahrt
        </h1>
        <p class="text-text-muted text-lg max-[640px]:text-[0.97rem]">
          Tonhallenstraße 21, 47051 Duisburg · 3. Obergeschoss · Aufzug vorhanden
        </p>
      </div>
    </section>

    <!-- Content -->
    <div class="container py-12 max-[640px]:py-9">
      <div class="grid md:grid-cols-2 gap-12 max-[640px]:gap-8">

        <!-- Phone-only appointment CTA -->
        <div class="bg-surface border border-border rounded-md max-[640px]:rounded-[20px] p-9 max-[640px]:p-5 shadow-sm flex flex-col">
          <!-- Notice -->
          <div class="bg-primary-light border border-[rgba(42,127,111,.25)] rounded-sm px-5 max-[640px]:px-4 py-4 max-[640px]:py-3.5 flex gap-3 items-start">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-sm text-primary leading-[1.65]">Termine werden ausschließlich <strong>telefonisch</strong> vereinbart.</p>
          </div>

          <!-- Large phone CTA -->
          <div class="flex flex-col items-center text-center gap-5 max-[640px]:gap-4 py-4 max-[640px]:py-2 flex-1 justify-center">
            <div class="w-18 h-18 max-[640px]:w-15 max-[640px]:h-15 bg-primary rounded-full flex items-center justify-center text-white shadow-[0_8px_24px_rgba(42,127,111,.35)]" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h2 class="font-display text-[1.5rem] max-[640px]:text-[1.3rem] font-semibold text-text mb-1.5">Jetzt anrufen</h2>
              <p class="text-text-muted text-[.9375rem] max-[640px]:text-[0.9rem] leading-[1.65] max-w-xs">Rufen Sie uns direkt an – wir beraten Sie gerne und helfen Ihnen schnell und unkompliziert weiter.</p>
            </div>
            <a href="tel:+4920334868690" class="btn btn-primary w-full justify-center text-[1.0625rem] max-[640px]:text-[1rem] py-4 max-[640px]:py-3.5">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              0203 – 34 86 86 90
            </a>
            <p class="text-sm text-text-muted">Erreichbar: <strong class="text-text">Mo–Fr 08:00–18:00 Uhr</strong></p>
          </div>

        </div>

        <!-- Contact info -->
        <div class="flex flex-col gap-5 max-[640px]:gap-4 h-full">
          <div class="bg-surface border border-border rounded-md max-[640px]:rounded-[18px] p-6 max-[640px]:p-5 shadow-sm flex gap-4 max-[640px]:gap-3 items-start md:flex-1">
            <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Telefon</div>
              <div class="text-[.9375rem] font-semibold text-text"><a class="text-primary hover:underline" href="tel:+4920334868690">0203 – 34 86 86 90</a></div>
              <div class="text-[.8125rem] text-text-muted mt-0.5">Mo–Fr 08:00–18:00 Uhr</div>
            </div>
          </div>
          <div class="bg-surface border border-border rounded-md max-[640px]:rounded-[18px] p-6 max-[640px]:p-5 shadow-sm flex gap-4 max-[640px]:gap-3 items-start md:flex-1">
            <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/></svg>
            </div>
            <div>
              <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Fax</div>
              <div class="text-[.9375rem] font-semibold text-text">0203 – 34 86 86 91</div>
            </div>
          </div>
          <div class="bg-surface border border-border rounded-md max-[640px]:rounded-[18px] p-6 max-[640px]:p-5 shadow-sm flex gap-4 max-[640px]:gap-3 items-start md:flex-1">
            <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">E-Mail</div>
              <div class="text-[.9375rem] font-semibold text-text"><a class="text-primary hover:underline" href="mailto:info@logopaedie-simsek.de">info@logopaedie-simsek.de</a></div>
              <div class="text-[.8125rem] text-text-muted mt-0.5">Für allgemeine Fragen · Termine bitte telefonisch</div>
            </div>
          </div>
          <div class="bg-surface border border-border rounded-md max-[640px]:rounded-[18px] p-6 max-[640px]:p-5 shadow-sm flex gap-4 max-[640px]:gap-3 items-start md:flex-1">
            <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Adresse</div>
              <address class="not-italic">
                <div class="text-[.9375rem] font-semibold text-text">Tonhallenstraße 21, 47051 Duisburg</div>
                <div class="text-[.8125rem] text-text-muted mt-0.5">3. OG · Aufzug vorhanden</div>
              </address>
            </div>
          </div>
        </div>

        <!-- Insurance note -->
        <div class="md:col-span-2 bg-accent-light border border-[rgba(196,113,79,.2)] rounded-md max-[640px]:rounded-[18px] p-6 max-[640px]:p-5">
          <p class="text-[.9375rem] max-[640px]:text-[0.9rem] text-text leading-[1.7] max-[640px]:leading-[1.65]"><strong>Kassenrezept oder Selbstzahler?</strong><br>Wir arbeiten mit allen gesetzlichen Krankenkassen und nehmen auch Privatpatienten sowie Selbstzahler an. Bei Fragen zur Abrechnung beraten wir Sie gerne.</p>
        </div>

        <!-- Anfahrt & Karte – full width -->
        <div class="md:col-span-2 bg-surface border border-border rounded-md max-[640px]:rounded-[18px] p-6 max-[640px]:p-5 shadow-sm md:grid md:grid-cols-[1fr_2fr] md:gap-8 md:items-start" data-google-map>
          <div class="mb-4 md:mb-0">
            <h3 class="font-display text-base font-semibold text-text mb-3">Anfahrt & Karte</h3>
            <p class="text-sm text-text-muted mb-5">
              Nur <strong class="text-text">2 Gehminuten</strong> vom Duisburger Hauptbahnhof.<br>
              U79 · König-Heinrich-Platz · S-Bahn / RE / RB Duisburg Hbf
            </p>
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=Tonhallenstra%C3%9Fe+21%2C+47051+Duisburg"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary w-full justify-center"
            >
              In Google Maps öffnen
            </a>
          </div>
          <div class="relative overflow-hidden rounded-sm border border-border bg-bg-alt aspect-video">
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-6 text-center" data-google-map-placeholder>
              <p class="text-sm text-text-muted leading-[1.6] max-w-sm">Die Google-Maps-Karte wird erst geladen, wenn Sie zustimmen. Dabei können Daten an Google übertragen werden.</p>
              <button type="button" class="btn btn-primary min-h-10! px-4! py-2! text-sm!" data-google-map-load>Karte laden</button>
            </div>
            <iframe
              hidden
              data-src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4975.050497490753!2d6.764741934341445!3d51.43014709490562!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b8bf14865595d3%3A0x2c4bfb33dd4326db!2zUHJheGlzIGbDvHIgTG9nb3DDpGRpZSDFnmltxZ9law!5e0!3m2!1sde!2sde!4v1530622945154"
              title="Google Maps: Praxis für Logopädie Şimşek"
              class="w-full h-full border-0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>

      </div>
    </div>

  </main>
  <Footer />
</Layout>
