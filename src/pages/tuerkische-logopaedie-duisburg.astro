---
import ServicePage from '../layouts/ServicePage.astro';
import { Image } from 'astro:assets';
import tuerkischImg from '../assets/therapy/tuerkische-logopaedie-familie-duisburg.webp';

const siteUrl = 'https://logopaedie-simsek.de';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Türkische Logopädie Duisburg – Türkçe Logopedi Duisburg",
  "description": "Türkische Logopädie in Duisburg – Fachpraxis Şimşek in Duisburg-Mitte. Vollständige Diagnostik und Therapie auf Türkisch und Deutsch. Nur 2 Min. vom Hauptbahnhof.",
  "url": `${siteUrl}/tuerkische-logopaedie-duisburg/`,
  "inLanguage": ["de", "tr"],
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Türkische Logopädie Duisburg", "item": `${siteUrl}/tuerkische-logopaedie-duisburg/` }
    ]
  }
};
---

<ServicePage
  title="Türkische Logopädie Duisburg – Türkçe Logopedi | Praxis Şimşek"
  description="Türkische Logopädie in Duisburg – Praxis Şimşek in Duisburg-Mitte. Therapie auf Türkisch und Deutsch. Alle Kassen. Nur 2 Minuten vom Hauptbahnhof Duisburg."
  serviceTitle="Türkische Logopädie Duisburg – Türkçe Logopedi"
  breadcrumbLabel="Türkische Logopädie Duisburg"
  tags={['Duisburg', 'Türkçe Logopedi', 'Duisburg-Mitte', 'Alle Kassen']}
  additionalSchemas={[schema]}
  hreflangAlternates={[
    { lang: 'de', url: `${siteUrl}/tuerkische-logopaedie-duisburg/` },
    { lang: 'tr', url: `${siteUrl}/anasayfa/` },
    { lang: 'x-default', url: `${siteUrl}/tuerkische-logopaedie-duisburg/` },
  ]}
  relatedServices={[
    { title: 'Türkische Sprachtherapie', href: '/tuerkische-sprachtherapie/', description: 'Diagnostik und Therapie von Sprachstörungen auf Türkisch' },
    { title: 'Logopädie Duisburg', href: '/logopaedie-duisburg/', description: 'Das logopädische Therapieangebot in Duisburg im Überblick' },
    { title: 'Kostenübernahme', href: '/kostenuebernahme/', description: 'Was zahlt die Krankenkasse für Logopädie?' },
  ]}
>
  <section class="bento-page" aria-label="Türkische Logopädie in Duisburg">
    <div class="bento-grid">
      <article class="bento-card bento-card--image">
        <Image
          src={tuerkischImg}
          alt="Türkische Logopädie für Familien in Duisburg – zweisprachige Therapie Deutsch und Türkisch"
          class="bento-card__image"
          widths={[540, 900, 1200]}
          sizes="(max-width: 960px) 100vw, 55vw"
          loading="eager"
          decoding="async"
        />
        <div class="bento-card__overlay">
          <span class="bento-eyebrow">Zweisprachige Praxis</span>
          <h2>Therapie auf Türkisch und Deutsch mitten in Duisburg</h2>
          <p>
            Die Praxis für Logopädie Şimşek ist Ihre spezialisierte Anlaufstelle für
            <strong> türkische Logopädie in Duisburg</strong>. Unsere Praxis liegt zentral in
            Duisburg-Mitte, nur 2 Gehminuten vom Hauptbahnhof entfernt.
          </p>
        </div>
      </article>

      <article class="bento-card bento-card--highlight">
        <span class="bento-eyebrow">Standort & Praxis</span>
        <h2>Gut erreichbar für Familien aus ganz Duisburg</h2>
        <ul>
          <li><strong>Adresse:</strong> Tonhallenstraße 21, 47051 Duisburg (3. OG, Aufzug)</li>
          <li><strong>Lage:</strong> Duisburg-Mitte, 2 Minuten vom Hauptbahnhof</li>
          <li><strong>Erreichbarkeit:</strong> Bus, Straßenbahn und U-Bahn in direkter Nähe</li>
          <li><strong>Öffnungszeiten:</strong> Montag bis Freitag 08:00–18:00 Uhr nach Vereinbarung</li>
          <li><strong>Sprachen:</strong> Vollständige Therapie auf Deutsch und Türkisch</li>
          <li><strong>Kassen:</strong> Gesetzlich und privat versichert</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Altersgruppen</span>
        <h2>Türkischsprachige Logopädie für alle Lebensphasen</h2>
        <ul>
          <li><strong>Säuglinge und Kleinkinder:</strong> Frühförderung, Fütterstörungen, frühe Sprachentwicklung</li>
          <li><strong>Kindergartenkinder:</strong> Aussprache, Sprachentwicklungsverzögerung, Stottern</li>
          <li><strong>Schulkinder und Jugendliche:</strong> LRS, auditive Verarbeitung, Redeflussstörungen</li>
          <li><strong>Erwachsene:</strong> Aphasie, Stimme, Schlucken, neurologische Erkrankungen</li>
          <li><strong>Seniorinnen und Senioren:</strong> Dysphagie, Demenz-begleitende Therapie, Schlaganfall-Nachsorge</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Warum Muttersprache zählt</span>
        <h2>Muttersprachliche Diagnostik verhindert Fehleinschätzungen</h2>
        <p>
          Für mehrsprachig aufwachsende Kinder ist eine <strong>Diagnostik in der Erstsprache</strong>
          entscheidend. Nur so lässt sich unterscheiden, ob tatsächlich eine Sprachstörung
          vorliegt oder ob Unsicherheiten Teil einer normalen mehrsprachigen Entwicklung sind.
        </p>
        <p>
          Auch Erwachsene profitieren davon: Wer Türkisch als Muttersprache spricht, kann sich
          in einer Therapie auf Türkisch oft genauer ausdrücken, Inhalte besser verstehen und
          dadurch stabilere Therapieerfolge erzielen.
        </p>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Duisburg</span>
        <h2>Warum Duisburg ein zentraler Ort für türkische Logopädie ist</h2>
        <p>
          Duisburg gehört zu den Städten mit einem großen türkischsprachigen Umfeld. Gerade
          in Stadtteilen wie Marxloh, Hamborn, Hochfeld, Meiderich und Duisburg-Mitte ist eine
          muttersprachliche logopädische Versorgung für viele Familien wichtig.
        </p>
        <p>
          Unsere Praxis schließt diese Versorgungslücke seit vielen Jahren mit vollständiger
          Diagnostik, Therapie und Elternberatung auf Türkisch und Deutsch.
        </p>
      </article>

      <article class="bento-card bento-card--wide">
        <span class="bento-eyebrow">Frühförderung</span>
        <h2>Frühförderung auf Türkisch gibt Eltern und Kindern Sicherheit</h2>
        <p>
          In der Frühförderung bis zum Schuleintritt ist die Muttersprache die Grundlage für
          alle weiteren sprachlichen Entwicklungsschritte. Türkische Logopädie in diesem
          Bereich bedeutet:
        </p>
        <ul>
          <li>Sprachstandserhebung in Türkisch und Deutsch</li>
          <li>Diagnostik von Sprachentwicklungsverzögerungen auf muttersprachlicher Basis</li>
          <li>Therapie in der dominanten oder schwächeren Sprache je nach Bedarf</li>
          <li>Elternberatung auf Türkisch, damit die Therapie zu Hause mitgetragen werden kann</li>
        </ul>
      </article>

      <article class="bento-card">
        <span class="bento-eyebrow">Therapieangebot</span>
        <h2>Unser türkischsprachiges Leistungsspektrum</h2>
        <ul>
          <li><strong>Sprachtherapie:</strong> Sprachentwicklungsverzögerung, Grammatik, Wortschatz, Aphasie</li>
          <li><strong>Sprechtherapie:</strong> Stottern, Poltern, Lispeln, Ausspracheprobleme</li>
          <li><strong>Stimmtherapie:</strong> Heiserkeit, Dysphonie, Stimmschulung</li>
          <li><strong>Schlucktherapie:</strong> Dysphagie nach Schlaganfall oder bei neurologischen Erkrankungen</li>
          <li><strong>Beratung:</strong> Elterngespräche, Befundbesprechungen und Therapieplanung auf Türkisch</li>
        </ul>
      </article>

      <article class="bento-card bento-card--accent">
        <span class="bento-eyebrow">Duisburg'daki ailelere</span>
        <h2>Çocuğunuzun dil gelişimi konusunda endişeniz varsa bizimle iletişime geçebilirsiniz.</h2>
        <p>
          Türkçe veya Almanca görüşebilir, ilk değerlendirme ve terapi süreci hakkında doğrudan
          bilgi alabilirsiniz.
        </p>
        <a class="bento-link" href="/kontakt/">Kontakt aufnehmen</a>
      </article>

      <article class="bento-card bento-card--wide bento-card--soft">
        <span class="bento-eyebrow">Kosten & Verordnung</span>
        <h2>Die Krankenkasse übernimmt türkische Logopädie genauso wie deutschsprachige Therapie</h2>
        <p>
          Sie benötigen eine Heilmittelverordnung von Ihrem Arzt. Gesetzliche und private
          Krankenkassen übernehmen die Behandlung, Kinder und Jugendliche bis 18 Jahre sind
          in der Regel von Zuzahlungen befreit.
        </p>
        <p>
          Mehr Informationen finden Sie unter <a href="/kostenuebernahme/">Kosten & Kostenübernahme</a>.
        </p>
      </article>
    </div>
  </section>
</ServicePage>

<style>
  .bento-page {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    grid-auto-flow: row dense;
  }

  .bento-card {
    grid-column: span 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(28, 25, 22, 0.06);
    min-height: 100%;
  }

  .bento-card--image {
    grid-column: span 6;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 22rem;
    border: 0;
  }

  .bento-card--highlight {
    grid-column: span 6;
    background: linear-gradient(180deg, rgba(112, 90, 74, 0.08), rgba(255, 255, 255, 0.96));
  }

  .bento-card--wide {
    grid-column: span 8;
  }

  .bento-card--accent {
    background: var(--color-primary);
    color: white;
  }

  .bento-card--soft {
    background: var(--color-primary-light);
  }

  .bento-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bento-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      180deg,
      rgba(24, 18, 14, 0.08) 10%,
      rgba(24, 18, 14, 0.76) 100%
    );
  }

  .bento-eyebrow {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .bento-card--image .bento-eyebrow,
  .bento-card--accent .bento-eyebrow {
    color: rgba(255, 255, 255, 0.84);
  }

  .bento-card :global(h2),
  .bento-card__overlay :global(h2) {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
    color: var(--color-text);
  }

  .bento-card__overlay :global(h2) {
    color: white;
    max-width: 20ch;
  }

  .bento-card__overlay :global(p),
  .bento-card__overlay :global(p strong),
  .bento-card__overlay :global(p a) {
    color: #ffffff !important;
  }

  .bento-card :global(p),
  .bento-card :global(ul),
  .bento-card__overlay :global(p) {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .bento-card__overlay :global(p) {
    color: rgba(255, 255, 255, 0.88);
    max-width: 56ch;
  }

  .bento-card__overlay :global(strong),
  .bento-card__overlay :global(a) {
    color: white;
  }

  .bento-card :global(ul) {
    display: grid;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .bento-card :global(li) {
    position: relative;
    padding-left: 1rem;
  }

  .bento-card :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .bento-card--accent :global(h2),
  .bento-card--accent :global(p),
  .bento-card--accent :global(a),
  .bento-card--accent .bento-eyebrow {
    color: white;
  }

  .bento-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1.1rem;
    font-weight: 600;
    text-decoration: none;
  }

  .bento-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 960px) {
    .bento-card,
    .bento-card--image,
    .bento-card--highlight,
    .bento-card--wide {
      grid-column: span 12;
    }

    .bento-card--image {
      min-height: 19rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid {
      gap: 0.875rem;
    }

    .bento-card {
      padding: 1.2rem;
    }

    .bento-card--image {
      min-height: 0;
      padding: 1rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .bento-card__overlay {
      position: static;
      padding: 1rem 0 0;
      background: none;
    }

    .bento-card__image {
      height: 13.5rem;
      border-radius: 6px;
    }

    .bento-card--image .bento-eyebrow {
      color: var(--color-primary);
    }

    .bento-grid .bento-card__overlay :global(h2) {
      color: var(--color-text);
      max-width: none;
    }

    .bento-card__overlay :global(p),
    .bento-card__overlay :global(p strong),
    .bento-card__overlay :global(p a) {
      color: var(--color-text-muted) !important;
    }

    .bento-card__overlay :global(strong),
    .bento-card__overlay :global(a) {
      color: var(--color-text) !important;
    }
  }
</style>
