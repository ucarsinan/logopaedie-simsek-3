---
interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const isTR = lang === 'tr';
---

<footer class="bg-text text-white/70 pt-12 pb-8" role="contentinfo">
  <div class="container">
    <div class="flex flex-wrap justify-between items-center gap-6 pb-8 border-b border-white/10 mb-6">
      <div class="font-display text-[1.1875rem] font-semibold text-white leading-[1.2]">
        Logopädie Şimşek
        <span class="block text-xs font-body font-normal text-white/50 tracking-[.06em] uppercase mt-0.5">{isTR ? 'Duisburg Logoterapi' : 'Sprachtherapie Duisburg'}</span>
      </div>
      <nav class="flex gap-6 flex-wrap" aria-label={isTR ? 'Footer Navigasyonu' : 'Footer-Navigation'}>
        <a href="#leistungen" class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{isTR ? 'Hizmetler' : 'Leistungen'}</a>
        <a href="#team" class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{isTR ? 'Ekip' : 'Team'}</a>
        <a href="#praxis" class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{isTR ? 'Muayenehane' : 'Praxis'}</a>
        {!isTR && <a href="#karriere" class="text-sm text-white/60 transition-colors duration-200 hover:text-white">Karriere</a>}
        <a href="#kontakt" class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{isTR ? 'İletişim' : 'Kontakt'}</a>
      </nav>
      <div class="flex gap-3">
        <a href="#" class="w-10 h-10 rounded-sm border border-white/15 flex items-center justify-center text-white/60 transition-[background,color,border-color] duration-200 hover:bg-white/10 hover:text-white hover:border-white/30" aria-label="Instagram" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="#" class="w-10 h-10 rounded-sm border border-white/15 flex items-center justify-center text-white/60 transition-[background,color,border-color] duration-200 hover:bg-white/10 hover:text-white hover:border-white/30" aria-label="Facebook" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    </div>
    <div class="flex flex-wrap justify-between items-center gap-3 text-[.8125rem]">
      <p>&copy; 2025 Logopädie Şimşek · Emel Şimşek-Uçar · {isTR ? 'Tüm hakları saklıdır' : 'Alle Rechte vorbehalten'}</p>
      <div class="flex gap-5 flex-wrap">
        <a href="/impressum" class="text-white/50 transition-colors duration-200 hover:text-white">Impressum</a>
        <a href="/datenschutz" class="text-white/50 transition-colors duration-200 hover:text-white">{isTR ? 'Gizlilik' : 'Datenschutz'}</a>
        <a href="/barrierefreiheit" class="text-white/50 transition-colors duration-200 hover:text-white">{isTR ? 'Erişilebilirlik' : 'Barrierefreiheit'}</a>
      </div>
    </div>
  </div>
</footer>
