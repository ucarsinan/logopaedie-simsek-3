---
import { useTranslations } from '../i18n/index';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).footer;
const year = new Date().getFullYear();
---

<footer class="bg-text text-white/70 pt-10 max-[640px]:pt-8 pb-8 max-[640px]:pb-6" role="contentinfo">
  <div class="container">
    <div class="flex flex-wrap justify-between items-start gap-6 max-[640px]:gap-5 pb-8 max-[640px]:pb-6 border-b border-white/10 mb-6">
      <div class="font-display text-[1.1875rem] max-[640px]:text-[1.05rem] font-semibold text-white leading-[1.2] max-[640px]:w-full">
        Praxis für Logopädie Şimşek
        <span class="block text-xs font-body font-normal text-white/50 tracking-[.06em] uppercase mt-0.5">{t.tagline}</span>
        <span class="block text-xs font-body font-normal text-white/50 mt-3 leading-[1.6]">
          Tonhallenstraße 21 · 47051 Duisburg · Tel. 0203 – 34 86 86 90 · Fax 0203 – 34 86 86 91
        </span>
      </div>
      <div class="flex items-center justify-end gap-5 max-[640px]:justify-start max-[640px]:items-start max-[640px]:w-full max-[640px]:gap-4 max-[420px]:flex-col">
        <nav class="flex justify-end gap-4 max-[640px]:justify-start max-[640px]:gap-3 flex-wrap" aria-label={t.nav_label}>
          <a href={t.links.services.href} class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{t.links.services.label}</a>
          {t.links.tuerkische && <a href={t.links.tuerkische.href} class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{t.links.tuerkische.label}</a>}
          <a href={t.links.insurance.href} class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{t.links.insurance.label}</a>
          <a href={t.links.team.href} class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{t.links.team.label}</a>
          <a href={t.links.karriere.href} class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{t.links.karriere.label}</a>
          <a href={t.links.contact.href} class="text-sm text-white/60 transition-colors duration-200 hover:text-white">{t.links.contact.label}</a>
        </nav>
        <a href="https://www.facebook.com/logopaediesimsek/" target="_blank" class="w-10 h-10 rounded-sm border border-white/15 flex shrink-0 items-center justify-center text-white/60 transition-[background,color,border-color] duration-200 hover:bg-white/10 hover:text-white hover:border-white/30" aria-label="Facebook" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    </div>
    <div class="flex flex-wrap justify-between items-center max-[640px]:items-start gap-3 text-[.8125rem] max-[640px]:text-[0.75rem]">
      <p class="max-[640px]:w-full leading-[1.6]">&copy; {year} Praxis für Logopädie Şimşek · Emel Şimşek-Uçar · {t.copyright}</p>
      <div class="flex gap-5 max-[640px]:gap-4 flex-wrap">
        <a href="/impressum/" class="text-white/50 transition-colors duration-200 hover:text-white">Impressum</a>
        <a href="/datenschutz/" class="text-white/50 transition-colors duration-200 hover:text-white">{t.privacy}</a>
        <a href="/barrierefreiheit/" class="text-white/50 transition-colors duration-200 hover:text-white">{t.accessibility}</a>
      </div>
    </div>
  </div>
</footer>
