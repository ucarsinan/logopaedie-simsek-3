---
const testimonials = [
  {
    quote: "Kızım 3 yaşında sadece birkaç kelime söylüyordu. Burada aldığı tedaviden sonra artık cümleler kuruyor ve anaokulunda kendini açıkça ifade edebiliyor. Türkçe terapi seçeneği bizim için büyük bir avantajdı.",
    author: "E. K.",
    role: "Bir çocuğun annesi",
    stars: 5,
  },
  {
    quote: "İnme sonrasında konuşmakta büyük güçlük çekiyordum. Buradaki çalışmalar bana hem Almanca hem Türkçe desteği sundu. Verilen alıştırmalar ve sabırlı yaklaşım sayesinde tekrar konuşabiliyorum.",
    author: "M. Y.",
    role: "61 yaşında hasta",
    stars: 5,
  },
  {
    quote: "Öğretmen olarak sesin benim için ne kadar önemli olduğunu ancak ses sorunumu yaşayınca fark ettim. Muayenehanenin bütüncül yaklaşımı sayesinde okulda tekrar tam kapasiteyle çalışabiliyorum.",
    author: "S. B.",
    role: "İlkokul öğretmeni",
    stars: 5,
  },
];
---

<section class="py-24 bg-bg" aria-labelledby="testimonials-heading">
  <div class="container">
    <header class="text-center mb-14 flex flex-col items-center gap-4">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">Hasta Yorumları</span>
      <h2 class="font-display text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="testimonials-heading">Hastalarımız Anlatıyor</h2>
      <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-150 reveal reveal-delay-2">Gerçek başarı hikayeleri – gizlilik koruması için kısaltılmış.</p>
    </header>
    <div class="grid grid-cols-3 gap-6 max-[768px]:grid-cols-1">
      {testimonials.map((t, i) => (
        <article class={`bg-surface border border-border rounded-md p-8 shadow-sm flex flex-col gap-5 reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
          <div class="flex gap-0.5" aria-label={`${t.stars} yıldız üzerinden 5`}>
            {Array.from({ length: t.stars }).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#F59E0B]" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <blockquote class="text-[.9375rem] text-text-muted leading-[1.75] italic flex-1">„{t.quote}"</blockquote>
          <footer>
            <div class="font-semibold text-text text-[.9375rem]">{t.author}</div>
            <div class="text-[.8125rem] text-text-muted">{t.role}</div>
          </footer>
        </article>
      ))}
    </div>
  </div>
  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full mt-20" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,30 C720,60 1080,0 1440,20 L1440,60 L0,60 Z" fill="#F3EDE5"/>
    </svg>
  </div>
</section>
