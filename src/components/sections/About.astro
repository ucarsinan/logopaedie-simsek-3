---
import { Image } from 'astro:assets';
import { useTranslations } from '../../i18n/index';
import aboutImg from '../../assets/therapy/about-section-kind-senior-therapeutin.webp';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).about;
---

<section class="pt-24 pb-20 bg-bg" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="grid grid-cols-2 gap-20 items-center max-[768px]:grid-cols-1 max-[768px]:gap-12">
      <div class="flex flex-col gap-8">
        <div class="font-display text-[clamp(1.75rem,3vw,2.5rem)] font-normal italic leading-[1.3] text-text relative pl-7 before:content-[''] before:absolute before:left-0 before:top-1.5 before:bottom-1.5 before:w-1 before:bg-accent before:rounded [&_strong]:font-semibold [&_strong]:not-italic [&_strong]:text-primary reveal" set:html={t.quote} />
        <div class="relative reveal reveal-delay-1 group">
          <div class="absolute inset-0 translate-x-3 translate-y-3 rounded-2xl bg-accent/25 -z-[1] transition-transform duration-500 group-hover:translate-x-4 group-hover:translate-y-4"></div>
          <div class="relative rounded-xl overflow-hidden shadow-[0_10px_36px_rgba(28,25,22,0.14)] ring-1 ring-black/5">
            <Image
              src={aboutImg}
              alt="Logopädin Emel Şimşek-Uçar mit Kind und Seniorin in der Praxis Duisburg – Therapie für alle Altersgruppen"
              class="w-full aspect-[4/3] object-cover object-top block transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              widths={[400, 720, 1100]}
              sizes="(max-width: 768px) 100vw, 50vw"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-5">
        <div class="reveal reveal-delay-1">
          <span class="text-xs font-semibold tracking-widest uppercase text-primary">{t.section_label}</span>
          <h2 class="font-display text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] text-text mt-3 mb-4" id="about-heading">{t.heading}</h2>
          <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-150" set:html={t.description} />
        </div>
        <div class="grid grid-cols-2 gap-4 mt-2 reveal reveal-delay-2">
          <div class="bg-surface border border-border rounded-md p-5 shadow-sm">
            <div class="font-display text-[2rem] font-bold text-primary leading-none mb-1">100%</div>
            <div class="text-[.8125rem] text-text-muted font-medium">{t.stat_bilingual}</div>
          </div>
          <div class="bg-surface border border-border rounded-md p-5 shadow-sm">
            <div class="font-display text-[2rem] font-bold text-primary leading-none mb-1">{t.stat_areas_value}</div>
            <div class="text-[.8125rem] text-text-muted font-medium">{t.stat_areas}</div>
          </div>
          <div class="bg-surface border border-border rounded-md p-5 shadow-sm">
            <div class="font-display text-[2rem] font-bold text-primary leading-none mb-1">{t.stat_station_value}</div>
            <div class="text-[.8125rem] text-text-muted font-medium">{t.stat_station}</div>
          </div>
          <div class="bg-surface border border-border rounded-md p-5 shadow-sm">
            <div class="font-display text-[2rem] font-bold text-primary leading-none mb-1">{t.stat_floor_value}</div>
            <div class="text-[.8125rem] text-text-muted font-medium">{t.stat_floor}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full mt-16" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,20 C480,60 960,0 1440,30 L1440,60 L0,60 Z" fill="#F3EDE5"/>
    </svg>
  </div>
</section>
