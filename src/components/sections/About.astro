---
import { Image } from 'astro:assets';
import { useTranslations } from '../../i18n/index';
import aboutImg from '../../assets/therapy/about-section-kind-senior-therapeutin.webp';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).about;
---

<section class="pt-20 pb-16 max-[640px]:pt-14 max-[640px]:pb-12 bg-bg" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="grid grid-cols-2 gap-20 items-stretch max-[1024px]:grid-cols-1 max-[1024px]:gap-12 max-[640px]:gap-8">
      <div class="flex flex-col gap-8 max-[640px]:gap-6 h-full min-h-0">
        <div class="font-display text-[clamp(1.55rem,3vw,2.5rem)] max-[640px]:text-[clamp(1.15rem,7vw,1.85rem)] font-normal italic leading-[1.3] max-[640px]:leading-[1.22] text-text relative pl-7 max-[640px]:pl-5 shrink-0 before:content-[''] before:absolute before:left-0 before:top-1.5 before:bottom-1.5 before:w-1 max-[640px]:before:w-[3px] before:bg-accent before:rounded [&_strong]:font-semibold [&_strong]:not-italic [&_strong]:text-primary reveal" set:html={t.quote} />
        <div class="relative reveal reveal-delay-1 group flex-1 min-h-[280px] max-[1024px]:flex-none max-[1024px]:h-[clamp(22rem,62vw,30rem)] max-[640px]:h-[20rem] max-[420px]:h-[18rem]">
          <div class="absolute inset-0 translate-x-3 translate-y-3 rounded-2xl bg-accent/25 -z-[1] transition-transform duration-500 group-hover:translate-x-4 group-hover:translate-y-4"></div>
          <div class="relative rounded-xl overflow-hidden shadow-[0_10px_36px_rgba(28,25,22,0.14)] ring-1 ring-black/5 h-full">
            <Image
              src={aboutImg}
              alt="Logopädin Emel Şimşek-Uçar im Beratungsgespräch mit Familie in der Praxis Duisburg"
              class="w-full h-full object-cover object-[50%_45%] max-[1024px]:object-[50%_44%] max-[420px]:object-[52%_44%] block transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              widths={[720, 1100, 1500]}
              sizes="(max-width: 1024px) 100vw, 50vw"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-5 max-[640px]:gap-4 h-full min-h-0 justify-between max-[1024px]:justify-start">
        <div class="reveal reveal-delay-1">
          <span class="text-xs font-semibold tracking-widest uppercase text-primary">{t.section_label}</span>
          <h2 class="font-display text-[clamp(1.85rem,4vw,2.75rem)] max-[640px]:text-[clamp(1.6rem,8vw,2.15rem)] font-semibold leading-[1.15] text-text mt-3 max-[640px]:mt-2.5 mb-4 max-[640px]:mb-3" id="about-heading">{t.heading}</h2>
          <p class="text-[1.0625rem] max-[640px]:text-[0.97rem] text-text-muted leading-[1.7] max-[640px]:leading-[1.65] max-w-150" set:html={t.description} />
        </div>
        <div class="grid grid-cols-2 gap-3 mt-auto reveal reveal-delay-2 max-w-[30rem] max-[1024px]:mt-2 max-[420px]:gap-2.5">
          <div class="bg-surface border border-border rounded-md p-4 shadow-sm min-w-0 max-[640px]:p-4 max-[420px]:p-3.5">
            <div class="font-display text-[1.65rem] font-bold text-primary leading-none mb-1 max-[640px]:text-[1.7rem] max-[420px]:text-[1.55rem]">100%</div>
            <div class="text-[.8125rem] text-text-muted font-medium leading-[1.4] break-words max-[640px]:text-[0.78rem] max-[420px]:text-[0.72rem]">{t.stat_bilingual}</div>
          </div>
          <div class="bg-surface border border-border rounded-md p-4 shadow-sm min-w-0 max-[640px]:p-4 max-[420px]:p-3.5">
            <div class="font-display text-[1.65rem] font-bold text-primary leading-none mb-1 max-[640px]:text-[1.7rem] max-[420px]:text-[1.55rem]">{t.stat_areas_value}</div>
            <div class="text-[.8125rem] text-text-muted font-medium leading-[1.4] break-words max-[640px]:text-[0.78rem] max-[420px]:text-[0.72rem]">{t.stat_areas}</div>
          </div>
          <div class="bg-surface border border-border rounded-md p-4 shadow-sm min-w-0 max-[640px]:p-4 max-[420px]:p-3.5">
            <div class="font-display text-[1.65rem] font-bold text-primary leading-none mb-1 max-[640px]:text-[1.7rem] max-[420px]:text-[1.55rem]">{t.stat_station_value}</div>
            <div class="text-[.8125rem] text-text-muted font-medium leading-[1.4] break-words max-[640px]:text-[0.78rem] max-[420px]:text-[0.72rem]">{t.stat_station}</div>
          </div>
          <div class="bg-surface border border-border rounded-md p-4 shadow-sm min-w-0 max-[640px]:p-4 max-[420px]:p-3.5">
            <div class="font-display text-[1.65rem] font-bold text-primary leading-none mb-1 max-[640px]:text-[1.7rem] max-[420px]:text-[1.55rem]">{t.stat_floor_value}</div>
            <div class="text-[.8125rem] text-text-muted font-medium leading-[1.4] break-words max-[640px]:text-[0.78rem] max-[420px]:text-[0.72rem]">{t.stat_floor}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full mt-12 max-[640px]:mt-8" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,20 C480,60 960,0 1440,30 L1440,60 L0,60 Z" fill="#F3EDE5"/>
    </svg>
  </div>
</section>
