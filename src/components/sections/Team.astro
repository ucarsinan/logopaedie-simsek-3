---
import { Image } from 'astro:assets';
import { useTranslations } from '../../i18n/index';
import emelImg from '../../assets/therapy/team-emel-simsek-ucar.jpg';
import maraImg from '../../assets/therapy/team-mara-niessalla.png';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).team;

const memberData = [
  { initials: 'EŞ', name: 'Emel Şimşek-Uçar', isLead: true, photo: emelImg },
  { initials: 'MN', name: 'Mara Nießalla', photo: maraImg },
];

const members = memberData.map((m, i) => ({ ...m, ...t.members[i] }));
---

<section class="py-24 bg-bg" id="team" aria-labelledby="team-heading">
  <div class="container">
    <header class="text-center mb-14 flex flex-col items-center gap-4">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">{t.section_label}</span>
      <h2 class="font-display text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="team-heading">#TeamSimsek</h2>
      <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-150 reveal reveal-delay-2">{t.description}</p>
    </header>
    <div class="grid grid-cols-3 gap-6 max-[860px]:grid-cols-2 max-[540px]:grid-cols-1">
      {members.map((member, index) => (
        <article class={`bg-surface border border-border rounded-md overflow-hidden shadow-sm transition-[transform,box-shadow] duration-250 ease-out hover:-translate-y-1 hover:shadow-md reveal${index === 0 ? '' : ` reveal-delay-${index}`}`}>
          <div class="h-65 relative overflow-hidden bg-surface-2">
            {member.photo
              ? <Image
                  src={member.photo}
                  alt={`${member.name} – Logopädin in der Praxis Şimşek Duisburg`}
                  class="w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                  widths={[320, 480]}
                  sizes="(max-width: 540px) 100vw, (max-width: 860px) 50vw, 33vw"
                  loading="lazy"
                  decoding="async"
                />
              : <div class="w-full h-full flex items-center justify-center">
                  <div class="w-20 h-20 rounded-full bg-primary text-white flex items-center justify-center font-display text-[1.75rem] font-semibold">{member.initials}</div>
                </div>
            }
            {member.badge && (
              <span class="absolute top-4 right-4 bg-accent text-white text-[.7rem] font-bold tracking-[.06em] uppercase px-2.5 py-1 rounded-full">{member.badge}</span>
            )}
          </div>
          <div class="p-6">
            <h3 class="font-display text-[1.1875rem] font-semibold mb-1 text-text">{member.name}</h3>
            <p class="text-sm text-primary font-semibold mb-2.5">{member.role}</p>
            <p class="text-[.8125rem] text-text-muted leading-[1.5]">{member.extra}</p>
          </div>
        </article>
      ))}
      <article class="bg-[linear-gradient(135deg,var(--color-accent-light),var(--color-primary-light))] border-2 border-dashed border-border rounded-md overflow-hidden flex flex-col reveal reveal-delay-5">
        <div class="h-[200px] flex items-center justify-center bg-transparent">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary opacity-50"><path d="M12 5v14M5 12h14"/></svg>
        </div>
        <div class="p-6 text-center flex flex-col items-center justify-center flex-1 pt-0">
          <h3 class="font-display text-[1.1875rem] font-semibold mb-1 text-text">{t.join_heading}</h3>
          <p class="text-sm text-accent font-semibold mb-2.5">{t.join_role}</p>
          <p class="text-[.8125rem] text-text-muted leading-[1.5] mb-4">{t.join_text}</p>
          <a href="#karriere" class="btn btn-accent text-sm py-[10px] px-5">{t.join_cta}</a>
        </div>
      </article>
    </div>
  </div>
  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full mt-20" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,40 C480,0 960,60 1440,20 L1440,60 L0,60 Z" fill="#F3EDE5"/>
    </svg>
  </div>
</section>
