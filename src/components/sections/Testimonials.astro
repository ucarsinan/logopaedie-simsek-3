---
import { useTranslations } from '../../i18n/index';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).testimonials;
const testimonials = t.items;
---

<section class="py-24 bg-bg-alt" id="bewertungen" aria-labelledby="testimonials-heading">
  <div class="container">
    <header class="text-center mb-14 flex flex-col items-center gap-4">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">{t.section_label}</span>
      <h2 class="font-display text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="testimonials-heading">{t.heading}</h2>
      <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-150 reveal reveal-delay-2">{t.description}</p>
    </header>
    <div class="grid grid-cols-3 gap-6 max-[860px]:grid-cols-1">
      {testimonials.map((item, i) => (
        <article class={`bg-surface border border-border rounded-md p-8 shadow-sm flex flex-col gap-5 reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
          <div class="flex gap-0.5" aria-label={t.stars_aria_template.replace('{n}', String(item.stars))}>
            {Array.from({ length: item.stars }).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <blockquote class="font-display text-[1.0625rem] italic leading-[1.55] text-text flex-1">„{item.quote}"</blockquote>
          <footer class="border-t border-border pt-4">
            <p class="font-semibold text-text text-sm">{item.author}</p>
            <p class="text-xs text-text-muted mt-0.5">{item.detail}</p>
          </footer>
        </article>
      ))}
    </div>
    <p class="text-center text-xs text-text-light mt-8">{t.footnote}</p>
  </div>
</section>
