---
interface FaqItem {
  q: string;
  a: string;
}

const items: FaqItem[] = [
  {
    q: 'Was behandeln Logopädinnen und Logopäden?',
    a: 'Logopädinnen behandeln Störungen in den Bereichen Sprache (z. B. Sprachentwicklungsverzögerung, Aphasie), Sprechen (z. B. Stottern, Lispeln, Dysarthrie), Stimme (z. B. Heiserkeit, Dysphonie) und Schlucken (Dysphagie). Die Therapie richtet sich an Kinder, Erwachsene und Senioren.',
  },
  {
    q: 'Ab welchem Alter kann mein Kind zur Logopädie?',
    a: 'Logopädische Therapie ist ab dem Säuglingsalter möglich – auch bei Saugstörungen von Neugeborenen. Je früher eine Sprachentwicklungsverzögerung erkannt und behandelt wird, desto besser sind die Therapieerfolge. Frühförderung vor dem Schuleintritt ist besonders wirkungsvoll.',
  },
  {
    q: 'Brauche ich ein ärztliches Rezept für Logopädie?',
    a: 'Für eine kassenfinanzierte Therapie benötigen Sie eine Heilmittelverordnung (Rezept) von Ihrem Haus- oder Facharzt. Als Selbstzahler können Sie auch ohne Rezept einen Termin in unserer Praxis vereinbaren. Rufen Sie uns gerne an – wir beraten Sie.',
  },
  {
    q: 'Übernimmt die Krankenkasse die Kosten der Therapie?',
    a: 'Gesetzliche Krankenkassen übernehmen bei vorliegender Heilmittelverordnung den Großteil der Therapiekosten. Sie leisten in der Regel eine Zuzahlung von 10 % der Verordnungskosten plus 10 € Rezeptgebühr pro Verordnung. Privatpatienten rechnen direkt über ihre Versicherung ab. Wir arbeiten mit allen gesetzlichen und privaten Krankenkassen zusammen.',
  },
  {
    q: 'Was passiert beim ersten Termin?',
    a: 'Beim ersten Termin führen wir eine ausführliche Anamnese durch und erheben mit standardisierten Diagnostikverfahren den aktuellen Therapiebedarf. Anschließend besprechen wir gemeinsam Therapieziele und erstellen einen individuellen Behandlungsplan. Der Ersttermin dauert in der Regel 60 Minuten.',
  },
  {
    q: 'Wie lange dauert eine Therapieeinheit?',
    a: 'Eine Therapieeinheit dauert in der Regel 45 Minuten. Beim Ersttermin (Diagnostik und Anamnese) kalkulieren wir etwas mehr Zeit ein. Die Gesamtdauer des Therapieprozesses hängt vom Störungsbild und den individuellen Fortschritten ab und wird regelmäßig neu bewertet.',
  },
  {
    q: 'Wie oft ist Therapie pro Woche notwendig?',
    a: 'Empfohlen werden je nach Störungsbild 1–2 Therapieeinheiten pro Woche. Regelmäßiges Üben zwischen den Terminen ist ein wichtiger Bestandteil der Therapie und entscheidend für nachhaltige Fortschritte. Wir geben Ihnen konkrete Heimübungen mit.',
  },
  {
    q: 'Bieten Sie Therapie auf Türkisch an?',
    a: 'Ja – wir bieten vollständige Diagnostik, Beratung und Therapie auf Deutsch und Türkisch an. Besonders für mehrsprachig aufwachsende Kinder und türkischsprachige Erwachsene ist diese interkulturelle Kompetenz ein großer Vorteil. Im Raum Duisburg ist dieses Angebot selten und schließt eine wichtige Versorgungslücke.',
  },
  {
    q: 'Sind Hausbesuche in Duisburg möglich?',
    a: 'Ja, wir bieten auf Wunsch Hausbesuche in Duisburg und der näheren Umgebung an. Dies ist besonders für mobilitätseingeschränkte Patienten sinnvoll oder wenn eine Therapie im vertrauten Lebensumfeld therapeutisch wertvoller ist. Bitte sprechen Sie uns an.',
  },
  {
    q: 'Was ist der Unterschied zwischen Sprach- und Sprechstörungen?',
    a: 'Sprachstörungen betreffen das linguistische System – also Wortschatz, Grammatik oder Sprachverständnis (z. B. Aphasie, Sprachentwicklungsverzögerung). Sprechstörungen betreffen die motorische Ausführung des Sprechens – also wie Laute und Wörter produziert werden (z. B. Stottern, Lispeln, Dysarthrie). Beide Bereiche können auch gleichzeitig auftreten.',
  },
];
---

<section class="py-24 bg-bg" id="faq" aria-labelledby="faq-heading">
  <div class="container max-w-3xl">
    <header class="text-center mb-12 flex flex-col items-center gap-4">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">Häufige Fragen</span>
      <h2 class="font-display text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="faq-heading">Ihre Fragen – unsere Antworten</h2>
      <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-[560px] reveal reveal-delay-2">Alles Wichtige rund um Logopädie, Kostenübernahme und Terminvereinbarung auf einen Blick.</p>
    </header>
    <div class="flex flex-col gap-3">
      {items.map((item, i) => (
        <details class={`bg-surface border border-border rounded-md overflow-hidden group reveal${i > 0 ? ` reveal-delay-${Math.min(i, 4)}` : ''}`}>
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer font-semibold text-[.9375rem] text-text list-none hover:text-primary transition-colors">
            {item.q}
            <svg class="shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-180" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="px-6 pb-5 text-[.9375rem] text-text-muted leading-[1.75] border-t border-border pt-4">{item.a}</div>
        </details>
      ))}
    </div>
    <div class="text-center mt-10 reveal">
      <p class="text-text-muted mb-4">Ihre Frage ist nicht dabei?</p>
      <a href="/#kontakt" class="btn btn-primary">Direkt anfragen</a>
    </div>
  </div>
</section>
