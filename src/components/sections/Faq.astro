---
import { useTranslations } from '../../i18n/index';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).faq;
const items = t.items;
---

<section class="py-20 max-[640px]:py-14 bg-bg" id="faq" aria-labelledby="faq-heading">
  <div class="container max-w-3xl">
    <header class="text-center mb-14 max-[640px]:mb-10 flex flex-col items-center gap-4 max-[640px]:gap-3">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">{t.section_label}</span>
      <h2 class="font-display text-[clamp(1.85rem,4vw,2.75rem)] max-[640px]:text-[clamp(1.6rem,8vw,2.1rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="faq-heading">{t.heading}</h2>
      <p class="text-[1.0625rem] max-[640px]:text-[0.97rem] text-text-muted leading-[1.7] max-[640px]:leading-[1.65] max-w-150 reveal reveal-delay-2">{t.description}</p>
    </header>
    <div class="flex flex-col gap-3">
      {items.map((item, i) => (
        <details class={`bg-surface border border-border rounded-md max-[640px]:rounded-[18px] overflow-hidden group reveal${i > 0 ? ` reveal-delay-${Math.min(i, 4)}` : ''}`}>
          <summary class="flex items-center justify-between gap-4 px-6 max-[640px]:px-5 py-5 max-[640px]:py-4 cursor-pointer font-semibold text-[.9375rem] max-[640px]:text-[0.9rem] text-text list-none hover:text-primary transition-colors">
            {item.q}
            <svg class="shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-180" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="px-6 max-[640px]:px-5 pb-5 max-[640px]:pb-4 text-[.9375rem] max-[640px]:text-[0.9rem] text-text-muted leading-[1.75] max-[640px]:leading-[1.65] border-t border-border pt-4">{item.a}</div>
        </details>
      ))}
    </div>
    <div class="text-center mt-10 max-[640px]:mt-8 reveal">
      <p class="text-text-muted mb-4">{t.no_question}</p>
      <a href={t.ask_href} class="btn btn-primary max-[640px]:w-full max-[640px]:justify-center">{t.ask_cta}</a>
    </div>
  </div>
</section>
