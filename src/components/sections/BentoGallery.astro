---
import { Image } from 'astro:assets';
import babyImg from '../../assets/therapy/fruehfoerderung-logopaedie-kind-duisburg.webp';
import stimmImg from '../../assets/therapy/stimmtherapie-bildkarten-duisburg.webp';
import hausImg from '../../assets/therapy/hausbesuche-logopaedie-duisburg.webp';
import seniImg from '../../assets/therapy/logopaedie-erwachsene-bildkarten-duisburg.webp';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;

const isTR = lang === 'tr';

type BentoCard = {
  img: typeof babyImg;
  label: string;
  sub: string;
  href: string;
};

type BentoCards = [BentoCard, BentoCard, BentoCard, BentoCard];

const cards: BentoCards = isTR
  ? [
      { img: babyImg, label: 'Erken Müdahale', sub: '0–6 Yaş', href: '/terapi/' },
      { img: stimmImg, label: 'Ses Terapisi', sub: 'Disfoni & Kısıklık', href: '/terapi/ses-terapisi/' },
      { img: hausImg, label: 'Ev Ziyaretleri', sub: 'Mobil Terapi', href: '/hausbesuche-duisburg/' },
      { img: seniImg, label: 'Yetişkin Terapisi', sub: 'Her Yaş İçin', href: '/terapi/' },
    ]
  : [
      { img: babyImg, label: 'Frühförderung', sub: '0–6 Jahre', href: '/fruehfoerderung-duisburg/' },
      { img: stimmImg, label: 'Stimmtherapie', sub: 'Dysphonie & Heiserkeit', href: '/therapie/stimmtherapie/' },
      { img: hausImg, label: 'Hausbesuche', sub: 'Mobile Therapie', href: '/hausbesuche-duisburg/' },
      { img: seniImg, label: 'Erwachsene & Senioren', sub: 'Für alle Altersgruppen', href: '/therapie/erwachsene/' },
    ];

const [primaryCard, voiceCard, homeVisitCard, adultCard] = cards;
---

<section class="py-5 bg-bg-alt" aria-label={isTR ? 'Praxisten Görüntüler' : 'Einblicke in die Praxis'}>
  <div class="container">
    <div class="bento-grid">

      <!-- Large cell: col-span-2 row-span-2 -->
      <a
        href={primaryCard.href}
        class="bento-cell bento-large group reveal"
        aria-label={primaryCard.label}
      >
        <Image
          src={primaryCard.img}
          alt={primaryCard.label}
          class="bento-img"
          widths={[480, 800, 1100]}
          sizes="(max-width: 900px) 100vw, 50vw"
          loading="lazy"
          decoding="async"
        />
        <div class="bento-overlay"></div>
        <div class="bento-label">
          <span class="bento-label-sub">{primaryCard.sub}</span>
          <span class="bento-label-title">{primaryCard.label}</span>
        </div>
        <div class="bento-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </div>
      </a>

      <!-- Medium cell top: col 3 row 1 -->
      <a
        href={voiceCard.href}
        class="bento-cell bento-medium group reveal reveal-delay-1"
        aria-label={voiceCard.label}
      >
        <Image
          src={voiceCard.img}
          alt={voiceCard.label}
          class="bento-img"
          widths={[320, 560]}
          sizes="(max-width: 900px) 50vw, 25vw"
          loading="lazy"
          decoding="async"
        />
        <div class="bento-overlay"></div>
        <div class="bento-label">
          <span class="bento-label-sub">{voiceCard.sub}</span>
          <span class="bento-label-title">{voiceCard.label}</span>
        </div>
      </a>

      <!-- Medium cell top: col 4 row 1 -->
      <a
        href={homeVisitCard.href}
        class="bento-cell bento-medium group reveal reveal-delay-2"
        aria-label={homeVisitCard.label}
      >
        <Image
          src={homeVisitCard.img}
          alt={homeVisitCard.label}
          class="bento-img"
          widths={[320, 560]}
          sizes="(max-width: 900px) 50vw, 25vw"
          loading="lazy"
          decoding="async"
        />
        <div class="bento-overlay"></div>
        <div class="bento-label">
          <span class="bento-label-sub">{homeVisitCard.sub}</span>
          <span class="bento-label-title">{homeVisitCard.label}</span>
        </div>
      </a>

      <!-- Wide cell: col-span-2 row 2 -->
      <a
        href={adultCard.href}
        class="bento-cell bento-wide group reveal reveal-delay-3"
        aria-label={adultCard.label}
      >
        <Image
          src={adultCard.img}
          alt={adultCard.label}
          class="bento-img"
          widths={[480, 800, 1100]}
          sizes="(max-width: 900px) 100vw, 50vw"
          loading="lazy"
          decoding="async"
        />
        <div class="bento-overlay"></div>
        <div class="bento-label">
          <span class="bento-label-sub">{adultCard.sub}</span>
          <span class="bento-label-title">{adultCard.label}</span>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 240px 240px;
    gap: 12px;
  }

  .bento-cell {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    display: block;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(28, 25, 22, 0.09);
    ring: 1px solid rgba(0, 0, 0, 0.05);
    text-decoration: none;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
  }

  .bento-cell:hover {
    transform: translateY(-3px) scale(1.01);
    box-shadow: 0 12px 36px rgba(28, 25, 22, 0.16);
  }

  .bento-large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .bento-medium {
    grid-column: span 1;
    grid-row: span 1;
  }

  .bento-wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  .bento-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .bento-cell:hover .bento-img {
    transform: scale(1.05);
  }

  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(20, 17, 14, 0.72) 0%,
      rgba(20, 17, 14, 0.18) 45%,
      transparent 75%
    );
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .bento-cell:hover .bento-overlay {
    opacity: 0.9;
  }

  .bento-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    transform: translateY(4px);
    transition: transform 0.3s ease;
  }

  .bento-cell:hover .bento-label {
    transform: translateY(0);
  }

  .bento-label-sub {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .bento-label-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.2;
  }

  .bento-large .bento-label-title {
    font-size: 1.5rem;
  }

  .bento-arrow {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .bento-cell:hover .bento-arrow {
    opacity: 1;
    transform: scale(1);
  }

  /* Tablet */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: none;
    }

    .bento-large {
      grid-column: span 2;
      grid-row: span 1;
      aspect-ratio: 4 / 3;
      height: auto;
    }

    .bento-medium {
      aspect-ratio: 1 / 1;
      height: auto;
    }

    .bento-wide {
      grid-column: span 2;
      grid-row: span 1;
      aspect-ratio: 16 / 7;
      height: auto;
    }
  }

  /* Mobile */
  @media (max-width: 540px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .bento-large,
    .bento-wide {
      grid-column: span 1;
      aspect-ratio: 4 / 3;
    }

    .bento-medium {
      aspect-ratio: 16 / 9;
    }

    .bento-label-title {
      font-size: 1.15rem;
    }

    .bento-large .bento-label-title {
      font-size: 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-cell,
    .bento-img,
    .bento-label,
    .bento-arrow {
      transition: none;
    }
  }
</style>
