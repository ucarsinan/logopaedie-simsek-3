---
interface BenefitCard {
  icon: string;
  title: string;
  desc: string;
}

const benefits: BenefitCard[] = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'Top-Gehalt',
    desc: 'Deutlich über dem Branchendurchschnitt – weil gute Arbeit fair entlohnt werden sollte.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
    title: '100% Fortbildungskosten',
    desc: 'Wir übernehmen sämtliche Kosten für Weiterbildungen – plus bezahlter Sonderurlaub.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>`,
    title: '4-Tage-Woche',
    desc: 'Work-Life-Balance ist keine Phrase – die 4-Tage-Woche ist bei uns möglich.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Flache Hierarchien',
    desc: 'Ehrlicher, familiärer Austausch auf Augenhöhe – keine verstaubten Strukturen.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Sonderurlaub',
    desc: 'Bezahlter Sonderurlaub für Fortbildungen – Zeit fürs Lernen gehört zum Job.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    title: 'Familiäres Team',
    desc: 'Ein echtes Miteinander, gegenseitige Unterstützung und eine Praxis, in der man gerne ist.',
  },
];

const revealDelays = ['', 'reveal-delay-1', 'reveal-delay-2', 'reveal-delay-1', 'reveal-delay-2', 'reveal-delay-3'];
---

<section class="py-20 max-[640px]:py-14 bg-bg" id="karriere" aria-labelledby="karriere-heading">
  <div class="container">
    <header class="text-center mb-14 max-[640px]:mb-10 flex flex-col items-center gap-4 max-[640px]:gap-3">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">Karriere</span>
      <div class="font-display text-[clamp(1.25rem,2.5vw,1.75rem)] font-medium italic text-accent reveal reveal-delay-1">#TeamSimsek</div>
      <h2 class="font-display text-[clamp(1.85rem,4vw,2.75rem)] max-[640px]:text-[clamp(1.6rem,8vw,2.1rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-2" id="karriere-heading">Werde Teil unseres Teams</h2>
      <p class="text-[1.0625rem] max-[640px]:text-[0.97rem] text-text-muted leading-[1.7] max-[640px]:leading-[1.65] max-w-150 reveal reveal-delay-3">Eine exzellente Therapie entsteht nur dort, wo sich Therapeutinnen und Therapeuten wohlfühlen. Deshalb bieten wir ein Umfeld, das Leistung honoriert und Work-Life-Balance ernst nimmt.</p>
    </header>

    <!-- Benefits bento grid -->
    <div class="grid grid-cols-3 gap-3 mb-3 max-[860px]:grid-cols-2 max-[480px]:grid-cols-1 max-[640px]:gap-4">
      {benefits.map((benefit, i) => (
        <div class={`bg-surface border border-border rounded-(--radius-lg) py-7 px-6 max-[640px]:py-5 max-[640px]:px-5 shadow-sm transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:shadow-md reveal${revealDelays[i] ? ` ${revealDelays[i]}` : ''}`}>
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary mb-4" aria-hidden="true" set:html={benefit.icon} />
          <div class="font-bold text-[.9375rem] mb-1.5 text-text">{benefit.title}</div>
          <div class="text-sm text-text-muted leading-[1.6]">{benefit.desc}</div>
        </div>
      ))}
    </div>

    <!-- Dark CTA card matching bento-apply style from /karriere/ page -->
    <div class="relative overflow-hidden rounded-(--radius-lg) bg-text border border-text p-10 max-[640px]:p-6 reveal reveal-delay-2">
      <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/4 pointer-events-none" aria-hidden="true"></div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-8 max-[640px]:gap-5">
        <div class="flex-1 min-w-0">
          <div class="text-[.6875rem] font-bold tracking-widest uppercase text-white/70 mb-3">Bewerbung</div>
          <h3 class="font-display text-[clamp(1.5rem,3vw,2rem)] font-semibold text-white leading-[1.1] mb-3">Klingt das nach dir?</h3>
          <p class="text-sm text-white/60 leading-[1.65] max-w-[38ch]">Einfach E-Mail, Anruf oder WhatsApp – der Lebenslauf reicht für den Anfang.</p>
        </div>
        <div class="flex flex-col sm:flex-row flex-wrap gap-3 shrink-0 max-[640px]:w-full">
          <a href="https://wa.me/4920334868690?text=Hallo%2C%20ich%20interessiere%20mich%20f%C3%BCr%20die%20Stelle%20als%20Logop%C3%A4din%20%2F%20Logop%C3%A4de%20in%20Ihrer%20Praxis." class="inline-flex items-center gap-2 font-semibold text-sm px-5 py-3 rounded-sm no-underline transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 max-[640px]:w-full max-[640px]:justify-center" style="background:#25D366;color:#fff;" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>
            WhatsApp
          </a>
          <a href="mailto:info@logopaedie-simsek.de" class="inline-flex items-center gap-2 bg-primary text-white font-semibold text-sm px-5 py-3 rounded-sm no-underline transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:shadow-[0_6px_18px_rgba(0,0,0,.3)] max-[640px]:w-full max-[640px]:justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Jetzt bewerben
          </a>
          <a href="/karriere/" class="inline-flex items-center gap-2 text-white/75 border border-white/20 font-semibold text-sm px-5 py-3 rounded-sm no-underline transition-colors duration-200 hover:bg-white/8 hover:border-white/40 hover:text-white max-[640px]:w-full max-[640px]:justify-center">
            Zum Stellenangebot
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full mt-14 max-[640px]:mt-10" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,30 C480,60 960,0 1440,40 L1440,60 L0,60 Z" fill="#F3EDE5"/>
    </svg>
  </div>
</section>
