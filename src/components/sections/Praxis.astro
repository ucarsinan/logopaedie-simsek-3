---
import { Image } from 'astro:assets';
import { useTranslations } from '../../i18n/index';
import praxisImg from '../../assets/therapy/praxis-simsek-atmosphaere-duisburg.webp';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).praxis;
---

<section class="py-20 max-[640px]:py-14 bg-bg-alt relative overflow-hidden" id="praxis" aria-labelledby="praxis-heading">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={praxisImg}
      alt=""
      class="w-full h-full object-cover object-center opacity-[0.12]"
      widths={[800, 1400, 1920]}
      sizes="100vw"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="container relative z-10">
    <header class="text-center mb-14 max-[640px]:mb-10 flex flex-col items-center gap-4 max-[640px]:gap-3">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">{t.section_label}</span>
      <h2 class="font-display text-[clamp(1.85rem,4vw,2.75rem)] max-[640px]:text-[clamp(1.6rem,8vw,2.1rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="praxis-heading">{t.heading}</h2>
      <p class="text-[1.0625rem] max-[640px]:text-[0.97rem] text-text-muted leading-[1.7] max-[640px]:leading-[1.65] max-w-150 reveal reveal-delay-2">{t.description}</p>
    </header>
    <div class="grid grid-cols-2 gap-16 items-stretch max-[768px]:grid-cols-1 max-[768px]:gap-12 max-[640px]:gap-8">
      <div class="flex flex-col gap-6 max-[640px]:gap-4 h-full">
        <div class="flex gap-4 max-[640px]:gap-3 items-start reveal">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-0.75">{t.address_label}</div>
            <div class="text-[.9375rem] text-text font-medium">Tonhallenstraße 21, 47051 Duisburg<small class="block text-[.8125rem] text-text-muted font-normal mt-px">{t.address_sub}</small></div>
          </div>
        </div>
        <div class="flex gap-4 max-[640px]:gap-3 items-start reveal reveal-delay-1">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-0.75">{t.hours_label}</div>
            <div class="mt-2 flex flex-col gap-2">
              <div class="flex justify-between text-sm">
                <span class="text-text-muted">{t.hours_weekdays}</span>
                <span class="font-semibold text-text">08:00 – 18:00</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-text-muted">{t.hours_weekend}</span>
                <span class="text-text-light italic">{t.hours_closed}</span>
              </div>
            </div>
          </div>
        </div>
        <div class="flex gap-4 max-[640px]:gap-3 items-start reveal reveal-delay-2">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-0.75">{t.transit_label}</div>
            <div class="text-[.9375rem] text-text font-medium">{t.transit_value}<small class="block text-[.8125rem] text-text-muted font-normal mt-px">{t.transit_sub}</small></div>
          </div>
        </div>
        <div class="flex flex-col gap-3 reveal reveal-delay-3">
          <div class="flex items-center gap-3 bg-surface border border-border rounded-sm px-4.5 max-[640px]:px-4 py-3.5 max-[640px]:py-3 text-[.9375rem] max-[640px]:text-[0.9rem] font-medium text-text shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            {t.feature_rooms}
          </div>
          <div class="flex items-center gap-3 bg-surface border border-border rounded-sm px-4.5 max-[640px]:px-4 py-3.5 max-[640px]:py-3 text-[.9375rem] max-[640px]:text-[0.9rem] font-medium text-text shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            {t.feature_kids}
          </div>
          <div class="flex items-center gap-3 bg-surface border border-border rounded-sm px-4.5 max-[640px]:px-4 py-3.5 max-[640px]:py-3 text-[.9375rem] max-[640px]:text-[0.9rem] font-medium text-text shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            {t.feature_materials}
          </div>
          <div class="flex items-center gap-3 bg-surface border border-border rounded-sm px-4.5 max-[640px]:px-4 py-3.5 max-[640px]:py-3 text-[.9375rem] max-[640px]:text-[0.9rem] font-medium text-text shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            {t.feature_accessible}
          </div>
        </div>
      </div>
      <div class="reveal reveal-delay-2 h-full">
        <div class="bg-surface border border-border rounded-md max-[640px]:rounded-[20px] overflow-hidden shadow-sm h-full flex flex-col">
          <div class="min-h-65 max-[640px]:min-h-52 flex-1 bg-[linear-gradient(135deg,var(--color-primary-light)_0%,var(--color-surface-2)_100%)] flex flex-col items-center justify-center gap-3 max-[640px]:gap-2 text-primary">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div class="font-display text-[1.1rem] font-semibold text-primary">Tonhallenstraße 21</div>
            <div class="text-sm text-text-muted">47051 Duisburg</div>
            <a href="https://goo.gl/maps/cGPVX58woxP2" target="_blank" rel="noopener noreferrer" class="btn btn-primary text-sm py-2.5 px-5 mt-2 max-[640px]:w-full max-[640px]:justify-center max-[640px]:max-w-[16rem]">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {t.map_open}
            </a>
          </div>
          <div class="px-6 max-[640px]:px-5 py-5 border-t border-border flex items-center max-[640px]:items-stretch max-[640px]:flex-col justify-between gap-3">
            <p class="text-[.9rem] max-[640px]:text-[0.88rem] text-text-muted leading-normal [&_strong]:text-text"><strong>Praxis für Logopädie Şimşek</strong><br>{t.map_address_sub}<br>47051 Duisburg</p>
            <a href="tel:+4920334868690" class="btn btn-ghost text-sm py-2.5 px-5 max-[640px]:w-full max-[640px]:justify-center">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {t.call}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full mt-14 max-[640px]:mt-10" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,20 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#FAF8F5"/>
    </svg>
  </div>
</section>
