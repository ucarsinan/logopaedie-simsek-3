---
import { useTranslations } from '../../i18n/index';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).hero;
---

<section
  class="min-h-svh pt-[calc(var(--header-h)+var(--nav-h))] flex flex-col justify-center relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-[image:var(--noise-bg)] before:pointer-events-none before:z-0"
  aria-labelledby="hero-heading">
  <div class="absolute rounded-full pointer-events-none z-0 w-[clamp(300px,40vw,580px)] h-[clamp(300px,40vw,580px)] bg-[radial-gradient(circle,rgba(42,127,111,.12)_0%,transparent_70%)] -top-[10%] -right-[10%]" aria-hidden="true"></div>
  <div class="absolute rounded-full pointer-events-none z-0 w-[clamp(200px,30vw,420px)] h-[clamp(200px,30vw,420px)] bg-[radial-gradient(circle,rgba(196,113,79,.10)_0%,transparent_70%)] bottom-[10%] -left-[5%]" aria-hidden="true"></div>
  <div class="container relative z-[1] pt-20 pb-[60px]">
    <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-12 lg:gap-16 items-start">
      <!-- Left: Text content -->
      <div>
        <div class="inline-flex items-center gap-2 bg-primary-light text-primary text-[.8125rem] font-semibold tracking-[.06em] uppercase px-[14px] py-[6px] rounded-full mb-6 before:content-[''] before:block before:w-1.5 before:h-1.5 before:rounded-full before:bg-primary reveal">{t.badge}</div>
        <h1 class="font-display text-[clamp(2.75rem,7vw,5.5rem)] font-semibold leading-[1.05] tracking-[-0.02em] text-text mb-6 [&_em]:italic [&_em]:text-primary reveal reveal-delay-1" id="hero-heading">
          {t.heading_line1}<br><em>{t.heading_line2}</em><br>{t.heading_line3}
        </h1>
        <p class="text-[clamp(1rem,1.5vw,1.1875rem)] text-text-muted leading-[1.7] max-w-[560px] mb-10 reveal reveal-delay-2">
          {t.description}
        </p>
        <div class="flex flex-wrap gap-3 mb-14 reveal reveal-delay-3">
          <a href="#kontakt" class="btn btn-accent">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/></svg>
            {t.cta_primary}
          </a>
          <a href="#leistungen" class="btn btn-ghost">
            {t.cta_secondary}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        <div class="flex flex-wrap gap-3 reveal reveal-delay-4">
          <span class="inline-flex items-center gap-2 bg-surface border border-border rounded-full px-4 py-2 text-sm font-medium text-text-muted shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            {t.badge_station}
          </span>
          <span class="inline-flex items-center gap-2 bg-surface border border-border rounded-full px-4 py-2 text-sm font-medium text-text-muted shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {t.badge_lang}
          </span>
          <span class="inline-flex items-center gap-2 bg-surface border border-border rounded-full px-4 py-2 text-sm font-medium text-text-muted shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {t.badge_homevisit}
          </span>
          <span class="inline-flex items-center gap-2 bg-surface border border-border rounded-full px-4 py-2 text-sm font-medium text-text-muted shadow-sm [&_svg]:text-primary [&_svg]:shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {t.badge_age}
          </span>
        </div>
      </div>

      <!-- Right: Hero Photo -->
      <div class="hidden lg:flex items-center justify-center reveal reveal-delay-2">
        <div class="relative w-full">
          <div class="absolute -inset-3 rounded-4xl bg-[radial-gradient(ellipse_at_center,rgba(42,127,111,0.10)_0%,transparent_70%)] blur-xl pointer-events-none"></div>
          <img
            src="/hero-photo.webp"
            alt="Logopädin mit einem Kind und einem älteren Patienten in einer hellen Therapiepraxis"
            class="relative w-full h-auto max-h-[95vh] object-cover object-center rounded-[1.25rem] shadow-[0_8px_40px_rgba(28,25,22,0.13)]"
            width="1024"
            height="1536"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,40 C360,0 1080,80 1440,40 L1440,60 L0,60 Z" fill="#F3EDE5"/>
    </svg>
  </div>
</section>
