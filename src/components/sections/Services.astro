---
import { useTranslations } from '../../i18n/index';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).services;
const services = t.items;

// SVG icons per service (index-matched)
const icons = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
];
---

<section class="py-20 max-[640px]:py-14 bg-bg-alt" id="therapieangebot" aria-labelledby="services-heading">
  <div class="container">
    <header class="text-center mb-14 max-[640px]:mb-10 flex flex-col items-center gap-4 max-[640px]:gap-3">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">{t.section_label}</span>
      <h2 class="font-display text-[clamp(1.85rem,4vw,2.75rem)] max-[640px]:text-[clamp(1.6rem,8vw,2.1rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="services-heading">{t.heading}</h2>
      <p class="text-[1.0625rem] max-[640px]:text-[0.97rem] text-text-muted leading-[1.7] max-[640px]:leading-[1.65] max-w-150 reveal reveal-delay-2">{t.description}</p>
    </header>
    <div class="grid grid-cols-2 gap-6 max-[640px]:grid-cols-1 max-[640px]:gap-4">
      {services.map((service, i) => (
        <a href={service.href} class={`group block bg-surface border border-border rounded-md p-8 shadow-sm no-underline transition-[transform,box-shadow,border-color] duration-250 ease-out hover:-translate-y-1 hover:shadow-md hover:border-primary focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary reveal max-[640px]:rounded-[20px] max-[640px]:p-6${i > 0 ? ` reveal-delay-${i}` : ''}`}>
          <div class="w-13 h-13 rounded-sm bg-primary-light flex items-center justify-center mb-5 text-primary max-[640px]:w-11 max-[640px]:h-11 max-[640px]:mb-4" aria-hidden="true" set:html={icons[i]} />
          <h3 class="font-display text-xl font-semibold mb-2.5 text-text max-[640px]:text-[1.45rem] max-[640px]:leading-[1.15] max-[640px]:mb-2">{service.title}</h3>
          <p class="text-[.9375rem] text-text-muted leading-[1.65] max-[640px]:text-[0.9rem] max-[640px]:leading-[1.55]">{service.text}</p>
          <div class="flex flex-wrap gap-2 mt-4 max-[640px]:mt-3">
            {service.tags.map(tag => (
              <span class="bg-primary-light text-primary-dark text-xs font-semibold px-2.5 py-1 rounded-full max-[640px]:text-[0.7rem] max-[640px]:px-2 max-[640px]:py-0.5">{tag}</span>
            ))}
          </div>
          <span class="inline-flex items-center gap-1.5 mt-5 text-sm font-semibold text-primary group-hover:underline max-[640px]:mt-4">
            {t.more}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        </a>
      ))}
    </div>
    <div class="flex justify-center mt-10 max-[640px]:mt-8 reveal reveal-delay-3">
      <a href={lang === 'tr' ? '/terapi/' : '/therapie/'} class="btn btn-ghost max-[640px]:w-full max-[640px]:justify-center">
        {t.overview}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </div>
  <div class="block w-full overflow-hidden leading-0 [&_svg]:block [&_svg]:w-full mt-14 max-[640px]:mt-10" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,30 C360,60 1080,0 1440,35 L1440,60 L0,60 Z" fill="#2A7F6F"/>
    </svg>
  </div>
</section>
