<section class="py-24 bg-bg-alt" id="kontakt" aria-labelledby="kontakt-heading">
  <div class="container">
    <header class="text-center mb-14 flex flex-col items-center gap-4">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">Kontakt</span>
      <h2 class="font-display text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="kontakt-heading">Termin anfragen</h2>
      <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-150 reveal reveal-delay-2">Nehmen Sie Kontakt auf – wir beraten Sie gerne und finden gemeinsam den passenden Therapieplatz für Sie oder Ihr Kind.</p>
    </header>
    <div class="grid grid-cols-2 gap-12 items-start max-[768px]:grid-cols-1">
      <form
        class="bg-surface border border-border rounded-md p-9 shadow-sm reveal"
        id="contactForm"
        action="/api/kontakt"
        method="POST"
        novalidate
        aria-label="Terminanfrage"
      >
        <!-- Honeypot: hidden from real users, catches bots -->
        <div class="hidden" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="grid grid-cols-2 gap-4 mb-5 max-[480px]:grid-cols-1">
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-semibold text-text" for="vorname">Vorname <span class="text-accent" aria-hidden="true">*</span></label>
            <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="text" id="vorname" name="vorname" autocomplete="given-name" required placeholder="Max" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-semibold text-text" for="nachname">Nachname <span class="text-accent" aria-hidden="true">*</span></label>
            <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="text" id="nachname" name="nachname" autocomplete="family-name" required placeholder="Mustermann" />
          </div>
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="email">E-Mail <span class="text-accent" aria-hidden="true">*</span></label>
          <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="email" id="email" name="email" autocomplete="email" required placeholder="max@beispiel.de" />
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="telefon">Telefon</label>
          <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="tel" id="telefon" name="telefon" autocomplete="tel" placeholder="+49 203 ..." />
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="bereich">Therapiebereich</label>
          <select class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" id="bereich" name="bereich">
            <option value="">Bitte wählen...</option>
            <option value="sprache">Sprachstörungen</option>
            <option value="sprechen">Sprechstörungen</option>
            <option value="stimme">Stimmstörungen</option>
            <option value="schlucken">Schluckstörungen (Dysphagie)</option>
            <option value="allgemein">Allgemeine Beratung</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="nachricht">Ihre Nachricht</label>
          <textarea class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none resize-y min-h-30 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" id="nachricht" name="nachricht" placeholder="Schildern Sie kurz Ihr Anliegen – wir melden uns schnellstmöglich bei Ihnen."></textarea>
        </div>
        <p class="text-[.8125rem] text-text-muted leading-normal mt-1"><span class="text-accent">*</span> Pflichtfelder. Ihre Daten werden vertraulich behandelt und nicht weitergegeben.</p>
        <div aria-live="polite" aria-atomic="true" id="formStatus" class="hidden mt-4 px-4 py-3 rounded-sm text-sm font-medium"></div>
        <button type="submit" id="submitBtn" class="btn btn-accent w-full mt-6 justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Anfrage senden
        </button>
      </form>
      <div class="flex flex-col gap-5">
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-1">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Telefon</div>
            <div class="text-[.9375rem] font-semibold text-text [&_a]:text-primary [&_a:hover]:underline"><a href="tel:+4920334868690">0203 – 34 86 86 90</a></div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">Mo–Fr 08:00–18:00 Uhr</div>
          </div>
        </div>
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-2">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">E-Mail</div>
            <div class="text-[.9375rem] font-semibold text-text [&_a]:text-primary [&_a:hover]:underline"><a href="mailto:info@logopaedie-simsek.de">info@logopaedie-simsek.de</a></div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">Wir antworten innerhalb von 24 Stunden</div>
          </div>
        </div>
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-3">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Adresse</div>
            <div class="text-[.9375rem] font-semibold text-text">Tonhallenstraße 21, 47051 Duisburg</div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">3. OG · Aufzug vorhanden · 2 min. vom HBf</div>
          </div>
        </div>
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-4">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">Sprachen</div>
            <div class="text-[.9375rem] font-semibold text-text">Deutsch &amp; Türkçe</div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">Therapy available in both languages</div>
          </div>
        </div>
        <div class="bg-accent-light border border-[rgba(196,113,79,.2)] rounded-md p-6">
          <p class="text-[.9375rem] text-text leading-[1.7]"><strong>Kassenrezept oder Selbstzahler?</strong><br>Wir arbeiten mit allen gesetzlichen Krankenkassen und nehmen auch Privatpatienten sowie Selbstzahler an. Bei Fragen zur Abrechnung beraten wir Sie gerne.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const statusEl = document.getElementById('formStatus') as HTMLElement | null;

  if (form && statusEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
      if (!btn) return;

      // Basic client-side validation
      const email = (form.querySelector('#email') as HTMLInputElement)?.value.trim();
      const vorname = (form.querySelector('#vorname') as HTMLInputElement)?.value.trim();
      const nachname = (form.querySelector('#nachname') as HTMLInputElement)?.value.trim();
      if (!vorname || !nachname || !email) {
        statusEl.textContent = 'Bitte füllen Sie alle Pflichtfelder aus.';
        statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-accent-light text-accent border border-[rgba(196,113,79,.3)]';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Wird gesendet…';

      statusEl.className = 'hidden';
      statusEl.textContent = '';

      try {
        const res = await fetch('/api/kontakt', {
          method: 'POST',
          body: new FormData(form),
        });
        const json = await res.json() as { success: boolean; error?: string };

        if (json.success) {
          statusEl.textContent = '✓ Ihre Anfrage wurde erfolgreich gesendet. Wir melden uns innerhalb von 24 Stunden.';
          statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-primary-light text-primary border border-[rgba(42,127,111,.3)]';
          form.reset();
          btn.disabled = false;
          btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Anfrage senden';
        } else {
          statusEl.textContent = json.error ?? 'Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut.';
          statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-accent-light text-accent border border-[rgba(196,113,79,.3)]';
          btn.disabled = false;
          btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Anfrage senden';
        }
      } catch {
        statusEl.textContent = 'Verbindungsfehler. Bitte prüfen Sie Ihre Internetverbindung und versuchen Sie es erneut.';
        statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-accent-light text-accent border border-[rgba(196,113,79,.3)]';
        btn.disabled = false;
        btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Anfrage senden';
      }
    });
  }
</script>
