---
import { useTranslations } from '../../i18n/index';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).kontakt;
---

<section class="py-24 bg-bg-alt" id="kontakt" aria-labelledby="kontakt-heading">
  <div class="container">
    <header class="text-center mb-14 flex flex-col items-center gap-4">
      <span class="text-xs font-semibold tracking-widest uppercase text-primary reveal">{t.section_label}</span>
      <h2 class="font-display text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] text-text reveal reveal-delay-1" id="kontakt-heading">{t.heading}</h2>
      <p class="text-[1.0625rem] text-text-muted leading-[1.7] max-w-150 reveal reveal-delay-2">{t.description}</p>
    </header>
    <div class="grid grid-cols-2 gap-12 items-start max-[768px]:grid-cols-1">
      <form
        class="bg-surface border border-border rounded-md p-9 shadow-sm reveal"
        id="contactForm"
        action="/api/kontakt"
        method="POST"
        novalidate
        aria-label={t.form_aria}
        data-msg-validation={t.js_validation}
        data-msg-sending={t.js_sending}
        data-msg-success={t.js_success}
        data-msg-error={t.js_error_fallback}
        data-msg-network={t.js_network_error}
        data-submit-label={t.submit}
      >
        <!-- Honeypot: hidden from real users, catches bots -->
        <div class="hidden" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="lang" value={lang} />

        <div class="grid grid-cols-2 gap-4 mb-5 max-[480px]:grid-cols-1">
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-semibold text-text" for="vorname">{t.label_firstname} <span class="text-accent" aria-hidden="true">*</span></label>
            <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="text" id="vorname" name="vorname" autocomplete="given-name" required placeholder={t.placeholder_firstname} />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-semibold text-text" for="nachname">{t.label_lastname} <span class="text-accent" aria-hidden="true">*</span></label>
            <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="text" id="nachname" name="nachname" autocomplete="family-name" required placeholder={t.placeholder_lastname} />
          </div>
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="email">{t.label_email} <span class="text-accent" aria-hidden="true">*</span></label>
          <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="email" id="email" name="email" autocomplete="email" required placeholder={t.placeholder_email} />
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="telefon">{t.label_phone}</label>
          <input class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" type="tel" id="telefon" name="telefon" autocomplete="tel" placeholder={t.placeholder_phone} />
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="bereich">{t.label_area}</label>
          <select class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none min-h-12 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" id="bereich" name="bereich">
            <option value="">{t.placeholder_area}</option>
            {t.areas.map(area => (
              <option value={area.value}>{area.label}</option>
            ))}
          </select>
        </div>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="text-sm font-semibold text-text" for="nachricht">{t.label_message}</label>
          <textarea class="w-full px-4 py-3 border-[1.5px] border-border rounded-sm text-[.9375rem] text-text bg-bg outline-none resize-y min-h-30 transition-[border-color,box-shadow] duration-200 focus:border-primary focus:shadow-[0_0_0_3px_rgba(42,127,111,.12)]" id="nachricht" name="nachricht" placeholder={t.placeholder_message}></textarea>
        </div>
        <p class="text-[.8125rem] text-text-muted leading-normal mt-1"><span class="text-accent">*</span> {t.privacy_note}</p>
        <div aria-live="polite" aria-atomic="true" id="formStatus" class="hidden mt-4 px-4 py-3 rounded-sm text-sm font-medium"></div>
        <button type="submit" id="submitBtn" class="btn btn-accent w-full mt-6 justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          <span id="submitBtnText">{t.submit}</span>
        </button>
      </form>
      <div class="flex flex-col gap-5">
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-1">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">{t.info_phone_label}</div>
            <div class="text-[.9375rem] font-semibold text-text [&_a]:text-primary [&_a:hover]:underline"><a href="tel:+4920334868690">0203 – 34 86 86 90</a></div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">{t.info_phone_hours}</div>
          </div>
        </div>
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-2">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">{t.info_email_label}</div>
            <div class="text-[.9375rem] font-semibold text-text [&_a]:text-primary [&_a:hover]:underline"><a href="mailto:info@logopaedie-simsek.de">info@logopaedie-simsek.de</a></div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">{t.info_email_hours}</div>
          </div>
        </div>
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-3">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">{t.info_address_label}</div>
            <div class="text-[.9375rem] font-semibold text-text">Tonhallenstraße 21, 47051 Duisburg</div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">{t.info_address_sub}</div>
          </div>
        </div>
        <div class="bg-surface border border-border rounded-md p-6 shadow-sm flex gap-4 items-start reveal reveal-delay-4">
          <div class="w-11 h-11 bg-primary-light rounded-sm flex items-center justify-center text-primary shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div>
            <div class="text-[.8rem] font-bold tracking-[.06em] uppercase text-text-light mb-1">{t.info_lang_label}</div>
            <div class="text-[.9375rem] font-semibold text-text">{t.info_lang_value}</div>
            <div class="text-[.8125rem] text-text-muted mt-0.5">{t.info_lang_sub}</div>
          </div>
        </div>
        <div class="bg-accent-light border border-[rgba(196,113,79,.2)] rounded-md p-6">
          <p class="text-[.9375rem] text-text leading-[1.7]" set:html={t.insurance_note} />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const statusEl = document.getElementById('formStatus') as HTMLElement | null;

  if (form && statusEl) {
    const msgValidation = form.dataset.msgValidation ?? 'Bitte füllen Sie alle Pflichtfelder aus.';
    const msgSending = form.dataset.msgSending ?? 'Wird gesendet…';
    const msgSuccess = form.dataset.msgSuccess ?? '✓ Ihre Anfrage wurde erfolgreich gesendet.';
    const msgError = form.dataset.msgError ?? 'Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut.';
    const msgNetwork = form.dataset.msgNetwork ?? 'Verbindungsfehler. Bitte prüfen Sie Ihre Internetverbindung.';
    const submitLabel = form.dataset.submitLabel ?? 'Anfrage senden';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
      const btnText = document.getElementById('submitBtnText') as HTMLSpanElement | null;
      if (!btn || !btnText) return;

      const email = (form.querySelector('#email') as HTMLInputElement)?.value.trim();
      const vorname = (form.querySelector('#vorname') as HTMLInputElement)?.value.trim();
      const nachname = (form.querySelector('#nachname') as HTMLInputElement)?.value.trim();
      if (!vorname || !nachname || !email) {
        statusEl.textContent = msgValidation;
        statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-accent-light text-accent border border-[rgba(196,113,79,.3)]';
        return;
      }

      btn.disabled = true;
      btnText.textContent = msgSending;
      statusEl.className = 'hidden';
      statusEl.textContent = '';

      try {
        const res = await fetch('/api/kontakt', {
          method: 'POST',
          body: new FormData(form),
        });
        const json = await res.json() as { success: boolean; error?: string };

        if (json.success) {
          statusEl.textContent = msgSuccess;
          statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-primary-light text-primary border border-[rgba(42,127,111,.3)]';
          form.reset();
          btn.disabled = false;
          btnText.textContent = submitLabel;
        } else {
          statusEl.textContent = json.error ?? msgError;
          statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-accent-light text-accent border border-[rgba(196,113,79,.3)]';
          btn.disabled = false;
          btnText.textContent = submitLabel;
        }
      } catch {
        statusEl.textContent = msgNetwork;
        statusEl.className = 'block mt-4 px-4 py-3 rounded-sm text-sm font-medium bg-accent-light text-accent border border-[rgba(196,113,79,.3)]';
        btn.disabled = false;
        btnText.textContent = submitLabel;
      }
    });
  }
</script>
