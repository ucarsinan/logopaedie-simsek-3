---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a
  href="https://goo.gl/maps/cGPVX58woxP2"
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "group inline-flex items-center gap-3 rounded-sm border border-border bg-surface px-4 py-3",
    "hover:border-primary/40 hover:bg-primary-light/40 transition-colors",
    className,
  ]}
  aria-label="Praxis für Logopädie Şimşek auf Google ansehen – 4,5 von 5 Sternen, 17 Bewertungen"
>
  <span
    class="shrink-0 w-9 h-9 flex items-center justify-center rounded-full bg-white shadow-sm border border-border/50"
    aria-hidden="true"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18">
      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
    </svg>
  </span>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-1.5">
      <span class="text-[#FBBC05] text-sm leading-none tracking-wider" aria-hidden="true">★★★★★</span>
      <span class="text-sm font-semibold text-text">4,5</span>
    </div>
    <p class="text-xs text-text-muted mt-0.5">17 Bewertungen auf Google</p>
  </div>

  <svg
    width="16" height="16" viewBox="0 0 24 24" fill="none"
    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
    class="text-text-muted group-hover:text-primary transition-colors shrink-0"
    aria-hidden="true"
  >
    <path d="m9 18 6-6-6-6"/>
  </svg>
</a>
