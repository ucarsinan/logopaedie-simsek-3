---
import { useTranslations } from '../i18n/index';

interface Props {
  lang?: 'de' | 'tr';
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang).nav;
---

<nav class="fixed left-0 right-0 z-[1000] bg-surface/95 backdrop-blur-sm border-b border-border top-[var(--header-h)]" id="site-nav" role="navigation" aria-label={t.aria_main}>
  <div class="container flex items-center h-[var(--nav-h)] gap-1">
    <!-- Desktop links -->
    <ul class="flex items-center h-full gap-0.5 max-[991px]:hidden" role="list">
      <li><a href={t.links.home} class="nav-link" aria-current="page">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        {t.home}</a></li>
      <li><a href={t.links.therapy} class="nav-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        {t.therapy}</a></li>
      <li><a href={t.links.team} class="nav-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        {t.team}</a></li>
      <li><a href={t.links.jobs} class="nav-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        {t.jobs}</a></li>
      <li><a href={t.links.contact} class="nav-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {t.contact}</a></li>
    </ul>

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Mobile: address + phone (tablet only, 768–991px) -->
    <a href="https://goo.gl/maps/cGPVX58woxP2" target="_blank" rel="noopener noreferrer"
       class="hidden max-[991px]:inline-flex max-[767px]:hidden items-center gap-2 px-3 py-1.5 rounded-md bg-primary text-white text-xs font-medium tracking-wide no-underline transition-colors duration-200 hover:bg-primary-dark shrink-0"
       aria-label="Adresse öffnen">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      Tonhallenstr. 21 – 47051 Duisburg
    </a>

    <!-- Mobile: compact buttons (< 768px) -->
    <div class="hidden max-[767px]:flex items-center gap-2">
      <a href="https://goo.gl/maps/cGPVX58woxP2" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-md bg-primary text-white text-[.7rem] font-medium no-underline transition-colors duration-200 hover:bg-primary-dark"
         aria-label="Adresse öffnen">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Tonhallenstr. 21
      </a>
      <a href="tel:+4920334868690"
         class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-md bg-primary text-white text-[.7rem] font-medium no-underline transition-colors duration-200 hover:bg-primary-dark"
         aria-label="Anrufen">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        0203 – 34 86 86 90
      </a>
    </div>

    <!-- Hamburger -->
    <button
      class="group hidden max-[991px]:flex flex-col gap-[5px] w-10 h-10 items-center justify-center rounded-md transition-colors duration-200 hover:bg-primary-light shrink-0 ml-2"
      id="hamburger"
      data-open="false"
      aria-label={t.aria_menu_open}
      aria-expanded="false">
      <span class="block w-[22px] h-0.5 bg-text rounded-sm transition-[transform,opacity] duration-300 group-data-[open=true]:translate-y-[7px] group-data-[open=true]:rotate-45"></span>
      <span class="block w-[22px] h-0.5 bg-text rounded-sm transition-[transform,opacity] duration-300 group-data-[open=true]:opacity-0"></span>
      <span class="block w-[22px] h-0.5 bg-text rounded-sm transition-[transform,opacity] duration-300 group-data-[open=true]:-translate-y-[7px] group-data-[open=true]:-rotate-45"></span>
    </button>
  </div>
</nav>

<!-- Mobile menu (slide-down) -->
<div
  class="fixed left-0 right-0 bg-surface z-[999] border-b border-border shadow-md top-[calc(var(--header-h)+var(--nav-h))] transition-[max-height,opacity] duration-300 ease-in-out max-h-0 opacity-0 overflow-hidden data-[open=true]:max-h-[500px] data-[open=true]:opacity-100"
  id="mobileMenu"
  data-open="false"
  role="navigation"
  aria-label={t.aria_mobile}>
  <div class="px-6 pb-6 pt-2">
    <a href={t.links.home} class="mobile-link inline-flex items-center gap-3 w-full text-[.9375rem] font-medium text-text py-3 border-b border-border transition-colors duration-200 hover:text-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
      {t.home}</a>
    <a href={t.links.therapy} class="mobile-link inline-flex items-center gap-3 w-full text-[.9375rem] font-medium text-text py-3 border-b border-border transition-colors duration-200 hover:text-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      {t.therapy}</a>
    <a href={t.links.team} class="mobile-link inline-flex items-center gap-3 w-full text-[.9375rem] font-medium text-text py-3 border-b border-border transition-colors duration-200 hover:text-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      {t.team}</a>
    <a href={t.links.jobs} class="mobile-link inline-flex items-center gap-3 w-full text-[.9375rem] font-medium text-text py-3 border-b border-border transition-colors duration-200 hover:text-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      {t.jobs}</a>
    <a href={t.links.contact} class="mobile-link inline-flex items-center gap-3 w-full text-[.9375rem] font-medium text-text py-3 border-b border-border transition-colors duration-200 hover:text-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      {t.contact}</a>
  </div>
</div>

<style>
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.2s, background-color 0.2s;
    white-space: nowrap;
    position: relative;
  }
  .nav-link:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-light);
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .nav-link.active {
    color: var(--color-primary);
    font-weight: 600;
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 1px;
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobileMenu') as HTMLElement;

  function setOpen(open: boolean) {
    mobileMenu.dataset.open = String(open);
    hamburger.dataset.open = String(open);
    hamburger.setAttribute('aria-expanded', String(open));
    const pageLang = document.documentElement.lang;
    hamburger.setAttribute('aria-label', open
      ? (pageLang === 'tr' ? 'Menüyü kapat' : 'Menü schließen')
      : (pageLang === 'tr' ? 'Menüyü aç' : 'Menü öffnen'));
  }

  hamburger.addEventListener('click', () => {
    setOpen(mobileMenu.dataset.open !== 'true');
  });

  document.querySelectorAll('#mobileMenu a').forEach(link => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>
