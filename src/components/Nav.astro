<div
  class="hidden data-[open=true]:block fixed left-0 right-0 bg-bg border-b border-border px-6 pb-6 pt-4 z-[999] shadow-md top-[calc(var(--header-h)+var(--nav-h))]"
  id="mobileMenu"
  data-open="false"
  role="navigation"
  aria-label="Mobile Navigation">
  <a href="#" class="mobile-link block text-base font-medium text-text py-[13px] border-b border-border transition-colors duration-200 hover:text-primary">Home</a>
  <a href="#leistungen" class="mobile-link block text-base font-medium text-text py-[13px] border-b border-border transition-colors duration-200 hover:text-primary">Therapie &amp; Leistungen</a>
  <a href="#praxis" class="mobile-link block text-base font-medium text-text py-[13px] border-b border-border transition-colors duration-200 hover:text-primary">Praxis &amp; Standort</a>
  <a href="#team" class="mobile-link block text-base font-medium text-text py-[13px] border-b border-border transition-colors duration-200 hover:text-primary">Team</a>
  <a href="#karriere" class="mobile-link block text-base font-medium text-text py-[13px] border-b border-border transition-colors duration-200 hover:text-primary">Karriere</a>
  <a href="#kontakt" class="mobile-link block text-base font-medium text-text py-[13px] border-b border-border transition-colors duration-200 hover:text-primary">Kontakt</a>
  <a href="#kontakt" class="btn btn-accent w-full justify-center mt-4">Termin anfragen</a>
</div>

<script>
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobileMenu') as HTMLElement;

  function setOpen(open: boolean) {
    mobileMenu.dataset.open = String(open);
    hamburger.dataset.open = String(open);
    hamburger.setAttribute('aria-expanded', String(open));
    hamburger.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
  }

  hamburger.addEventListener('click', () => {
    setOpen(mobileMenu.dataset.open !== 'true');
  });

  document.querySelectorAll('#mobileMenu a').forEach(link => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>
