---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { useTranslations } from '../i18n/index';

interface HreflangAlternate {
  lang: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  additionalSchemas?: Record<string, unknown>[];
  lang?: 'de' | 'tr';
  hreflangAlternates?: HreflangAlternate[];
  lastUpdated?: string;
}

const {
  title,
  description,
  ogImage = '/therapy/og-logopaedie-simsek-duisburg.webp',
  additionalSchemas = [],
  lang = 'de',
  hreflangAlternates = [],
  lastUpdated = '2026-04-23',
} = Astro.props;

const siteUrl = 'https://logopaedie-simsek.de';
const normalizeAbsoluteUrl = (url: string) => {
  const absoluteUrl = url.startsWith('http')
    ? url
    : `${siteUrl}${url.startsWith('/') ? '' : '/'}${url}`;
  const parsedUrl = new URL(absoluteUrl);

  if (!parsedUrl.pathname.includes('.') && !parsedUrl.pathname.endsWith('/')) {
    parsedUrl.pathname = `${parsedUrl.pathname}/`;
  }

  return parsedUrl.toString();
};

const canonicalUrl = normalizeAbsoluteUrl(`${siteUrl}${Astro.url.pathname}`);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const ogLocale = lang === 'tr' ? 'tr_TR' : 'de_DE';
const alternateOgLocale = lang === 'tr' ? 'de_DE' : 'tr_TR';
const inLanguage = lang === 'tr' ? 'tr-DE' : 'de-DE';
const normalizedHreflangAlternates = hreflangAlternates.map((alt) => ({
  ...alt,
  url: normalizeAbsoluteUrl(alt.url),
}));
const s = useTranslations(lang).schema;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": `${siteUrl}/`,
      "name": "Praxis für Logopädie Şimşek",
      "inLanguage": ["de-DE", "tr-DE"],
      "publisher": { "@id": `${siteUrl}/#business` }
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      "url": canonicalUrl,
      "name": title,
      "description": description,
      "inLanguage": inLanguage,
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "about": { "@id": `${siteUrl}/#business` },
      "publisher": { "@id": `${siteUrl}/#business` },
      "reviewedBy": {
        "@type": "Person",
        "name": "Emel Şimşek-Uçar",
        "jobTitle": s.founder_title
      },
      "primaryImageOfPage": ogImageUrl,
      "dateModified": lastUpdated
    },
    {
      "@type": ["LocalBusiness", "MedicalBusiness"],
      "@id": `${siteUrl}/#business`,
      "name": "Praxis für Logopädie Şimşek",
      "description": s.business_description,
      "url": siteUrl,
      "telephone": "+4920334868690",
      "faxNumber": "+4920334868691",
      "email": "info@logopaedie-simsek.de",
      "image": `${siteUrl}/logo.png`,
      "logo": `${siteUrl}/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Tonhallenstraße 21",
        "addressLocality": "Duisburg",
        "postalCode": "47051",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.4292,
        "longitude": 6.7681
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:00",
          "closes": "18:00"
        }
      ],
      "priceRange": "€€",
      "paymentAccepted": "Kassenrezept, Privatrezept, Selbstzahler",
      "availableLanguage": [
        { "@type": "Language", "name": "German" },
        { "@type": "Language", "name": "Turkish" }
      ],
      "areaServed": {
        "@type": "City",
        "name": "Duisburg"
      },
      "founder": {
        "@type": "Person",
        "name": "Emel Şimşek-Uçar",
        "jobTitle": s.founder_title
      },
      "sameAs": [
        "https://www.facebook.com/logopaediesimsek/",
        "https://www.google.com/maps/place/Praxis+f%C3%BCr+Logop%C3%A4die+%C5%9Eim%C5%9Fek/@51.4301471,6.7647419,17z"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": s.offer_catalog_name,
        "itemListElement": s.services.map(sv => ({
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": sv.name, "url": `${siteUrl}${sv.url}` }
        }))
      }
    }
  ]
};
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternates -->
    {normalizedHreflangAlternates.map(alt => (
      <link rel="alternate" hreflang={alt.lang} href={alt.url} />
    ))}

    <!-- Favicons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <meta name="theme-color" content="#2a7f6f" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />
    <meta property="og:site_name" content="Praxis für Logopädie Şimşek" />
    <meta property="article:modified_time" content={lastUpdated} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="author" content="Praxis für Logopädie Şimşek" />
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content="Duisburg" />
    <meta name="geo.position" content="51.4292;6.7681" />
    <meta name="ICBM" content="51.4292, 6.7681" />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {additionalSchemas.map(schema => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {gaMeasurementId && (
      <script is:inline define:vars={{ gaMeasurementId }}>
        (function () {
          window.dataLayer = window.dataLayer || [];
          window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };

          function analyticsAccepted() {
            return true;
          }

          function loadAnalytics() {
            if (window.__simsekGaLoaded || !gaMeasurementId) return;
            var script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(gaMeasurementId);
            document.head.appendChild(script);
            window.__simsekGaLoaded = true;
            window.gtag('js', new Date());
          }

          function trackPageview() {
            if (!analyticsAccepted()) return;
            window.gtag('config', gaMeasurementId, {
              page_path: location.pathname + location.search,
              page_title: document.title,
              anonymize_ip: true,
              storage: 'none',       // kein GA-Cookie → kein Consent-Banner nötig (DSGVO)
              client_storage: 'none'
            });
          }

          loadAnalytics();

          document.addEventListener('DOMContentLoaded', function () {
            trackPageview();
          });
          document.addEventListener('astro:page-load', function () {
            trackPageview();
          });
        })();
      </script>
    )}

    <!-- robots -->
    <meta name="robots" content={
      ['/impressum', '/datenschutz', '/barrierefreiheit'].some(p => Astro.url.pathname.startsWith(p))
        ? 'noindex, nofollow'
        : 'index, follow'
    } />

    <!-- View Transitions: eliminates page-reload flash on navigation -->
    <ClientRouter />
  </head>
  <body>
    <slot />
    <script>
      function initPage() {
        // Scroll Reveal
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('reveal-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // Smooth Scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
          anchor.addEventListener('click', (e) => {
            const id = (anchor as HTMLAnchorElement).getAttribute('href');
            if (id === '#') return;
            const target = document.querySelector(id!);
            if (target) {
              e.preventDefault();
              const headerH = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-h')) || 80;
              const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--nav-h')) || 50;
              window.scrollTo({
                top: target.getBoundingClientRect().top + window.scrollY - headerH - navH - 16,
                behavior: 'smooth',
              });
            }
          });
        });

        document.querySelectorAll('[data-google-map-load]').forEach(button => {
          if (button instanceof HTMLButtonElement && button.dataset.ready !== 'true') {
            button.dataset.ready = 'true';
            button.addEventListener('click', () => {
              const wrapper = button.closest('[data-google-map]');
              const iframe = wrapper?.querySelector('iframe[data-src]');
              if (iframe instanceof HTMLIFrameElement && iframe.dataset.src) {
                iframe.src = iframe.dataset.src;
                iframe.removeAttribute('hidden');
                button.closest('[data-google-map-placeholder]')?.setAttribute('hidden', '');
              }
            });
          }
        });
      }

      document.addEventListener('astro:page-load', initPage);
    </script>
  </body>
</html>
