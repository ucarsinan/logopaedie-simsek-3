---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface HreflangAlternate {
  lang: string;
  url: string;
}

interface RelatedService {
  title: string;
  href: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  serviceTitle: string;
  breadcrumbLabel: string;
  tags: string[];
  relatedServices: RelatedService[];
  additionalSchemas?: Record<string, unknown>[];
  lang?: 'de' | 'tr';
  hreflangAlternates?: HreflangAlternate[];
  alternateUrl?: string;
}

const {
  title,
  description,
  serviceTitle,
  breadcrumbLabel,
  tags,
  relatedServices,
  additionalSchemas = [],
  lang = 'de',
  hreflangAlternates = [],
  alternateUrl,
} = Astro.props;

const isTR = lang === 'tr';
const t = {
  home: isTR ? 'Ana Sayfa' : 'Startseite',
  services: isTR ? 'Terapi Alanları' : 'Therapie',
  servicesHref: isTR ? '/terapi/' : '/therapie/',
  appointment: isTR ? 'Randevu Talebi' : 'Termin anfragen',
  ctaHeading: isTR ? 'İlk adıma hazır mısınız?' : 'Bereit für den ersten Schritt?',
  ctaText: isTR
    ? 'Duisburg\'daki muayenehanemizde Almanca veya Türkçe ilk görüşmenizi şimdi ayarlayın.'
    : 'Vereinbaren Sie jetzt Ihr Erstgespräch in unserer Praxis in Duisburg – auf Deutsch oder Türkisch.',
  ctaButton: isTR ? 'Randevu Talebi' : 'Termin anfragen',
  moreInfo: isTR ? 'Daha fazla bilgi' : 'Mehr erfahren',
  relatedHeading: isTR ? 'Diğer Terapi Alanları' : 'Weitere Therapiebereiche',
  kontaktHref: isTR ? '/iletisim/' : '/kontakt/',
};
---

<Layout title={title} description={description} additionalSchemas={additionalSchemas} lang={lang} hreflangAlternates={hreflangAlternates}>
  <Header lang={lang} {...(alternateUrl !== undefined && { alternateUrl })} />
  <Nav lang={lang} {...(alternateUrl !== undefined && { alternateUrl })} />
  <main class="pt-[calc(var(--header-h)+var(--nav-h))]">
    <!-- Breadcrumb -->
    <nav class="bg-bg-alt border-b border-border" aria-label={isTR ? 'İçerik Yolu' : 'Breadcrumb'}>
      <div class="container py-3 max-[640px]:py-2.5">
        <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap" role="list">
          <li><a href={isTR ? '/anasayfa/' : '/'} class="hover:text-primary transition-colors">{t.home}</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li><a href={t.servicesHref} class="hover:text-primary transition-colors">{t.services}</a></li>
          <li aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-text font-medium" aria-current="page">{breadcrumbLabel}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-bg-alt pt-12 max-[640px]:pt-9 pb-9 max-[640px]:pb-7 border-b border-border">
      <div class="container">
        <div class="flex flex-wrap gap-2 mb-5 max-[640px]:mb-4">
          {tags.map(tag => (
            <span class="bg-primary-light text-primary text-xs font-semibold px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
        <h1 class="font-display text-[clamp(1.85rem,5vw,3.25rem)] max-[640px]:text-[clamp(1.55rem,8vw,2.15rem)] font-semibold leading-[1.1] max-[640px]:leading-[1.08] text-text mb-5 max-[640px]:mb-4">{serviceTitle}</h1>
        <div class="flex flex-col sm:flex-row flex-wrap gap-3">
          <a href={t.kontaktHref} class="btn btn-accent max-[640px]:w-full">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/></svg>
            {t.appointment}
          </a>
          <a href="tel:+4920334868690" class="btn btn-ghost max-[640px]:w-full">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.9-1.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            0203 – 34 86 86 90
          </a>
        </div>
      </div>
    </section>

    <!-- Main content (slot) -->
    <div class="container py-12 max-[640px]:py-9">
      <div class="prose-section">
        <slot />
      </div>
    </div>

    <!-- CTA Banner -->
    <section class="bg-primary py-12 max-[640px]:py-10" aria-label={isTR ? 'Randevu Talebi' : 'Termin anfragen'}>
      <div class="container text-center flex flex-col items-center gap-5">
        <h2 class="font-display text-[clamp(1.4rem,3vw,2.25rem)] max-[640px]:text-[clamp(1.3rem,7vw,1.8rem)] font-semibold text-white leading-[1.2]">{t.ctaHeading}</h2>
        <p class="text-white/80 text-lg max-[640px]:text-[0.97rem] max-w-xl">{t.ctaText}</p>
        <a href={t.kontaktHref} class="btn btn-outline-white max-[640px]:w-full max-[640px]:max-w-[20rem]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/></svg>
          {t.ctaButton}
        </a>
      </div>
    </section>

    <!-- Related Services -->
    {relatedServices.length > 0 && (
      <section class="py-12 max-[640px]:py-10 bg-bg" aria-labelledby="related-heading">
        <div class="container">
          <h2 class="font-display text-2xl max-[640px]:text-[1.5rem] font-semibold text-text mb-8 max-[640px]:mb-6" id="related-heading">{t.relatedHeading}</h2>
          <div class="grid grid-cols-3 gap-6 max-[860px]:grid-cols-2 max-[640px]:grid-cols-1">
            {relatedServices.map(s => (
              <a href={s.href} class="bg-surface border border-border rounded-md max-[640px]:rounded-[18px] p-6 max-[640px]:p-5 shadow-sm hover:border-primary hover:-translate-y-0.5 hover:shadow-md transition-[transform,box-shadow,border-color] duration-200 flex flex-col gap-2 no-underline group">
                <span class="font-semibold text-text group-hover:text-primary transition-colors">{s.title}</span>
                <span class="text-sm text-text-muted leading-[1.6]">{s.description}</span>
                <span class="text-xs font-semibold text-primary mt-auto inline-flex items-center gap-1">
                  {t.moreInfo}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .prose-section :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .prose-section :global(h3) {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-section :global(p) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-section :global(ul) {
    list-style: none;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose-section :global(ul li) {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    padding-left: 1.5rem;
    position: relative;
  }
  .prose-section :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .prose-section :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }
  .prose-section :global(.info-box) {
    background: var(--color-primary-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 6px 6px 0;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }
  .prose-section :global(.info-box p) {
    margin: 0;
  }

  @media (max-width: 640px) {
    .prose-section :global(h2) {
      margin-top: 2rem;
      font-size: 1.3rem;
      margin-bottom: 0.65rem;
    }
    .prose-section :global(h3) {
      font-size: 1.05rem;
      margin-top: 1.6rem;
    }
    .prose-section :global(p),
    .prose-section :global(ul li) {
      font-size: 0.9rem;
      line-height: 1.65;
    }
    .prose-section :global(.info-box) {
      padding: 1rem 1.1rem;
      margin: 1.25rem 0;
    }
  }
</style>
